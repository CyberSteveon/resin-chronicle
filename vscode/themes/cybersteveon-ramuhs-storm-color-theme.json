{
  "name": "Ramuh's Storm",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#06060C",
    "editor.foreground": "#8878A0",
    "editorCursor.foreground": "#7B2FBE",
    "editor.lineHighlightBackground": "#0C0A18",
    "editor.selectionBackground": "#2E144ACC",
    "editor.selectionHighlightBackground": "#2E144A66",
    "editor.inactiveSelectionBackground": "#2E144A88",
    "editor.findMatchBackground": "#E0D0FF44",
    "editor.findMatchHighlightBackground": "#E0D0FF22",
    "editor.findMatchBorder": "#E0D0FF",
    "editor.wordHighlightBackground": "#2E144A66",
    "editor.wordHighlightStrongBackground": "#2E144ACC",
    "editorLineNumber.foreground": "#705D95",
    "editorLineNumber.activeForeground": "#7B2FBE",
    "editorWhitespace.foreground": "#705D95",
    "editorIndentGuide.background1": "#18181E",
    "editorIndentGuide.activeBackground1": "#705D95",
    "editorRuler.foreground": "#18181E",
    "editorBracketMatch.background": "#2E144A66",
    "editorBracketMatch.border": "#645A78",
    "editorError.foreground": "#E04050",
    "editorWarning.foreground": "#805AB0",
    "editorInfo.foreground": "#C8A8FF",
    "editorHint.foreground": "#9060E0",
    "editorGutter.background": "#06060C",
    "editorGutter.addedBackground": "#B8A8D0",
    "editorGutter.modifiedBackground": "#C8A030",
    "editorGutter.deletedBackground": "#E04050",
    "editorGroupHeader.tabsBackground": "#020208",
    "tab.activeBackground": "#06060C",
    "tab.inactiveBackground": "#020208",
    "tab.activeForeground": "#8878A0",
    "tab.inactiveForeground": "#705D95",
    "tab.activeBorderTop": "#7B2FBE",
    "tab.border": "#18181E",
    "titleBar.activeBackground": "#020208",
    "titleBar.activeForeground": "#8878A0",
    "titleBar.inactiveBackground": "#020208",
    "titleBar.inactiveForeground": "#705D95",
    "activityBar.background": "#101016",
    "activityBar.foreground": "#8878A0",
    "activityBar.inactiveForeground": "#705D95",
    "activityBar.border": "#18181E",
    "activityBarBadge.background": "#7B2FBE",
    "activityBarBadge.foreground": "#06060C",
    "sideBar.background": "#101016",
    "sideBar.foreground": "#8878A0",
    "sideBar.border": "#18181E",
    "list.activeSelectionBackground": "#2E144ACC",
    "list.activeSelectionForeground": "#8878A0",
    "list.hoverBackground": "#0C0A18",
    "list.highlightForeground": "#7B2FBE",
    "statusBar.background": "#020208",
    "statusBar.foreground": "#705D95",
    "statusBar.border": "#18181E",
    "statusBarItem.remoteBackground": "#7B2FBE",
    "statusBarItem.remoteForeground": "#06060C",
    "panel.background": "#06060C",
    "panel.border": "#18181E",
    "terminal.background": "#06060C",
    "terminal.foreground": "#8878A0",
    "terminal.ansiBlack": "#020208",
    "terminal.ansiRed": "#E04050",
    "terminal.ansiGreen": "#B8A8D0",
    "terminal.ansiYellow": "#C8A030",
    "terminal.ansiBlue": "#C8A8FF",
    "terminal.ansiMagenta": "#8B3ECF",
    "terminal.ansiCyan": "#9060E0",
    "terminal.ansiWhite": "#705D95",
    "terminal.ansiBrightBlack": "#705D95",
    "terminal.ansiBrightRed": "#E04050",
    "terminal.ansiBrightGreen": "#B8A8D0",
    "terminal.ansiBrightYellow": "#E0D0FF",
    "terminal.ansiBrightBlue": "#C8A8FF",
    "terminal.ansiBrightMagenta": "#D060C8",
    "terminal.ansiBrightCyan": "#7B2FBE",
    "terminal.ansiBrightWhite": "#8878A0",
    "terminalCursor.foreground": "#7B2FBE",
    "input.background": "#101016",
    "input.foreground": "#8878A0",
    "input.border": "#18181E",
    "input.placeholderForeground": "#705D95",
    "button.background": "#7B2FBE",
    "button.foreground": "#06060C",
    "badge.background": "#7B2FBE",
    "badge.foreground": "#06060C",
    "focusBorder": "#7B2FBE66",
    "scrollbarSlider.background": "#705D9522",
    "scrollbarSlider.hoverBackground": "#705D9533",
    "gitDecoration.addedResourceForeground": "#B8A8D0",
    "gitDecoration.modifiedResourceForeground": "#C8A030",
    "gitDecoration.deletedResourceForeground": "#E04050",
    "gitDecoration.ignoredResourceForeground": "#705D95",
    "diffEditor.insertedTextBackground": "#B8A8D018",
    "diffEditor.removedTextBackground": "#E0405018",
    "minimap.findMatchHighlight": "#E0D0FF",
    "minimap.selectionHighlight": "#2E144ACC",
    "peekView.border": "#7B2FBE",
    "peekViewEditor.background": "#101016",
    "peekViewResult.background": "#020208",
    "breadcrumb.foreground": "#705D95",
    "breadcrumb.focusForeground": "#8878A0",
    "editorWidget.background": "#101016",
    "editorSuggestWidget.background": "#101016",
    "editorSuggestWidget.selectedBackground": "#2E144ACC",
    "editorHoverWidget.background": "#101016"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#8878A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#705D95",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#B8A8D0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C8A030"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#C8A030"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#706080"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8B3ECF"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#9060E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#C8A8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#A060D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#A060D8"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#805AB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D060C8"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#8878A0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#805AB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#507860"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#80C0E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E0D0FF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D060C8"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#8B3ECF"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#705D95"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#645A78"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#695E9E"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C8A8FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#805AB0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#E04050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#6A5DA0"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#C8A030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#706080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#A060D8",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#805AB0"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D060C8"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C8A8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#A060D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B8A8D0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#9060E0"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#C8A8FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#C8A8FF",
      "bold": true
    },
    "method": {
      "foreground": "#C8A8FF",
      "bold": true
    },
    "class": {
      "foreground": "#A060D8",
      "bold": true
    },
    "struct": {
      "foreground": "#A060D8",
      "bold": true
    },
    "interface": {
      "foreground": "#A060D8",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#A060D8",
      "bold": true
    },
    "enumMember": {
      "foreground": "#805AB0",
      "bold": true
    },
    "type": {
      "foreground": "#A060D8"
    },
    "typeParameter": {
      "foreground": "#805AB0",
      "italic": true
    },
    "variable": {
      "foreground": "#8878A0"
    },
    "variable.readonly": {
      "foreground": "#D060C8"
    },
    "property": {
      "foreground": "#507860"
    },
    "parameter": {
      "foreground": "#805AB0",
      "italic": true
    },
    "keyword": {
      "foreground": "#8B3ECF"
    },
    "string": {
      "foreground": "#B8A8D0"
    },
    "number": {
      "foreground": "#E0D0FF"
    },
    "comment": {
      "foreground": "#705D95",
      "italic": true
    },
    "decorator": {
      "foreground": "#D060C8"
    },
    "namespace": {
      "foreground": "#695E9E"
    },
    "macro": {
      "foreground": "#706080",
      "bold": true
    },
    "lifetime": {
      "foreground": "#C8A030",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#80C0E0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#9060E0",
      "bold": true
    },
    "operator": {
      "foreground": "#8B3ECF"
    },
    "*.unsafe": {
      "foreground": "#E04050"
    }
  }
}