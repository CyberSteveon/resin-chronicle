    "editorInfo.foreground": "#1A8A47",
    "editorHint.foreground": "#5DADE2",
    "editorGutter.background": "#060D08",
    "editorGutter.addedBackground": "#C8D8E0",
    "editorGutter.modifiedBackground": "#E67E22",
    "editorGutter.deletedBackground": "#E74C3C",
    "editorGroupHeader.tabsBackground": "#020904",
    "tab.activeBackground": "#060D08",
    "tab.inactiveBackground": "#020904",
    "tab.activeForeground": "#A8B8C0",
    "tab.inactiveForeground": "#88613B",
    "tab.activeBorderTop": "#D4AF37",
    "tab.border": "#181F1A",
    "titleBar.activeBackground": "#020904",
    "titleBar.activeForeground": "#A8B8C0",
    "titleBar.inactiveBackground": "#020904",
    "titleBar.inactiveForeground": "#88613B",
    "activityBar.background": "#101712",
    "activityBar.foreground": "#A8B8C0",
    "activityBar.inactiveForeground": "#88613B",
    "activityBar.border": "#181F1A",
    "activityBarBadge.background": "#D4AF37",
    "activityBarBadge.foreground": "#060D08",
    "sideBar.background": "#101712",
    "sideBar.foreground": "#A8B8C0",
    "sideBar.border": "#181F1A",
    "list.activeSelectionBackground": "#4E4518CC",
    "list.activeSelectionForeground": "#A8B8C0",
    "list.hoverBackground": "#0C1A0E",
    "list.highlightForeground": "#D4AF37",
    "statusBar.background": "#020904",
    "statusBar.foreground": "#88613B",
    "statusBar.border": "#181F1A",
    "statusBarItem.remoteBackground": "#D4AF37",
    "statusBarItem.remoteForeground": "#060D08",
    "panel.background": "#060D08",
    "panel.border": "#181F1A",
    "terminal.background": "#060D08",
    "terminal.foreground": "#A8B8C0",
    "terminal.ansiBlack": "#020904",
    "terminal.ansiRed": "#E74C3C",
    "terminal.ansiGreen": "#C8D8E0",
    "terminal.ansiYellow": "#E67E22",
    "terminal.ansiBlue": "#1A8A47",
    "terminal.ansiMagenta": "#D4AF37",
    "terminal.ansiCyan": "#5DADE2",
    "terminal.ansiWhite": "#88613B",
    "terminal.ansiBrightBlack": "#88613B",
    "terminal.ansiBrightRed": "#E74C3C",
    "terminal.ansiBrightGreen": "#C8D8E0",
    "terminal.ansiBrightYellow": "#2ECC71",
    "terminal.ansiBrightBlue": "#1A8A47",
    "terminal.ansiBrightMagenta": "#9B59B6",
    "terminal.ansiBrightCyan": "#D4AF37",
    "terminal.ansiBrightWhite": "#A8B8C0",
    "terminalCursor.foreground": "#D4AF37",
    "input.background": "#101712",
    "input.foreground": "#A8B8C0",
    "input.border": "#181F1A",
    "input.placeholderForeground": "#88613B",
    "button.background": "#D4AF37",
    "button.foreground": "#060D08",
    "badge.background": "#D4AF37",
    "badge.foreground": "#060D08",
    "focusBorder": "#D4AF3766",
    "scrollbarSlider.background": "#88613B22",
    "scrollbarSlider.hoverBackground": "#88613B33",
    "gitDecoration.addedResourceForeground": "#C8D8E0",
    "gitDecoration.modifiedResourceForeground": "#E67E22",
    "gitDecoration.deletedResourceForeground": "#E74C3C",
    "gitDecoration.ignoredResourceForeground": "#88613B",
    "diffEditor.insertedTextBackground": "#C8D8E018",
    "diffEditor.removedTextBackground": "#E74C3C18",
    "minimap.findMatchHighlight": "#D4AF37",
    "minimap.selectionHighlight": "#4E4518CC",
    "peekView.border": "#D4AF37",
    "peekViewEditor.background": "#101712",
    "peekViewResult.background": "#020904",
    "breadcrumb.foreground": "#88613B",
    "breadcrumb.focusForeground": "#A8B8C0",
    "editorWidget.background": "#101712",
    "editorSuggestWidget.background": "#101712",
    "editorSuggestWidget.selectedBackground": "#4E4518CC",
    "editorHoverWidget.background": "#101712"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A8B8C0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#88613B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C8D8E0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#E67E22"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#E67E22"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#90A8B0"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D4AF37"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#5DADE2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#1A8A47",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#4CAF7D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#4CAF7D"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#A8882A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#9B59B6"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A8B8C0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#4CAF7D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#A8882A"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#D0E8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#2ECC71"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#9B59B6"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D4AF37"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#88613B"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#6A8088"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#2ECC71"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A8882A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#E74C3C",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7CBA6A"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#E67E22",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#90A8B0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#4CAF7D",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#A8882A"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#9B59B6"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#1A8A47",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#4CAF7D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C8D8E0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#2ECC71"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#1A8A47",
      "bold": true
    },
    "method": {
      "foreground": "#1A8A47",
      "bold": true
    },
    "class": {
      "foreground": "#4CAF7D",
      "bold": true
    },
    "struct": {
      "foreground": "#4CAF7D",
      "bold": true
    },
    "interface": {
      "foreground": "#4CAF7D",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#4CAF7D",
      "bold": true
    },
    "enumMember": {
      "foreground": "#A8882A",
      "bold": true
    },
    "type": {
      "foreground": "#4CAF7D"
    },
    "typeParameter": {
      "foreground": "#4CAF7D",
      "italic": true
    },
    "variable": {
      "foreground": "#A8B8C0"
    },
    "variable.readonly": {
      "foreground": "#9B59B6"
    },
    "property": {
      "foreground": "#A8882A"
    },
    "parameter": {
      "foreground": "#4CAF7D",
      "italic": true
    },
    "keyword": {
      "foreground": "#D4AF37"
    },
    "string": {
      "foreground": "#C8D8E0"
    },
    "number": {
      "foreground": "#2ECC71"
    },
    "comment": {
      "foreground": "#88613B",
      "italic": true
    },
    "decorator": {
      "foreground": "#9B59B6"
    },
    "namespace": {
      "foreground": "#8B6914"
    },
    "macro": {
      "foreground": "#90A8B0",
      "bold": true
    },
    "lifetime": {
      "foreground": "#E67E22",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#D0E8F0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#5DADE2",
      "bold": true
    },
    "operator": {
      "foreground": "#D4AF37"
    },
    "*.unsafe": {
      "foreground": "#E74C3C"
    }
  }
}