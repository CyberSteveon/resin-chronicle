    },
    "variable": {
      "foreground": "#A8B8C0"
    },
    "variable.readonly": {
      "foreground": "#9B59B6"
    },
    "property": {
      "foreground": "#A8882A"
    },
    "parameter": {
      "foreground": "#4CAF7D",
      "italic": true
    },
    "keyword": {
      "foreground": "#D4AF37"
    },
    "modifier": {
      "foreground": "#D4AF37"
    },
    "string": {
      "foreground": "#C8D8E0"
    },
    "number": {
      "foreground": "#2ECC71"
    },
    "comment": {
      "foreground": "#4A3520",
      "italic": true
    },
    "decorator": {
      "foreground": "#9B59B6"
    },
    "namespace": {
      "foreground": "#8B6914"
    },
    "macro": {
      "foreground": "#90A8B0",
      "bold": true
    },
    "lifetime": {
      "foreground": "#E67E22",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#D0E8F0",
      "italic": true
    },
    "selfParameter": {
      "foreground": "#D0E8F0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#5DADE2",
      "bold": true
    },
    "operator": {
      "foreground": "#D4AF37"
    },
    "*.mutable": {
      "underline": true
    },
    "*.unsafe": {
      "foreground": "#E74C3C"
    }
  }
}