{
  "name": "Neon Resin Mono",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0E1415",
    "editor.foreground": "#94E8F3",
    "editorCursor.foreground": "#7EE3F0",
    "editor.lineHighlightBackground": "#162021",
    "editor.selectionBackground": "#355F61CC",
    "editor.selectionHighlightBackground": "#355F6166",
    "editor.inactiveSelectionBackground": "#355F6188",
    "editor.findMatchBackground": "#19CDE544",
    "editor.findMatchHighlightBackground": "#19CDE522",
    "editor.findMatchBorder": "#19CDE5",
    "editor.wordHighlightBackground": "#355F6166",
    "editor.wordHighlightStrongBackground": "#355F61CC",
    "editorLineNumber.foreground": "#0E7583",
    "editorLineNumber.activeForeground": "#7EE3F0",
    "editorWhitespace.foreground": "#0E7583",
    "editorIndentGuide.background1": "#202627",
    "editorIndentGuide.activeBackground1": "#0E7583",
    "editorRuler.foreground": "#202627",
    "editorBracketMatch.background": "#355F6166",
    "editorBracketMatch.border": "#36D3E8",
    "editorError.foreground": "#56DAEC",
    "editorWarning.foreground": "#53DAEB",
    "editorInfo.foreground": "#7EE3F0",
    "editorHint.foreground": "#14A2B4",
    "editorGutter.background": "#0E1415",
    "editorGutter.addedBackground": "#5EDCED",
    "editorGutter.modifiedBackground": "#19CDE5",
    "editorGutter.deletedBackground": "#56DAEC",
    "editorGroupHeader.tabsBackground": "#0A1011",
    "tab.activeBackground": "#0E1415",
    "tab.inactiveBackground": "#0A1011",
    "tab.activeForeground": "#94E8F3",
    "tab.inactiveForeground": "#0E7583",
    "tab.activeBorderTop": "#7EE3F0",
    "tab.border": "#202627",
    "titleBar.activeBackground": "#0A1011",
    "titleBar.activeForeground": "#94E8F3",
    "titleBar.inactiveBackground": "#0A1011",
    "titleBar.inactiveForeground": "#0E7583",
    "activityBar.background": "#181E1F",
    "activityBar.foreground": "#94E8F3",
    "activityBar.inactiveForeground": "#0E7583",
    "activityBar.border": "#202627",
    "activityBarBadge.background": "#7EE3F0",
    "activityBarBadge.foreground": "#0E1415",
    "sideBar.background": "#181E1F",
    "sideBar.foreground": "#94E8F3",
    "sideBar.border": "#202627",
    "list.activeSelectionBackground": "#355F61CC",
    "list.activeSelectionForeground": "#94E8F3",
    "list.hoverBackground": "#162021",
    "list.highlightForeground": "#7EE3F0",
    "statusBar.background": "#0A1011",
    "statusBar.foreground": "#0E7583",
    "statusBar.border": "#202627",
    "statusBarItem.remoteBackground": "#7EE3F0",
    "statusBarItem.remoteForeground": "#0E1415",
    "panel.background": "#0E1415",
    "panel.border": "#202627",
    "terminal.background": "#0E1415",
    "terminal.foreground": "#94E8F3",
    "terminal.ansiBlack": "#0A1011",
    "terminal.ansiRed": "#56DAEC",
    "terminal.ansiGreen": "#5EDCED",
    "terminal.ansiYellow": "#19CDE5",
    "terminal.ansiBlue": "#7EE3F0",
    "terminal.ansiMagenta": "#42D6E9",
    "terminal.ansiCyan": "#14A2B4",
    "terminal.ansiWhite": "#0E7583",
    "terminal.ansiBrightBlack": "#0E7583",
    "terminal.ansiBrightRed": "#56DAEC",
    "terminal.ansiBrightGreen": "#5EDCED",
    "terminal.ansiBrightYellow": "#19CDE5",
    "terminal.ansiBrightBlue": "#7EE3F0",
    "terminal.ansiBrightMagenta": "#42D6E9",
    "terminal.ansiBrightCyan": "#7EE3F0",
    "terminal.ansiBrightWhite": "#94E8F3",
    "terminalCursor.foreground": "#7EE3F0",
    "input.background": "#181E1F",
    "input.foreground": "#94E8F3",
    "input.border": "#202627",
    "input.placeholderForeground": "#0E7583",
    "button.background": "#7EE3F0",
    "button.foreground": "#0E1415",
    "badge.background": "#7EE3F0",
    "badge.foreground": "#0E1415",
    "focusBorder": "#7EE3F066",
    "scrollbarSlider.background": "#0E758322",
    "scrollbarSlider.hoverBackground": "#0E758333",
    "gitDecoration.addedResourceForeground": "#5EDCED",
    "gitDecoration.modifiedResourceForeground": "#19CDE5",
    "gitDecoration.deletedResourceForeground": "#56DAEC",
    "gitDecoration.ignoredResourceForeground": "#0E7583",
    "diffEditor.insertedTextBackground": "#5EDCED18",
    "diffEditor.removedTextBackground": "#56DAEC18",
    "minimap.findMatchHighlight": "#19CDE5",
    "minimap.selectionHighlight": "#355F61CC",
    "peekView.border": "#7EE3F0",
    "peekViewEditor.background": "#181E1F",
    "peekViewResult.background": "#0A1011",
    "breadcrumb.foreground": "#0E7583",
    "breadcrumb.focusForeground": "#94E8F3",
    "editorWidget.background": "#181E1F",
    "editorSuggestWidget.background": "#181E1F",
    "editorSuggestWidget.selectedBackground": "#355F61CC",
    "editorHoverWidget.background": "#181E1F"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#94E8F3"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#0E7583",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#5EDCED"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#19CDE5"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#19CDE5"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#B2EEF6"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#42D6E9"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#14A2B4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#7EE3F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#19CDE5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#19CDE5"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#53DAEB",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#42D6E9"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#94E8F3"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#53DAEB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#5FDCED"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#BFF1F7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#19CDE5"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#42D6E9"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#42D6E9"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#0E7583"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#36D3E8"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#7EE3F0"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#7EE3F0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#53DAEB"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#56DAEC",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#57DBEC"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#19CDE5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#B2EEF6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#19CDE5",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#53DAEB"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#42D6E9"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7EE3F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#19CDE5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5EDCED"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#14A2B4"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7EE3F0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#7EE3F0",
      "bold": true
    },
    "method": {
      "foreground": "#7EE3F0",
      "bold": true
    },
    "class": {
      "foreground": "#19CDE5",
      "bold": true
    },
    "struct": {
      "foreground": "#19CDE5",
      "bold": true
    },
    "interface": {
      "foreground": "#19CDE5",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#19CDE5",
      "bold": true
    },
    "enumMember": {
      "foreground": "#53DAEB",
      "bold": true
    },
    "type": {
      "foreground": "#19CDE5"
    },
    "typeParameter": {
      "foreground": "#53DAEB",
      "italic": true
    },
    "variable": {
      "foreground": "#94E8F3"
    },
    "variable.readonly": {
      "foreground": "#42D6E9"
    },
    "property": {
      "foreground": "#5FDCED"
    },
    "parameter": {
      "foreground": "#53DAEB",
      "italic": true
    },
    "keyword": {
      "foreground": "#42D6E9"
    },
    "string": {
      "foreground": "#5EDCED"
    },
    "number": {
      "foreground": "#19CDE5"
    },
    "comment": {
      "foreground": "#0E7583",
      "italic": true
    },
    "decorator": {
      "foreground": "#42D6E9"
    },
    "namespace": {
      "foreground": "#7EE3F0"
    },
    "macro": {
      "foreground": "#B2EEF6",
      "bold": true
    },
    "lifetime": {
      "foreground": "#19CDE5",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#BFF1F7",
      "italic": true
    },
    "builtinType": {
      "foreground": "#14A2B4",
      "bold": true
    },
    "operator": {
      "foreground": "#42D6E9"
    },
    "*.unsafe": {
      "foreground": "#56DAEC"
    }
  }
}