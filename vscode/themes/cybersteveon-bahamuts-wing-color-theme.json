{
  "name": "Bahamut's Wing",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#050814",
    "editor.foreground": "#5870A0",
    "editorCursor.foreground": "#1E90FF",
    "editor.lineHighlightBackground": "#0A1020",
    "editor.selectionBackground": "#1E90FF44",
    "editor.selectionHighlightBackground": "#1E90FF22",
    "editor.inactiveSelectionBackground": "#1E90FF22",
    "editor.findMatchBackground": "#FFE86044",
    "editor.findMatchHighlightBackground": "#FFE86022",
    "editor.findMatchBorder": "#FFE860",
    "editor.wordHighlightBackground": "#1E90FF22",
    "editor.wordHighlightStrongBackground": "#1E90FF44",
    "editorLineNumber.foreground": "#4466AB",
    "editorLineNumber.activeForeground": "#1E90FF",
    "editorWhitespace.foreground": "#4466AB",
    "editorIndentGuide.background1": "#171A26",
    "editorIndentGuide.activeBackground1": "#4466AB",
    "editorRuler.foreground": "#171A26",
    "editorBracketMatch.background": "#1E90FF22",
    "editorBracketMatch.border": "#475F8F",
    "editorError.foreground": "#FF3040",
    "editorWarning.foreground": "#C8A000",
    "editorInfo.foreground": "#1E90FF",
    "editorHint.foreground": "#1468C8",
    "editorGutter.background": "#050814",
    "editorGutter.addedBackground": "#7898D0",
    "editorGutter.modifiedBackground": "#A08030",
    "editorGutter.deletedBackground": "#FF3040",
    "editorGroupHeader.tabsBackground": "#010410",
    "tab.activeBackground": "#050814",
    "tab.inactiveBackground": "#010410",
    "tab.activeForeground": "#5870A0",
    "tab.inactiveForeground": "#4466AB",
    "tab.activeBorderTop": "#1E90FF",
    "tab.border": "#171A26",
    "titleBar.activeBackground": "#010410",
    "titleBar.activeForeground": "#5870A0",
    "titleBar.inactiveBackground": "#010410",
    "titleBar.inactiveForeground": "#4466AB",
    "activityBar.background": "#0F121E",
    "activityBar.foreground": "#5870A0",
    "activityBar.inactiveForeground": "#4466AB",
    "activityBar.border": "#171A26",
    "activityBarBadge.background": "#1E90FF",
    "activityBarBadge.foreground": "#050814",
    "sideBar.background": "#0F121E",
    "sideBar.foreground": "#5870A0",
    "sideBar.border": "#171A26",
    "list.activeSelectionBackground": "#1E90FF44",
    "list.activeSelectionForeground": "#5870A0",
    "list.hoverBackground": "#0A1020",
    "list.highlightForeground": "#1E90FF",
    "statusBar.background": "#010410",
    "statusBar.foreground": "#4466AB",
    "statusBar.border": "#171A26",
    "statusBarItem.remoteBackground": "#1E90FF",
    "statusBarItem.remoteForeground": "#050814",
    "panel.background": "#050814",
    "panel.border": "#171A26",
    "terminal.background": "#050814",
    "terminal.foreground": "#5870A0",
    "terminal.ansiBlack": "#010410",
    "terminal.ansiRed": "#FF3040",
    "terminal.ansiGreen": "#7898D0",
    "terminal.ansiYellow": "#A08030",
    "terminal.ansiBlue": "#1E90FF",
    "terminal.ansiMagenta": "#FFD700",
    "terminal.ansiCyan": "#1468C8",
    "terminal.ansiWhite": "#4466AB",
    "terminal.ansiBrightBlack": "#4466AB",
    "terminal.ansiBrightRed": "#FF3040",
    "terminal.ansiBrightGreen": "#7898D0",
    "terminal.ansiBrightYellow": "#FFE860",
    "terminal.ansiBrightBlue": "#1E90FF",
    "terminal.ansiBrightMagenta": "#D04080",
    "terminal.ansiBrightCyan": "#1E90FF",
    "terminal.ansiBrightWhite": "#5870A0",
    "terminalCursor.foreground": "#1E90FF",
    "input.background": "#0F121E",
    "input.foreground": "#5870A0",
    "input.border": "#171A26",
    "input.placeholderForeground": "#4466AB",
    "button.background": "#1E90FF",
    "button.foreground": "#050814",
    "badge.background": "#1E90FF",
    "badge.foreground": "#050814",
    "focusBorder": "#1E90FF66",
    "scrollbarSlider.background": "#4466AB22",
    "scrollbarSlider.hoverBackground": "#4466AB33",
    "gitDecoration.addedResourceForeground": "#7898D0",
    "gitDecoration.modifiedResourceForeground": "#A08030",
    "gitDecoration.deletedResourceForeground": "#FF3040",
    "gitDecoration.ignoredResourceForeground": "#4466AB",
    "diffEditor.insertedTextBackground": "#7898D018",
    "diffEditor.removedTextBackground": "#FF304018",
    "minimap.findMatchHighlight": "#FFE860",
    "minimap.selectionHighlight": "#1E90FF44",
    "peekView.border": "#1E90FF",
    "peekViewEditor.background": "#0F121E",
    "peekViewResult.background": "#010410",
    "breadcrumb.foreground": "#4466AB",
    "breadcrumb.focusForeground": "#5870A0",
    "editorWidget.background": "#0F121E",
    "editorSuggestWidget.background": "#0F121E",
    "editorSuggestWidget.selectedBackground": "#1E90FF44",
    "editorHoverWidget.background": "#0F121E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#5870A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4466AB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#7898D0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#A08030"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#A08030"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#4E6083"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#1468C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#1E90FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#4060C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#4060C0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#C8A000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D04080"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#5870A0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C8A000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#3D657A"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60D0F8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#FFE860"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D04080"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#4466AB"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#475F8F"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#4966A0"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#1E90FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C8A000"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF3040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#4466AA"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#A08030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#4E6083",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#4060C0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#C8A000"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#D04080"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#1E90FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#4060C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#7898D0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#1468C8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#1E90FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#1E90FF",
      "bold": true
    },
    "method": {
      "foreground": "#1E90FF",
      "bold": true
    },
    "class": {
      "foreground": "#4060C0",
      "bold": true
    },
    "struct": {
      "foreground": "#4060C0",
      "bold": true
    },
    "interface": {
      "foreground": "#4060C0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#4060C0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#C8A000",
      "bold": true
    },
    "type": {
      "foreground": "#4060C0"
    },
    "typeParameter": {
      "foreground": "#C8A000",
      "italic": true
    },
    "variable": {
      "foreground": "#5870A0"
    },
    "variable.readonly": {
      "foreground": "#D04080"
    },
    "property": {
      "foreground": "#3D657A"
    },
    "parameter": {
      "foreground": "#C8A000",
      "italic": true
    },
    "keyword": {
      "foreground": "#FFD700"
    },
    "string": {
      "foreground": "#7898D0"
    },
    "number": {
      "foreground": "#FFE860"
    },
    "comment": {
      "foreground": "#4466AB",
      "italic": true
    },
    "decorator": {
      "foreground": "#D04080"
    },
    "namespace": {
      "foreground": "#4966A0"
    },
    "macro": {
      "foreground": "#4E6083",
      "bold": true
    },
    "lifetime": {
      "foreground": "#A08030",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60D0F8",
      "italic": true
    },
    "builtinType": {
      "foreground": "#1468C8",
      "bold": true
    },
    "operator": {
      "foreground": "#FFD700"
    },
    "*.unsafe": {
      "foreground": "#FF3040"
    }
  }
}