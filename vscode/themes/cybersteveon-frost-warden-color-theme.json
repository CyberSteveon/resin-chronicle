{
  "name": "Frost Warden",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#060C12",
    "editor.foreground": "#A8B8C8",
    "editorCursor.foreground": "#5BC8F0",
    "editor.lineHighlightBackground": "#0C1620",
    "editor.selectionBackground": "#234D5FCC",
    "editor.selectionHighlightBackground": "#234D5F66",
    "editor.inactiveSelectionBackground": "#234D5F88",
    "editor.findMatchBackground": "#40D4A044",
    "editor.findMatchHighlightBackground": "#40D4A022",
    "editor.findMatchBorder": "#40D4A0",
    "editor.wordHighlightBackground": "#234D5F66",
    "editor.wordHighlightStrongBackground": "#234D5FCC",
    "editorLineNumber.foreground": "#486C84",
    "editorLineNumber.activeForeground": "#5BC8F0",
    "editorWhitespace.foreground": "#486C84",
    "editorIndentGuide.background1": "#181E24",
    "editorIndentGuide.activeBackground1": "#486C84",
    "editorRuler.foreground": "#181E24",
    "editorBracketMatch.background": "#234D5F66",
    "editorBracketMatch.border": "#607080",
    "editorError.foreground": "#D04040",
    "editorWarning.foreground": "#90A8B8",
    "editorInfo.foreground": "#5BC8F0",
    "editorHint.foreground": "#28A878",
    "editorGutter.background": "#060C12",
    "editorGutter.addedBackground": "#A8D8F0",
    "editorGutter.modifiedBackground": "#C09040",
    "editorGutter.deletedBackground": "#D04040",
    "editorGroupHeader.tabsBackground": "#02080E",
    "tab.activeBackground": "#060C12",
    "tab.inactiveBackground": "#02080E",
    "tab.activeForeground": "#A8B8C8",
    "tab.inactiveForeground": "#486C84",
    "tab.activeBorderTop": "#5BC8F0",
    "tab.border": "#181E24",
    "titleBar.activeBackground": "#02080E",
    "titleBar.activeForeground": "#A8B8C8",
    "titleBar.inactiveBackground": "#02080E",
    "titleBar.inactiveForeground": "#486C84",
    "activityBar.background": "#10161C",
    "activityBar.foreground": "#A8B8C8",
    "activityBar.inactiveForeground": "#486C84",
    "activityBar.border": "#181E24",
    "activityBarBadge.background": "#5BC8F0",
    "activityBarBadge.foreground": "#060C12",
    "sideBar.background": "#10161C",
    "sideBar.foreground": "#A8B8C8",
    "sideBar.border": "#181E24",
    "list.activeSelectionBackground": "#234D5FCC",
    "list.activeSelectionForeground": "#A8B8C8",
    "list.hoverBackground": "#0C1620",
    "list.highlightForeground": "#5BC8F0",
    "statusBar.background": "#02080E",
    "statusBar.foreground": "#486C84",
    "statusBar.border": "#181E24",
    "statusBarItem.remoteBackground": "#5BC8F0",
    "statusBarItem.remoteForeground": "#060C12",
    "panel.background": "#060C12",
    "panel.border": "#181E24",
    "terminal.background": "#060C12",
    "terminal.foreground": "#A8B8C8",
    "terminal.ansiBlack": "#02080E",
    "terminal.ansiRed": "#D04040",
    "terminal.ansiGreen": "#A8D8F0",
    "terminal.ansiYellow": "#C09040",
    "terminal.ansiBlue": "#5BC8F0",
    "terminal.ansiMagenta": "#D0EEF8",
    "terminal.ansiCyan": "#28A878",
    "terminal.ansiWhite": "#486C84",
    "terminal.ansiBrightBlack": "#486C84",
    "terminal.ansiBrightRed": "#D04040",
    "terminal.ansiBrightGreen": "#A8D8F0",
    "terminal.ansiBrightYellow": "#90C8E0",
    "terminal.ansiBrightBlue": "#5BC8F0",
    "terminal.ansiBrightMagenta": "#8070C0",
    "terminal.ansiBrightCyan": "#5BC8F0",
    "terminal.ansiBrightWhite": "#A8B8C8",
    "terminalCursor.foreground": "#5BC8F0",
    "input.background": "#10161C",
    "input.foreground": "#A8B8C8",
    "input.border": "#181E24",
    "input.placeholderForeground": "#486C84",
    "button.background": "#5BC8F0",
    "button.foreground": "#060C12",
    "badge.background": "#5BC8F0",
    "badge.foreground": "#060C12",
    "focusBorder": "#5BC8F066",
    "scrollbarSlider.background": "#486C8422",
    "scrollbarSlider.hoverBackground": "#486C8433",
    "gitDecoration.addedResourceForeground": "#A8D8F0",
    "gitDecoration.modifiedResourceForeground": "#C09040",
    "gitDecoration.deletedResourceForeground": "#D04040",
    "gitDecoration.ignoredResourceForeground": "#486C84",
    "diffEditor.insertedTextBackground": "#A8D8F018",
    "diffEditor.removedTextBackground": "#D0404018",
    "minimap.findMatchHighlight": "#40D4A0",
    "minimap.selectionHighlight": "#234D5FCC",
    "peekView.border": "#5BC8F0",
    "peekViewEditor.background": "#10161C",
    "peekViewResult.background": "#02080E",
    "breadcrumb.foreground": "#486C84",
    "breadcrumb.focusForeground": "#A8B8C8",
    "editorWidget.background": "#10161C",
    "editorSuggestWidget.background": "#10161C",
    "editorSuggestWidget.selectedBackground": "#234D5FCC",
    "editorHoverWidget.background": "#10161C"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A8B8C8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#486C84",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#A8D8F0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C09040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#C09040"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#6898B0"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D0EEF8"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#28A878",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#5BC8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C8D8E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C8D8E8"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#90A8B8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#8070C0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A8B8C8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#90A8B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#3A7860"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60D8E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#90C8E0"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#8070C0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D0EEF8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#486C84"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#607080"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#406880"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#5BC8F0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#90A8B8"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#D04040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7090A0"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#C09040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#6898B0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C8D8E8",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#90A8B8"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#8070C0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#5BC8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C8D8E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A8D8F0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#28A878"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#5BC8F0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#5BC8F0",
      "bold": true
    },
    "method": {
      "foreground": "#5BC8F0",
      "bold": true
    },
    "class": {
      "foreground": "#C8D8E8",
      "bold": true
    },
    "struct": {
      "foreground": "#C8D8E8",
      "bold": true
    },
    "interface": {
      "foreground": "#C8D8E8",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C8D8E8",
      "bold": true
    },
    "enumMember": {
      "foreground": "#90A8B8",
      "bold": true
    },
    "type": {
      "foreground": "#C8D8E8"
    },
    "typeParameter": {
      "foreground": "#90A8B8",
      "italic": true
    },
    "variable": {
      "foreground": "#A8B8C8"
    },
    "variable.readonly": {
      "foreground": "#8070C0"
    },
    "property": {
      "foreground": "#3A7860"
    },
    "parameter": {
      "foreground": "#90A8B8",
      "italic": true
    },
    "keyword": {
      "foreground": "#D0EEF8"
    },
    "string": {
      "foreground": "#A8D8F0"
    },
    "number": {
      "foreground": "#90C8E0"
    },
    "comment": {
      "foreground": "#486C84",
      "italic": true
    },
    "decorator": {
      "foreground": "#8070C0"
    },
    "namespace": {
      "foreground": "#406880"
    },
    "macro": {
      "foreground": "#6898B0",
      "bold": true
    },
    "lifetime": {
      "foreground": "#C09040",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60D8E0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#28A878",
      "bold": true
    },
    "operator": {
      "foreground": "#D0EEF8"
    },
    "*.unsafe": {
      "foreground": "#D04040"
    }
  }
}