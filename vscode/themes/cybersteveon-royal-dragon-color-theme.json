{
  "name": "Royal Dragon",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0E0804",
    "editor.foreground": "#C4A882",
    "editorCursor.foreground": "#D4AF37",
    "editor.lineHighlightBackground": "#180E08",
    "editor.selectionBackground": "#534215CC",
    "editor.selectionHighlightBackground": "#53421566",
    "editor.inactiveSelectionBackground": "#53421588",
    "editor.findMatchBackground": "#D4AF3744",
    "editor.findMatchHighlightBackground": "#D4AF3722",
    "editor.findMatchBorder": "#D4AF37",
    "editor.wordHighlightBackground": "#53421566",
    "editor.wordHighlightStrongBackground": "#534215CC",
    "editorLineNumber.foreground": "#8E7560",
    "editorLineNumber.activeForeground": "#D4AF37",
    "editorWhitespace.foreground": "#8E7560",
    "editorIndentGuide.background1": "#201A16",
    "editorIndentGuide.activeBackground1": "#8E7560",
    "editorRuler.foreground": "#201A16",
    "editorBracketMatch.background": "#53421566",
    "editorBracketMatch.border": "#8A7055",
    "editorError.foreground": "#FF4500",
    "editorWarning.foreground": "#E25822",
    "editorInfo.foreground": "#C0392B",
    "editorHint.foreground": "#4A9E6B",
    "editorGutter.background": "#0E0804",
    "editorGutter.addedBackground": "#E8D5B0",
    "editorGutter.modifiedBackground": "#B87333",
    "editorGutter.deletedBackground": "#FF4500",
    "editorGroupHeader.tabsBackground": "#0A0400",
    "tab.activeBackground": "#0E0804",
    "tab.inactiveBackground": "#0A0400",
    "tab.activeForeground": "#C4A882",
    "tab.inactiveForeground": "#8E7560",
    "tab.activeBorderTop": "#D4AF37",
    "tab.border": "#201A16",
    "titleBar.activeBackground": "#0A0400",
    "titleBar.activeForeground": "#C4A882",
    "titleBar.inactiveBackground": "#0A0400",
    "titleBar.inactiveForeground": "#8E7560",
    "activityBar.background": "#18120E",
    "activityBar.foreground": "#C4A882",
    "activityBar.inactiveForeground": "#8E7560",
    "activityBar.border": "#201A16",
    "activityBarBadge.background": "#D4AF37",
    "activityBarBadge.foreground": "#0E0804",
    "sideBar.background": "#18120E",
    "sideBar.foreground": "#C4A882",
    "sideBar.border": "#201A16",
    "list.activeSelectionBackground": "#534215CC",
    "list.activeSelectionForeground": "#C4A882",
    "list.hoverBackground": "#180E08",
    "list.highlightForeground": "#D4AF37",
    "statusBar.background": "#0A0400",
    "statusBar.foreground": "#8E7560",
    "statusBar.border": "#201A16",
    "statusBarItem.remoteBackground": "#D4AF37",
    "statusBarItem.remoteForeground": "#0E0804",
    "panel.background": "#0E0804",
    "panel.border": "#201A16",
    "terminal.background": "#0E0804",
    "terminal.foreground": "#C4A882",
    "terminal.ansiBlack": "#0A0400",
    "terminal.ansiRed": "#FF4500",
    "terminal.ansiGreen": "#E8D5B0",
    "terminal.ansiYellow": "#B87333",
    "terminal.ansiBlue": "#C0392B",
    "terminal.ansiMagenta": "#D4AF37",
    "terminal.ansiCyan": "#4A9E6B",
    "terminal.ansiWhite": "#8E7560",
    "terminal.ansiBrightBlack": "#8E7560",
    "terminal.ansiBrightRed": "#FF4500",
    "terminal.ansiBrightGreen": "#E8D5B0",
    "terminal.ansiBrightYellow": "#D4AF37",
    "terminal.ansiBrightBlue": "#C0392B",
    "terminal.ansiBrightMagenta": "#B22F00",
    "terminal.ansiBrightCyan": "#D4AF37",
    "terminal.ansiBrightWhite": "#C4A882",
    "terminalCursor.foreground": "#D4AF37",
    "input.background": "#18120E",
    "input.foreground": "#C4A882",
    "input.border": "#201A16",
    "input.placeholderForeground": "#8E7560",
    "button.background": "#D4AF37",
    "button.foreground": "#0E0804",
    "badge.background": "#D4AF37",
    "badge.foreground": "#0E0804",
    "focusBorder": "#D4AF3766",
    "scrollbarSlider.background": "#8E756022",
    "scrollbarSlider.hoverBackground": "#8E756033",
    "gitDecoration.addedResourceForeground": "#E8D5B0",
    "gitDecoration.modifiedResourceForeground": "#B87333",
    "gitDecoration.deletedResourceForeground": "#FF4500",
    "gitDecoration.ignoredResourceForeground": "#8E7560",
    "diffEditor.insertedTextBackground": "#E8D5B018",
    "diffEditor.removedTextBackground": "#FF450018",
    "minimap.findMatchHighlight": "#D4AF37",
    "minimap.selectionHighlight": "#534215CC",
    "peekView.border": "#D4AF37",
    "peekViewEditor.background": "#18120E",
    "peekViewResult.background": "#0A0400",
    "breadcrumb.foreground": "#8E7560",
    "breadcrumb.focusForeground": "#C4A882",
    "editorWidget.background": "#18120E",
    "editorSuggestWidget.background": "#18120E",
    "editorSuggestWidget.selectedBackground": "#534215CC",
    "editorHoverWidget.background": "#18120E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#C4A882"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8E7560",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#E8D5B0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#C4A882"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D4AF37"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#4A9E6B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#C0392B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#E25822",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#E25822"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#B8972E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#B22F00"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#C4A882"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#E25822",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#B8972E"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#5B8FA8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D4AF37"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#B22F00"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D4AF37"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8E7560"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#8A7055"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C0392B"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B8972E"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF4500",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7C6010"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#B87333",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#C4A882",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#E25822",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#B8972E"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#B22F00"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C0392B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E25822",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E8D5B0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#4A9E6B"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#C0392B"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#C0392B",
      "bold": true
    },
    "method": {
      "foreground": "#C0392B",
      "bold": true
    },
    "class": {
      "foreground": "#E25822",
      "bold": true
    },
    "struct": {
      "foreground": "#E25822",
      "bold": true
    },
    "interface": {
      "foreground": "#E25822",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#E25822",
      "bold": true
    },
    "enumMember": {
      "foreground": "#B8972E",
      "bold": true
    },
    "type": {
      "foreground": "#E25822"
    },
    "typeParameter": {
      "foreground": "#E25822",
      "italic": true
    },
    "variable": {
      "foreground": "#C4A882"
    },
    "variable.readonly": {
      "foreground": "#B22F00"
    },
    "property": {
      "foreground": "#B8972E"
    },
    "parameter": {
      "foreground": "#E25822",
      "italic": true
    },
    "keyword": {
      "foreground": "#D4AF37"
    },
    "string": {
      "foreground": "#E8D5B0"
    },
    "number": {
      "foreground": "#D4AF37"
    },
    "comment": {
      "foreground": "#8E7560",
      "italic": true
    },
    "decorator": {
      "foreground": "#B22F00"
    },
    "namespace": {
      "foreground": "#B87333"
    },
    "macro": {
      "foreground": "#C4A882",
      "bold": true
    },
    "lifetime": {
      "foreground": "#B87333",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#5B8FA8",
      "italic": true
    },
    "builtinType": {
      "foreground": "#4A9E6B",
      "bold": true
    },
    "operator": {
      "foreground": "#D4AF37"
    },
    "*.unsafe": {
      "foreground": "#FF4500"
    }
  }
}