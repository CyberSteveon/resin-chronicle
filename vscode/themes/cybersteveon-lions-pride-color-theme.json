{
  "name": "Lion's Pride",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0C0804",
    "editor.foreground": "#A89060",
    "editorCursor.foreground": "#C8860A",
    "editor.lineHighlightBackground": "#161008",
    "editor.selectionBackground": "#4D3406CC",
    "editor.selectionHighlightBackground": "#4D340666",
    "editor.inactiveSelectionBackground": "#4D340688",
    "editor.findMatchBackground": "#D4A82044",
    "editor.findMatchHighlightBackground": "#D4A82022",
    "editor.findMatchBorder": "#D4A820",
    "editor.wordHighlightBackground": "#4D340666",
    "editor.wordHighlightStrongBackground": "#4D3406CC",
    "editorLineNumber.foreground": "#826136",
    "editorLineNumber.activeForeground": "#C8860A",
    "editorWhitespace.foreground": "#826136",
    "editorIndentGuide.background1": "#1E1A16",
    "editorIndentGuide.activeBackground1": "#826136",
    "editorRuler.foreground": "#1E1A16",
    "editorBracketMatch.background": "#4D340666",
    "editorBracketMatch.border": "#786040",
    "editorError.foreground": "#CC2200",
    "editorWarning.foreground": "#C4854A",
    "editorInfo.foreground": "#E8782A",
    "editorHint.foreground": "#6A8FC0",
    "editorGutter.background": "#0C0804",
    "editorGutter.addedBackground": "#D8C090",
    "editorGutter.modifiedBackground": "#D4901A",
    "editorGutter.deletedBackground": "#CC2200",
    "editorGroupHeader.tabsBackground": "#080400",
    "tab.activeBackground": "#0C0804",
    "tab.inactiveBackground": "#080400",
    "tab.activeForeground": "#A89060",
    "tab.inactiveForeground": "#826136",
    "tab.activeBorderTop": "#C8860A",
    "tab.border": "#1E1A16",
    "titleBar.activeBackground": "#080400",
    "titleBar.activeForeground": "#A89060",
    "titleBar.inactiveBackground": "#080400",
    "titleBar.inactiveForeground": "#826136",
    "activityBar.background": "#16120E",
    "activityBar.foreground": "#A89060",
    "activityBar.inactiveForeground": "#826136",
    "activityBar.border": "#1E1A16",
    "activityBarBadge.background": "#C8860A",
    "activityBarBadge.foreground": "#0C0804",
    "sideBar.background": "#16120E",
    "sideBar.foreground": "#A89060",
    "sideBar.border": "#1E1A16",
    "list.activeSelectionBackground": "#4D3406CC",
    "list.activeSelectionForeground": "#A89060",
    "list.hoverBackground": "#161008",
    "list.highlightForeground": "#C8860A",
    "statusBar.background": "#080400",
    "statusBar.foreground": "#826136",
    "statusBar.border": "#1E1A16",
    "statusBarItem.remoteBackground": "#C8860A",
    "statusBarItem.remoteForeground": "#0C0804",
    "panel.background": "#0C0804",
    "panel.border": "#1E1A16",
    "terminal.background": "#0C0804",
    "terminal.foreground": "#A89060",
    "terminal.ansiBlack": "#080400",
    "terminal.ansiRed": "#CC2200",
    "terminal.ansiGreen": "#D8C090",
    "terminal.ansiYellow": "#D4901A",
    "terminal.ansiBlue": "#E8782A",
    "terminal.ansiMagenta": "#C8860A",
    "terminal.ansiCyan": "#6A8FC0",
    "terminal.ansiWhite": "#826136",
    "terminal.ansiBrightBlack": "#826136",
    "terminal.ansiBrightRed": "#CC2200",
    "terminal.ansiBrightGreen": "#D8C090",
    "terminal.ansiBrightYellow": "#D4A820",
    "terminal.ansiBrightBlue": "#E8782A",
    "terminal.ansiBrightMagenta": "#B82222",
    "terminal.ansiBrightCyan": "#C8860A",
    "terminal.ansiBrightWhite": "#A89060",
    "terminalCursor.foreground": "#C8860A",
    "input.background": "#16120E",
    "input.foreground": "#A89060",
    "input.border": "#1E1A16",
    "input.placeholderForeground": "#826136",
    "button.background": "#C8860A",
    "button.foreground": "#0C0804",
    "badge.background": "#C8860A",
    "badge.foreground": "#0C0804",
    "focusBorder": "#C8860A66",
    "scrollbarSlider.background": "#82613622",
    "scrollbarSlider.hoverBackground": "#82613633",
    "gitDecoration.addedResourceForeground": "#D8C090",
    "gitDecoration.modifiedResourceForeground": "#D4901A",
    "gitDecoration.deletedResourceForeground": "#CC2200",
    "gitDecoration.ignoredResourceForeground": "#826136",
    "diffEditor.insertedTextBackground": "#D8C09018",
    "diffEditor.removedTextBackground": "#CC220018",
    "minimap.findMatchHighlight": "#D4A820",
    "minimap.selectionHighlight": "#4D3406CC",
    "peekView.border": "#C8860A",
    "peekViewEditor.background": "#16120E",
    "peekViewResult.background": "#080400",
    "breadcrumb.foreground": "#826136",
    "breadcrumb.focusForeground": "#A89060",
    "editorWidget.background": "#16120E",
    "editorSuggestWidget.background": "#16120E",
    "editorSuggestWidget.selectedBackground": "#4D3406CC",
    "editorHoverWidget.background": "#16120E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A89060"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#826136",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D8C090"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D4901A"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#D4901A"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#A89060"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C8860A"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#6A8FC0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#E8782A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C4854A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C4854A"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#A06830",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#B82222"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A89060"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C4854A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#5A8040"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#8090A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D4A820"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#B82222"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C8860A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#826136"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#786040"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#B8722A"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#E8782A"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A06830"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#CC2200",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#906818"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#D4901A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#A89060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C4854A",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#A06830"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#B82222"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E8782A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C4854A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D8C090"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#6A8FC0"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#E8782A"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#E8782A",
      "bold": true
    },
    "method": {
      "foreground": "#E8782A",
      "bold": true
    },
    "class": {
      "foreground": "#C4854A",
      "bold": true
    },
    "struct": {
      "foreground": "#C4854A",
      "bold": true
    },
    "interface": {
      "foreground": "#C4854A",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C4854A",
      "bold": true
    },
    "enumMember": {
      "foreground": "#A06830",
      "bold": true
    },
    "type": {
      "foreground": "#C4854A"
    },
    "typeParameter": {
      "foreground": "#C4854A",
      "italic": true
    },
    "variable": {
      "foreground": "#A89060"
    },
    "variable.readonly": {
      "foreground": "#B82222"
    },
    "property": {
      "foreground": "#5A8040"
    },
    "parameter": {
      "foreground": "#C4854A",
      "italic": true
    },
    "keyword": {
      "foreground": "#C8860A"
    },
    "string": {
      "foreground": "#D8C090"
    },
    "number": {
      "foreground": "#D4A820"
    },
    "comment": {
      "foreground": "#826136",
      "italic": true
    },
    "decorator": {
      "foreground": "#B82222"
    },
    "namespace": {
      "foreground": "#B8722A"
    },
    "macro": {
      "foreground": "#A89060",
      "bold": true
    },
    "lifetime": {
      "foreground": "#D4901A",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#8090A0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#6A8FC0",
      "bold": true
    },
    "operator": {
      "foreground": "#C8860A"
    },
    "*.unsafe": {
      "foreground": "#CC2200"
    }
  }
}