{
  "name": "Lifestream",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#04080A",
    "editor.foreground": "#80C0A0",
    "editorCursor.foreground": "#40E0A0",
    "editor.lineHighlightBackground": "#081410",
    "editor.selectionBackground": "#19533ECC",
    "editor.selectionHighlightBackground": "#19533E66",
    "editor.inactiveSelectionBackground": "#19533E88",
    "editor.findMatchBackground": "#A0FFD044",
    "editor.findMatchHighlightBackground": "#A0FFD022",
    "editor.findMatchBorder": "#A0FFD0",
    "editor.wordHighlightBackground": "#19533E66",
    "editor.wordHighlightStrongBackground": "#19533ECC",
    "editorLineNumber.foreground": "#407160",
    "editorLineNumber.activeForeground": "#40E0A0",
    "editorWhitespace.foreground": "#407160",
    "editorIndentGuide.background1": "#161A1C",
    "editorIndentGuide.activeBackground1": "#407160",
    "editorRuler.foreground": "#161A1C",
    "editorBracketMatch.background": "#19533E66",
    "editorBracketMatch.border": "#446655",
    "editorError.foreground": "#C04060",
    "editorWarning.foreground": "#806AB0",
    "editorInfo.foreground": "#40E0A0",
    "editorHint.foreground": "#28A870",
    "editorGutter.background": "#04080A",
    "editorGutter.addedBackground": "#60D8B0",
    "editorGutter.modifiedBackground": "#974354",
    "editorGutter.deletedBackground": "#C04060",
    "editorGroupHeader.tabsBackground": "#000406",
    "tab.activeBackground": "#04080A",
    "tab.inactiveBackground": "#000406",
    "tab.activeForeground": "#80C0A0",
    "tab.inactiveForeground": "#407160",
    "tab.activeBorderTop": "#40E0A0",
    "tab.border": "#161A1C",
    "titleBar.activeBackground": "#000406",
    "titleBar.activeForeground": "#80C0A0",
    "titleBar.inactiveBackground": "#000406",
    "titleBar.inactiveForeground": "#407160",
    "activityBar.background": "#0E1214",
    "activityBar.foreground": "#80C0A0",
    "activityBar.inactiveForeground": "#407160",
    "activityBar.border": "#161A1C",
    "activityBarBadge.background": "#40E0A0",
    "activityBarBadge.foreground": "#04080A",
    "sideBar.background": "#0E1214",
    "sideBar.foreground": "#80C0A0",
    "sideBar.border": "#161A1C",
    "list.activeSelectionBackground": "#19533ECC",
    "list.activeSelectionForeground": "#80C0A0",
    "list.hoverBackground": "#081410",
    "list.highlightForeground": "#40E0A0",
    "statusBar.background": "#000406",
    "statusBar.foreground": "#407160",
    "statusBar.border": "#161A1C",
    "statusBarItem.remoteBackground": "#40E0A0",
    "statusBarItem.remoteForeground": "#04080A",
    "panel.background": "#04080A",
    "panel.border": "#161A1C",
    "terminal.background": "#04080A",
    "terminal.foreground": "#80C0A0",
    "terminal.ansiBlack": "#000406",
    "terminal.ansiRed": "#C04060",
    "terminal.ansiGreen": "#60D8B0",
    "terminal.ansiYellow": "#974354",
    "terminal.ansiBlue": "#40E0A0",
    "terminal.ansiMagenta": "#60D8B0",
    "terminal.ansiCyan": "#28A870",
    "terminal.ansiWhite": "#407160",
    "terminal.ansiBrightBlack": "#407160",
    "terminal.ansiBrightRed": "#C04060",
    "terminal.ansiBrightGreen": "#60D8B0",
    "terminal.ansiBrightYellow": "#A0FFD0",
    "terminal.ansiBrightBlue": "#40E0A0",
    "terminal.ansiBrightMagenta": "#FF90B0",
    "terminal.ansiBrightCyan": "#40E0A0",
    "terminal.ansiBrightWhite": "#80C0A0",
    "terminalCursor.foreground": "#40E0A0",
    "input.background": "#0E1214",
    "input.foreground": "#80C0A0",
    "input.border": "#161A1C",
    "input.placeholderForeground": "#407160",
    "button.background": "#40E0A0",
    "button.foreground": "#04080A",
    "badge.background": "#40E0A0",
    "badge.foreground": "#04080A",
    "focusBorder": "#40E0A066",
    "scrollbarSlider.background": "#40716022",
    "scrollbarSlider.hoverBackground": "#40716033",
    "gitDecoration.addedResourceForeground": "#60D8B0",
    "gitDecoration.modifiedResourceForeground": "#974354",
    "gitDecoration.deletedResourceForeground": "#C04060",
    "gitDecoration.ignoredResourceForeground": "#407160",
    "diffEditor.insertedTextBackground": "#60D8B018",
    "diffEditor.removedTextBackground": "#C0406018",
    "minimap.findMatchHighlight": "#A0FFD0",
    "minimap.selectionHighlight": "#19533ECC",
    "peekView.border": "#40E0A0",
    "peekViewEditor.background": "#0E1214",
    "peekViewResult.background": "#000406",
    "breadcrumb.foreground": "#407160",
    "breadcrumb.focusForeground": "#80C0A0",
    "editorWidget.background": "#0E1214",
    "editorSuggestWidget.background": "#0E1214",
    "editorSuggestWidget.selectedBackground": "#19533ECC",
    "editorHoverWidget.background": "#0E1214"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#407160",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#974354"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#974354"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#446655"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#28A870",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#40E0A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#B090E0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#806AB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#806AB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#408060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60A8E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#A0FFD0"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#407160"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#446655"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#20764E"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#40E0A0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#806AB0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C04060",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#2D725B"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#974354",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#446655",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#806AB0"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#40E0A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#28A870"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#40E0A0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "method": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "class": {
      "foreground": "#B090E0",
      "bold": true
    },
    "struct": {
      "foreground": "#B090E0",
      "bold": true
    },
    "interface": {
      "foreground": "#B090E0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#B090E0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#806AB0",
      "bold": true
    },
    "type": {
      "foreground": "#B090E0"
    },
    "typeParameter": {
      "foreground": "#806AB0",
      "italic": true
    },
    "variable": {
      "foreground": "#80C0A0"
    },
    "variable.readonly": {
      "foreground": "#FF90B0"
    },
    "property": {
      "foreground": "#408060"
    },
    "parameter": {
      "foreground": "#806AB0",
      "italic": true
    },
    "keyword": {
      "foreground": "#60D8B0"
    },
    "string": {
      "foreground": "#60D8B0"
    },
    "number": {
      "foreground": "#A0FFD0"
    },
    "comment": {
      "foreground": "#407160",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF90B0"
    },
    "namespace": {
      "foreground": "#20764E"
    },
    "macro": {
      "foreground": "#446655",
      "bold": true
    },
    "lifetime": {
      "foreground": "#974354",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60A8E0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#28A870",
      "bold": true
    },
    "operator": {
      "foreground": "#60D8B0"
    },
    "*.unsafe": {
      "foreground": "#C04060"
    }
  }
}