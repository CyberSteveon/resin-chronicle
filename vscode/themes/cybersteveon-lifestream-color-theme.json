  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#203830",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#904050"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#904050"
      }
    },
    {
      "name": "Template / f-string interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression",
        "meta.embedded.expression",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#406050"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#28A870",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#40E0A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type.instance"
      ],
      "settings": {
        "foreground": "#806AB0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum",
        "meta.enum"
      ],
      "settings": {
        "foreground": "#806AB0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#80C0A0"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#806AB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Struct fields / property access",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "meta.path variable.other"
      ],
      "settings": {
        "foreground": "#408060"
      }
    },
    {
      "name": "Self / this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60A8E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#A0FFD0"
      }
    },
    {
      "name": "Constants and booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language.special"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.brackets"
      ],
      "settings": {
        "foreground": "#203830"
      }
    },
    {
      "name": "Namespace / path separators",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace",
        "meta.path punctuation"
      ],
      "settings": {
        "foreground": "#406050"
      }
    },
    {
      "name": "Import / module names",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#1A6040"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#40E0A0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#806AB0"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C04060",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility modifiers (pub / private)",
      "scope": [
        "storage.modifier.visibility",
        "keyword.other.rust",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#205040"
      }
    },
    {
      "name": "Rust — lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": {
        "foreground": "#904050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust — macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust",
        "meta.macro.rust"
      ],
      "settings": {
        "foreground": "#406050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust — traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust — enum variants (path)",
      "scope": [
        "entity.name.enum.rust",
        "meta.path.rust entity.name.type.rust"
      ],
      "settings": {
        "foreground": "#806AB0"
      }
    },
    {
      "name": "Rust — derive attributes",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#FF90B0"
      }
    },
    {
      "name": "PowerShell cmdlets",
      "scope": [
        "support.function.powershell",
        "entity.name.function.powershell"
      ],
      "settings": {
        "foreground": "#40E0A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PowerShell variables",
      "scope": [
        "variable.other.readwrite.powershell"
      ],
      "settings": {
        "foreground": "#60A8E0"
      }
    },
    {
      "name": "PowerShell parameters",
      "scope": [
        "variable.parameter.powershell"
      ],
      "settings": {
        "foreground": "#806AB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#40E0A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#B090E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#203830",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#60D8B0"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#28A870"
      }
    },
    {
      "name": "JSON / TOML / YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "string.quoted.double.json meta.structure.dictionary.key.json",
        "keyword.key.toml",
        "support.type.property-name.toml",
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#40E0A0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "function.declaration": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "method": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "method.declaration": {
      "foreground": "#40E0A0",
      "bold": true
    },
    "class": {
      "foreground": "#B090E0",
      "bold": true
    },
    "class.declaration": {
      "foreground": "#B090E0",
      "bold": true
    },
    "struct": {
      "foreground": "#B090E0",
      "bold": true
    },
    "struct.declaration": {
      "foreground": "#B090E0",
      "bold": true
    },
    "interface": {
      "foreground": "#B090E0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#B090E0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#806AB0",
      "bold": true
    },
    "type": {
      "foreground": "#806AB0"
    },
    "typeParameter": {
      "foreground": "#806AB0",
      "italic": true
    },
    "variable": {
      "foreground": "#80C0A0"
    },
    "variable.readonly": {
      "foreground": "#FF90B0"
    },
    "property": {
      "foreground": "#408060"
    },
    "parameter": {
      "foreground": "#806AB0",
      "italic": true
    },
    "keyword": {
      "foreground": "#60D8B0"
    },
    "modifier": {
      "foreground": "#60D8B0"
    },
    "string": {
      "foreground": "#60D8B0"
    },
    "number": {
      "foreground": "#A0FFD0"
    },
    "comment": {
      "foreground": "#203830",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF90B0"
    },
    "namespace": {
      "foreground": "#1A6040"
    },
    "macro": {
      "foreground": "#406050",
      "bold": true
    },
    "lifetime": {
      "foreground": "#904050",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60A8E0",
      "italic": true
    },
    "selfParameter": {
      "foreground": "#60A8E0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#28A870",
      "bold": true
    },
    "operator": {
      "foreground": "#60D8B0"
    },
    "*.mutable": {
      "underline": true
    },
    "*.unsafe": {
      "foreground": "#C04060"
    }
  }
}