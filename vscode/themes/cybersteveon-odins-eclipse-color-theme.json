{
  "name": "Odin's Eclipse",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080608",
    "editor.foreground": "#807090",
    "editorCursor.foreground": "#C0C0D8",
    "editor.lineHighlightBackground": "#100C10",
    "editor.selectionBackground": "#C0C0D844",
    "editor.selectionHighlightBackground": "#C0C0D822",
    "editor.inactiveSelectionBackground": "#C0C0D822",
    "editor.findMatchBackground": "#E0A03044",
    "editor.findMatchHighlightBackground": "#E0A03022",
    "editor.findMatchBorder": "#E0A030",
    "editor.wordHighlightBackground": "#C0C0D822",
    "editor.wordHighlightStrongBackground": "#C0C0D844",
    "editorLineNumber.foreground": "#8B538B",
    "editorLineNumber.activeForeground": "#C0C0D8",
    "editorWhitespace.foreground": "#8B538B",
    "editorIndentGuide.background1": "#1A181A",
    "editorIndentGuide.activeBackground1": "#8B538B",
    "editorRuler.foreground": "#1A181A",
    "editorBracketMatch.background": "#C0C0D822",
    "editorBracketMatch.border": "#64597B",
    "editorError.foreground": "#C03050",
    "editorWarning.foreground": "#B07810",
    "editorInfo.foreground": "#C0C0D8",
    "editorHint.foreground": "#9090A8",
    "editorGutter.background": "#080608",
    "editorGutter.addedBackground": "#9080A0",
    "editorGutter.modifiedBackground": "#706080",
    "editorGutter.deletedBackground": "#C03050",
    "editorGroupHeader.tabsBackground": "#040204",
    "tab.activeBackground": "#080608",
    "tab.inactiveBackground": "#040204",
    "tab.activeForeground": "#807090",
    "tab.inactiveForeground": "#8B538B",
    "tab.activeBorderTop": "#C0C0D8",
    "tab.border": "#1A181A",
    "titleBar.activeBackground": "#040204",
    "titleBar.activeForeground": "#807090",
    "titleBar.inactiveBackground": "#040204",
    "titleBar.inactiveForeground": "#8B538B",
    "activityBar.background": "#121012",
    "activityBar.foreground": "#807090",
    "activityBar.inactiveForeground": "#8B538B",
    "activityBar.border": "#1A181A",
    "activityBarBadge.background": "#C0C0D8",
    "activityBarBadge.foreground": "#080608",
    "sideBar.background": "#121012",
    "sideBar.foreground": "#807090",
    "sideBar.border": "#1A181A",
    "list.activeSelectionBackground": "#C0C0D844",
    "list.activeSelectionForeground": "#807090",
    "list.hoverBackground": "#100C10",
    "list.highlightForeground": "#C0C0D8",
    "statusBar.background": "#040204",
    "statusBar.foreground": "#8B538B",
    "statusBar.border": "#1A181A",
    "statusBarItem.remoteBackground": "#C0C0D8",
    "statusBarItem.remoteForeground": "#080608",
    "panel.background": "#080608",
    "panel.border": "#1A181A",
    "terminal.background": "#080608",
    "terminal.foreground": "#807090",
    "terminal.ansiBlack": "#040204",
    "terminal.ansiRed": "#C03050",
    "terminal.ansiGreen": "#9080A0",
    "terminal.ansiYellow": "#706080",
    "terminal.ansiBlue": "#C0C0D8",
    "terminal.ansiMagenta": "#7552BA",
    "terminal.ansiCyan": "#9090A8",
    "terminal.ansiWhite": "#8B538B",
    "terminal.ansiBrightBlack": "#8B538B",
    "terminal.ansiBrightRed": "#C03050",
    "terminal.ansiBrightGreen": "#9080A0",
    "terminal.ansiBrightYellow": "#D0C060",
    "terminal.ansiBrightBlue": "#C0C0D8",
    "terminal.ansiBrightMagenta": "#C060D0",
    "terminal.ansiBrightCyan": "#C0C0D8",
    "terminal.ansiBrightWhite": "#807090",
    "terminalCursor.foreground": "#C0C0D8",
    "input.background": "#121012",
    "input.foreground": "#807090",
    "input.border": "#1A181A",
    "input.placeholderForeground": "#8B538B",
    "button.background": "#C0C0D8",
    "button.foreground": "#080608",
    "badge.background": "#C0C0D8",
    "badge.foreground": "#080608",
    "focusBorder": "#C0C0D866",
    "scrollbarSlider.background": "#8B538B22",
    "scrollbarSlider.hoverBackground": "#8B538B33",
    "gitDecoration.addedResourceForeground": "#9080A0",
    "gitDecoration.modifiedResourceForeground": "#706080",
    "gitDecoration.deletedResourceForeground": "#C03050",
    "gitDecoration.ignoredResourceForeground": "#8B538B",
    "diffEditor.insertedTextBackground": "#9080A018",
    "diffEditor.removedTextBackground": "#C0305018",
    "minimap.findMatchHighlight": "#E0A030",
    "minimap.selectionHighlight": "#C0C0D844",
    "peekView.border": "#C0C0D8",
    "peekViewEditor.background": "#121012",
    "peekViewResult.background": "#040204",
    "breadcrumb.foreground": "#8B538B",
    "breadcrumb.focusForeground": "#807090",
    "editorWidget.background": "#121012",
    "editorSuggestWidget.background": "#121012",
    "editorSuggestWidget.selectedBackground": "#C0C0D844",
    "editorHoverWidget.background": "#121012"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#807090"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8B538B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9080A0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#706080"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#706080"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#6A5580"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7552BA"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#9090A8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#C0C0D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#E0A030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#E0A030"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#B07810",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#C060D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#807090"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B07810",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#507060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#8090C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#D0C060"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#C060D0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#7552BA"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8B538B"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#64597B"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#695E9E"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C0C0D8"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B07810"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7D5796"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#706080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#6A5580",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#E0A030",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#B07810"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#C060D0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C0C0D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E0A030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#9080A0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#9090A8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#C0C0D8"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#C0C0D8",
      "bold": true
    },
    "method": {
      "foreground": "#C0C0D8",
      "bold": true
    },
    "class": {
      "foreground": "#E0A030",
      "bold": true
    },
    "struct": {
      "foreground": "#E0A030",
      "bold": true
    },
    "interface": {
      "foreground": "#E0A030",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#E0A030",
      "bold": true
    },
    "enumMember": {
      "foreground": "#B07810",
      "bold": true
    },
    "type": {
      "foreground": "#E0A030"
    },
    "typeParameter": {
      "foreground": "#B07810",
      "italic": true
    },
    "variable": {
      "foreground": "#807090"
    },
    "variable.readonly": {
      "foreground": "#C060D0"
    },
    "property": {
      "foreground": "#507060"
    },
    "parameter": {
      "foreground": "#B07810",
      "italic": true
    },
    "keyword": {
      "foreground": "#7552BA"
    },
    "string": {
      "foreground": "#9080A0"
    },
    "number": {
      "foreground": "#D0C060"
    },
    "comment": {
      "foreground": "#8B538B",
      "italic": true
    },
    "decorator": {
      "foreground": "#C060D0"
    },
    "namespace": {
      "foreground": "#695E9E"
    },
    "macro": {
      "foreground": "#6A5580",
      "bold": true
    },
    "lifetime": {
      "foreground": "#706080",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#8090C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#9090A8",
      "bold": true
    },
    "operator": {
      "foreground": "#7552BA"
    },
    "*.unsafe": {
      "foreground": "#C03050"
    }
  }
}