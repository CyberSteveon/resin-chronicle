{
  "name": "Neon Resin Deep",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#070B14",
    "editor.foreground": "#A8DDE0",
    "editorCursor.foreground": "#60F0FF",
    "editor.lineHighlightBackground": "#0C1220",
    "editor.selectionBackground": "#60F0FF44",
    "editor.selectionHighlightBackground": "#60F0FF22",
    "editor.inactiveSelectionBackground": "#60F0FF22",
    "editor.findMatchBackground": "#BBFF0044",
    "editor.findMatchHighlightBackground": "#BBFF0022",
    "editor.findMatchBorder": "#BBFF00",
    "editor.wordHighlightBackground": "#60F0FF22",
    "editor.wordHighlightStrongBackground": "#60F0FF44",
    "editorLineNumber.foreground": "#5D6982",
    "editorLineNumber.activeForeground": "#60F0FF",
    "editorWhitespace.foreground": "#5D6982",
    "editorIndentGuide.background1": "#191D26",
    "editorIndentGuide.activeBackground1": "#5D6982",
    "editorRuler.foreground": "#191D26",
    "editorBracketMatch.background": "#60F0FF22",
    "editorBracketMatch.border": "#6A9FB5",
    "editorError.foreground": "#FF4455",
    "editorWarning.foreground": "#FF9240",
    "editorInfo.foreground": "#60F0FF",
    "editorHint.foreground": "#00E8C8",
    "editorGutter.background": "#070B14",
    "editorGutter.addedBackground": "#88F040",
    "editorGutter.modifiedBackground": "#BBFF00",
    "editorGutter.deletedBackground": "#FF4455",
    "editorGroupHeader.tabsBackground": "#030710",
    "tab.activeBackground": "#070B14",
    "tab.inactiveBackground": "#030710",
    "tab.activeForeground": "#A8DDE0",
    "tab.inactiveForeground": "#5D6982",
    "tab.activeBorderTop": "#60F0FF",
    "tab.border": "#191D26",
    "titleBar.activeBackground": "#030710",
    "titleBar.activeForeground": "#A8DDE0",
    "titleBar.inactiveBackground": "#030710",
    "titleBar.inactiveForeground": "#5D6982",
    "activityBar.background": "#11151E",
    "activityBar.foreground": "#A8DDE0",
    "activityBar.inactiveForeground": "#5D6982",
    "activityBar.border": "#191D26",
    "activityBarBadge.background": "#60F0FF",
    "activityBarBadge.foreground": "#070B14",
    "sideBar.background": "#11151E",
    "sideBar.foreground": "#A8DDE0",
    "sideBar.border": "#191D26",
    "list.activeSelectionBackground": "#60F0FF44",
    "list.activeSelectionForeground": "#A8DDE0",
    "list.hoverBackground": "#0C1220",
    "list.highlightForeground": "#60F0FF",
    "statusBar.background": "#030710",
    "statusBar.foreground": "#5D6982",
    "statusBar.border": "#191D26",
    "statusBarItem.remoteBackground": "#60F0FF",
    "statusBarItem.remoteForeground": "#070B14",
    "panel.background": "#070B14",
    "panel.border": "#191D26",
    "terminal.background": "#070B14",
    "terminal.foreground": "#A8DDE0",
    "terminal.ansiBlack": "#030710",
    "terminal.ansiRed": "#FF4455",
    "terminal.ansiGreen": "#88F040",
    "terminal.ansiYellow": "#BBFF00",
    "terminal.ansiBlue": "#60F0FF",
    "terminal.ansiMagenta": "#FF1A6E",
    "terminal.ansiCyan": "#00E8C8",
    "terminal.ansiWhite": "#5D6982",
    "terminal.ansiBrightBlack": "#5D6982",
    "terminal.ansiBrightRed": "#FF4455",
    "terminal.ansiBrightGreen": "#88F040",
    "terminal.ansiBrightYellow": "#BBFF00",
    "terminal.ansiBrightBlue": "#60F0FF",
    "terminal.ansiBrightMagenta": "#FF1A6E",
    "terminal.ansiBrightCyan": "#60F0FF",
    "terminal.ansiBrightWhite": "#A8DDE0",
    "terminalCursor.foreground": "#60F0FF",
    "input.background": "#11151E",
    "input.foreground": "#A8DDE0",
    "input.border": "#191D26",
    "input.placeholderForeground": "#5D6982",
    "button.background": "#60F0FF",
    "button.foreground": "#070B14",
    "badge.background": "#60F0FF",
    "badge.foreground": "#070B14",
    "focusBorder": "#60F0FF66",
    "scrollbarSlider.background": "#5D698222",
    "scrollbarSlider.hoverBackground": "#5D698233",
    "gitDecoration.addedResourceForeground": "#88F040",
    "gitDecoration.modifiedResourceForeground": "#BBFF00",
    "gitDecoration.deletedResourceForeground": "#FF4455",
    "gitDecoration.ignoredResourceForeground": "#5D6982",
    "diffEditor.insertedTextBackground": "#88F04018",
    "diffEditor.removedTextBackground": "#FF445518",
    "minimap.findMatchHighlight": "#BBFF00",
    "minimap.selectionHighlight": "#60F0FF44",
    "peekView.border": "#60F0FF",
    "peekViewEditor.background": "#11151E",
    "peekViewResult.background": "#030710",
    "breadcrumb.foreground": "#5D6982",
    "breadcrumb.focusForeground": "#A8DDE0",
    "editorWidget.background": "#11151E",
    "editorSuggestWidget.background": "#11151E",
    "editorSuggestWidget.selectedBackground": "#60F0FF44",
    "editorHoverWidget.background": "#11151E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A8DDE0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5D6982",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#88F040"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#BBFF00"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#BBFF00"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#A0E8F8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF1A6E"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#00E8C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#60F0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FF6D00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF6D00"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#FF9240",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#FF1A6E"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A8DDE0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FF9240",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#7ECFB3"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#B8D4FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#BBFF00"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#FF1A6E"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#FF1A6E"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#5D6982"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#6A9FB5"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#60F0FF"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#60F0FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FF9240"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF4455",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#FF9B45"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#BBFF00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#A0E8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#FF6D00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#FF9240"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#FF1A6E"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#60F0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF6D00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#88F040"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#00E8C8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#60F0FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#60F0FF",
      "bold": true
    },
    "method": {
      "foreground": "#60F0FF",
      "bold": true
    },
    "class": {
      "foreground": "#FF6D00",
      "bold": true
    },
    "struct": {
      "foreground": "#FF6D00",
      "bold": true
    },
    "interface": {
      "foreground": "#FF6D00",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#FF6D00",
      "bold": true
    },
    "enumMember": {
      "foreground": "#FF9240",
      "bold": true
    },
    "type": {
      "foreground": "#FF6D00"
    },
    "typeParameter": {
      "foreground": "#FF9240",
      "italic": true
    },
    "variable": {
      "foreground": "#A8DDE0"
    },
    "variable.readonly": {
      "foreground": "#FF1A6E"
    },
    "property": {
      "foreground": "#7ECFB3"
    },
    "parameter": {
      "foreground": "#FF9240",
      "italic": true
    },
    "keyword": {
      "foreground": "#FF1A6E"
    },
    "string": {
      "foreground": "#88F040"
    },
    "number": {
      "foreground": "#BBFF00"
    },
    "comment": {
      "foreground": "#5D6982",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF1A6E"
    },
    "namespace": {
      "foreground": "#60F0FF"
    },
    "macro": {
      "foreground": "#A0E8F8",
      "bold": true
    },
    "lifetime": {
      "foreground": "#BBFF00",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#B8D4FF",
      "italic": true
    },
    "builtinType": {
      "foreground": "#00E8C8",
      "bold": true
    },
    "operator": {
      "foreground": "#FF1A6E"
    },
    "*.unsafe": {
      "foreground": "#FF4455"
    }
  }
}