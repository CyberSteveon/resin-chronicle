{
  "name": "Ul'dah Sands",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0E0A04",
    "editor.foreground": "#B09878",
    "editorCursor.foreground": "#D4900A",
    "editor.lineHighlightBackground": "#1A1208",
    "editor.selectionBackground": "#533806CC",
    "editor.selectionHighlightBackground": "#53380666",
    "editor.inactiveSelectionBackground": "#53380688",
    "editor.findMatchBackground": "#E8B03044",
    "editor.findMatchHighlightBackground": "#E8B03022",
    "editor.findMatchBorder": "#E8B030",
    "editor.wordHighlightBackground": "#53380666",
    "editor.wordHighlightStrongBackground": "#533806CC",
    "editorLineNumber.foreground": "#9A582C",
    "editorLineNumber.activeForeground": "#D4900A",
    "editorWhitespace.foreground": "#9A582C",
    "editorIndentGuide.background1": "#201C16",
    "editorIndentGuide.activeBackground1": "#9A582C",
    "editorRuler.foreground": "#201C16",
    "editorBracketMatch.background": "#53380666",
    "editorBracketMatch.border": "#706048",
    "editorError.foreground": "#C02820",
    "editorWarning.foreground": "#906020",
    "editorInfo.foreground": "#C04030",
    "editorHint.foreground": "#B03027",
    "editorGutter.background": "#0E0A04",
    "editorGutter.addedBackground": "#D0B878",
    "editorGutter.modifiedBackground": "#907050",
    "editorGutter.deletedBackground": "#C02820",
    "editorGroupHeader.tabsBackground": "#0A0600",
    "tab.activeBackground": "#0E0A04",
    "tab.inactiveBackground": "#0A0600",
    "tab.activeForeground": "#B09878",
    "tab.inactiveForeground": "#9A582C",
    "tab.activeBorderTop": "#D4900A",
    "tab.border": "#201C16",
    "titleBar.activeBackground": "#0A0600",
    "titleBar.activeForeground": "#B09878",
    "titleBar.inactiveBackground": "#0A0600",
    "titleBar.inactiveForeground": "#9A582C",
    "activityBar.background": "#18140E",
    "activityBar.foreground": "#B09878",
    "activityBar.inactiveForeground": "#9A582C",
    "activityBar.border": "#201C16",
    "activityBarBadge.background": "#D4900A",
    "activityBarBadge.foreground": "#0E0A04",
    "sideBar.background": "#18140E",
    "sideBar.foreground": "#B09878",
    "sideBar.border": "#201C16",
    "list.activeSelectionBackground": "#533806CC",
    "list.activeSelectionForeground": "#B09878",
    "list.hoverBackground": "#1A1208",
    "list.highlightForeground": "#D4900A",
    "statusBar.background": "#0A0600",
    "statusBar.foreground": "#9A582C",
    "statusBar.border": "#201C16",
    "statusBarItem.remoteBackground": "#D4900A",
    "statusBarItem.remoteForeground": "#0E0A04",
    "panel.background": "#0E0A04",
    "panel.border": "#201C16",
    "terminal.background": "#0E0A04",
    "terminal.foreground": "#B09878",
    "terminal.ansiBlack": "#0A0600",
    "terminal.ansiRed": "#C02820",
    "terminal.ansiGreen": "#D0B878",
    "terminal.ansiYellow": "#907050",
    "terminal.ansiBlue": "#C04030",
    "terminal.ansiMagenta": "#D4900A",
    "terminal.ansiCyan": "#B03027",
    "terminal.ansiWhite": "#9A582C",
    "terminal.ansiBrightBlack": "#9A582C",
    "terminal.ansiBrightRed": "#C02820",
    "terminal.ansiBrightGreen": "#D0B878",
    "terminal.ansiBrightYellow": "#E8B030",
    "terminal.ansiBrightBlue": "#C04030",
    "terminal.ansiBrightMagenta": "#D050A0",
    "terminal.ansiBrightCyan": "#D4900A",
    "terminal.ansiBrightWhite": "#B09878",
    "terminalCursor.foreground": "#D4900A",
    "input.background": "#18140E",
    "input.foreground": "#B09878",
    "input.border": "#201C16",
    "input.placeholderForeground": "#9A582C",
    "button.background": "#D4900A",
    "button.foreground": "#0E0A04",
    "badge.background": "#D4900A",
    "badge.foreground": "#0E0A04",
    "focusBorder": "#D4900A66",
    "scrollbarSlider.background": "#9A582C22",
    "scrollbarSlider.hoverBackground": "#9A582C33",
    "gitDecoration.addedResourceForeground": "#D0B878",
    "gitDecoration.modifiedResourceForeground": "#907050",
    "gitDecoration.deletedResourceForeground": "#C02820",
    "gitDecoration.ignoredResourceForeground": "#9A582C",
    "diffEditor.insertedTextBackground": "#D0B87818",
    "diffEditor.removedTextBackground": "#C0282018",
    "minimap.findMatchHighlight": "#E8B030",
    "minimap.selectionHighlight": "#533806CC",
    "peekView.border": "#D4900A",
    "peekViewEditor.background": "#18140E",
    "peekViewResult.background": "#0A0600",
    "breadcrumb.foreground": "#9A582C",
    "breadcrumb.focusForeground": "#B09878",
    "editorWidget.background": "#18140E",
    "editorSuggestWidget.background": "#18140E",
    "editorSuggestWidget.selectedBackground": "#533806CC",
    "editorHoverWidget.background": "#18140E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#B09878"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9A582C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D0B878"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#907848"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D4900A"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#B03027",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#C04030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C07030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C07030"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#A86A00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D050A0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#B09878"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#906020",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#608050"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#3A5CB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E8B030"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D050A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D4900A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#9A582C"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#706048"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806030"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C04030"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A86A00"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C02820",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#975A1E"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#907050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#907848",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C07030",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#A86A00"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D050A0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#C04030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C07030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D0B878"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#B03027"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#C04030"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#C04030",
      "bold": true
    },
    "method": {
      "foreground": "#C04030",
      "bold": true
    },
    "class": {
      "foreground": "#C07030",
      "bold": true
    },
    "struct": {
      "foreground": "#C07030",
      "bold": true
    },
    "interface": {
      "foreground": "#C07030",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C07030",
      "bold": true
    },
    "enumMember": {
      "foreground": "#A86A00",
      "bold": true
    },
    "type": {
      "foreground": "#C07030"
    },
    "typeParameter": {
      "foreground": "#906020",
      "italic": true
    },
    "variable": {
      "foreground": "#B09878"
    },
    "variable.readonly": {
      "foreground": "#D050A0"
    },
    "property": {
      "foreground": "#608050"
    },
    "parameter": {
      "foreground": "#906020",
      "italic": true
    },
    "keyword": {
      "foreground": "#D4900A"
    },
    "string": {
      "foreground": "#D0B878"
    },
    "number": {
      "foreground": "#E8B030"
    },
    "comment": {
      "foreground": "#9A582C",
      "italic": true
    },
    "decorator": {
      "foreground": "#D050A0"
    },
    "namespace": {
      "foreground": "#806030"
    },
    "macro": {
      "foreground": "#907848",
      "bold": true
    },
    "lifetime": {
      "foreground": "#907050",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#3A5CB0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#B03027",
      "bold": true
    },
    "operator": {
      "foreground": "#D4900A"
    },
    "*.unsafe": {
      "foreground": "#C02820"
    }
  }
}