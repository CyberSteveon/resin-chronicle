{
  "name": "Carbuncle",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080608",
    "editor.foreground": "#A090B8",
    "editorCursor.foreground": "#E04060",
    "editor.lineHighlightBackground": "#100C10",
    "editor.selectionBackground": "#E0406044",
    "editor.selectionHighlightBackground": "#E0406022",
    "editor.inactiveSelectionBackground": "#E0406022",
    "editor.findMatchBackground": "#F0E06044",
    "editor.findMatchHighlightBackground": "#F0E06022",
    "editor.findMatchBorder": "#F0E060",
    "editor.wordHighlightBackground": "#E0406022",
    "editor.wordHighlightStrongBackground": "#E0406044",
    "editorLineNumber.foreground": "#8550A0",
    "editorLineNumber.activeForeground": "#E04060",
    "editorWhitespace.foreground": "#8550A0",
    "editorIndentGuide.background1": "#1A181A",
    "editorIndentGuide.activeBackground1": "#8550A0",
    "editorRuler.foreground": "#1A181A",
    "editorBracketMatch.background": "#E0406022",
    "editorBracketMatch.border": "#605870",
    "editorError.foreground": "#C03040",
    "editorWarning.foreground": "#20A050",
    "editorInfo.foreground": "#E04060",
    "editorHint.foreground": "#B02840",
    "editorGutter.background": "#080608",
    "editorGutter.addedBackground": "#C0D8F0",
    "editorGutter.modifiedBackground": "#806850",
    "editorGutter.deletedBackground": "#C03040",
    "editorGroupHeader.tabsBackground": "#040204",
    "tab.activeBackground": "#080608",
    "tab.inactiveBackground": "#040204",
    "tab.activeForeground": "#A090B8",
    "tab.inactiveForeground": "#8550A0",
    "tab.activeBorderTop": "#E04060",
    "tab.border": "#1A181A",
    "titleBar.activeBackground": "#040204",
    "titleBar.activeForeground": "#A090B8",
    "titleBar.inactiveBackground": "#040204",
    "titleBar.inactiveForeground": "#8550A0",
    "activityBar.background": "#121012",
    "activityBar.foreground": "#A090B8",
    "activityBar.inactiveForeground": "#8550A0",
    "activityBar.border": "#1A181A",
    "activityBarBadge.background": "#E04060",
    "activityBarBadge.foreground": "#080608",
    "sideBar.background": "#121012",
    "sideBar.foreground": "#A090B8",
    "sideBar.border": "#1A181A",
    "list.activeSelectionBackground": "#E0406044",
    "list.activeSelectionForeground": "#A090B8",
    "list.hoverBackground": "#100C10",
    "list.highlightForeground": "#E04060",
    "statusBar.background": "#040204",
    "statusBar.foreground": "#8550A0",
    "statusBar.border": "#1A181A",
    "statusBarItem.remoteBackground": "#E04060",
    "statusBarItem.remoteForeground": "#080608",
    "panel.background": "#080608",
    "panel.border": "#1A181A",
    "terminal.background": "#080608",
    "terminal.foreground": "#A090B8",
    "terminal.ansiBlack": "#040204",
    "terminal.ansiRed": "#C03040",
    "terminal.ansiGreen": "#C0D8F0",
    "terminal.ansiYellow": "#806850",
    "terminal.ansiBlue": "#E04060",
    "terminal.ansiMagenta": "#E0A020",
    "terminal.ansiCyan": "#B02840",
    "terminal.ansiWhite": "#8550A0",
    "terminal.ansiBrightBlack": "#8550A0",
    "terminal.ansiBrightRed": "#C03040",
    "terminal.ansiBrightGreen": "#C0D8F0",
    "terminal.ansiBrightYellow": "#F0E060",
    "terminal.ansiBrightBlue": "#E04060",
    "terminal.ansiBrightMagenta": "#A050D0",
    "terminal.ansiBrightCyan": "#E04060",
    "terminal.ansiBrightWhite": "#A090B8",
    "terminalCursor.foreground": "#E04060",
    "input.background": "#121012",
    "input.foreground": "#A090B8",
    "input.border": "#1A181A",
    "input.placeholderForeground": "#8550A0",
    "button.background": "#E04060",
    "button.foreground": "#080608",
    "badge.background": "#E04060",
    "badge.foreground": "#080608",
    "focusBorder": "#E0406066",
    "scrollbarSlider.background": "#8550A022",
    "scrollbarSlider.hoverBackground": "#8550A033",
    "gitDecoration.addedResourceForeground": "#C0D8F0",
    "gitDecoration.modifiedResourceForeground": "#806850",
    "gitDecoration.deletedResourceForeground": "#C03040",
    "gitDecoration.ignoredResourceForeground": "#8550A0",
    "diffEditor.insertedTextBackground": "#C0D8F018",
    "diffEditor.removedTextBackground": "#C0304018",
    "minimap.findMatchHighlight": "#F0E060",
    "minimap.selectionHighlight": "#E0406044",
    "peekView.border": "#E04060",
    "peekViewEditor.background": "#121012",
    "peekViewResult.background": "#040204",
    "breadcrumb.foreground": "#8550A0",
    "breadcrumb.focusForeground": "#A090B8",
    "editorWidget.background": "#121012",
    "editorSuggestWidget.background": "#121012",
    "editorSuggestWidget.selectedBackground": "#E0406044",
    "editorHoverWidget.background": "#121012"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A090B8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8550A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C0D8F0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#806850"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#806850"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#708898"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#B02840",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#E04060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#30C870",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#30C870"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#B07810",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#A050D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A090B8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#20A050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#407060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#3060C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#F0E060"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#A050D0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8550A0"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#605870"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806090"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#E04060"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B07810"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7854A9"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#806850",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#708898",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#30C870",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#B07810"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#A050D0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E04060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#30C870",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C0D8F0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#B02840"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#E04060"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#E04060",
      "bold": true
    },
    "method": {
      "foreground": "#E04060",
      "bold": true
    },
    "class": {
      "foreground": "#30C870",
      "bold": true
    },
    "struct": {
      "foreground": "#30C870",
      "bold": true
    },
    "interface": {
      "foreground": "#30C870",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#30C870",
      "bold": true
    },
    "enumMember": {
      "foreground": "#B07810",
      "bold": true
    },
    "type": {
      "foreground": "#30C870"
    },
    "typeParameter": {
      "foreground": "#20A050",
      "italic": true
    },
    "variable": {
      "foreground": "#A090B8"
    },
    "variable.readonly": {
      "foreground": "#A050D0"
    },
    "property": {
      "foreground": "#407060"
    },
    "parameter": {
      "foreground": "#20A050",
      "italic": true
    },
    "keyword": {
      "foreground": "#E0A020"
    },
    "string": {
      "foreground": "#C0D8F0"
    },
    "number": {
      "foreground": "#F0E060"
    },
    "comment": {
      "foreground": "#8550A0",
      "italic": true
    },
    "decorator": {
      "foreground": "#A050D0"
    },
    "namespace": {
      "foreground": "#806090"
    },
    "macro": {
      "foreground": "#708898",
      "bold": true
    },
    "lifetime": {
      "foreground": "#806850",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#3060C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#B02840",
      "bold": true
    },
    "operator": {
      "foreground": "#E0A020"
    },
    "*.unsafe": {
      "foreground": "#C03040"
    }
  }
}