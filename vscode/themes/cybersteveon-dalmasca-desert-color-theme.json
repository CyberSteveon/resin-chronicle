  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#B09070"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#302010",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D4B870"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Template / f-string interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression",
        "meta.embedded.expression",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#907840"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C06820"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#208060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#E0A020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type.instance"
      ],
      "settings": {
        "foreground": "#606080"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum",
        "meta.enum"
      ],
      "settings": {
        "foreground": "#606080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#B09070"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#606080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Struct fields / property access",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "meta.path variable.other"
      ],
      "settings": {
        "foreground": "#608050"
      }
    },
    {
      "name": "Self / this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#6090D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#FFD040"
      }
    },
    {
      "name": "Constants and booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language.special"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#C06820"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.brackets"
      ],
      "settings": {
        "foreground": "#302010"
      }
    },
    {
      "name": "Namespace / path separators",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace",
        "meta.path punctuation"
      ],
      "settings": {
        "foreground": "#706040"
      }
    },
    {
      "name": "Import / module names",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806030"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#606080"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03020",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility modifiers (pub / private)",
      "scope": [
        "storage.modifier.visibility",
        "keyword.other.rust",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#504020"
      }
    },
    {
      "name": "Rust — lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": {
        "foreground": "#907050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust — macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust",
        "meta.macro.rust"
      ],
      "settings": {
        "foreground": "#907840",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust — traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust — enum variants (path)",
      "scope": [
        "entity.name.enum.rust",
        "meta.path.rust entity.name.type.rust"
      ],
      "settings": {
        "foreground": "#606080"
      }
    },
    {
      "name": "Rust — derive attributes",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "PowerShell cmdlets",
      "scope": [
        "support.function.powershell",
        "entity.name.function.powershell"
      ],
      "settings": {
        "foreground": "#E0A020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PowerShell variables",
      "scope": [
        "variable.other.readwrite.powershell"
      ],
      "settings": {
        "foreground": "#6090D0"
      }
    },
    {
      "name": "PowerShell parameters",
      "scope": [
        "variable.parameter.powershell"
      ],
      "settings": {
        "foreground": "#606080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#E0A020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#302010",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D4B870"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#208060"
      }
    },
    {
      "name": "JSON / TOML / YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "string.quoted.double.json meta.structure.dictionary.key.json",
        "keyword.key.toml",
        "support.type.property-name.toml",
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#E0A020",
      "bold": true
    },
    "function.declaration": {
      "foreground": "#E0A020",
      "bold": true
    },
    "method": {
      "foreground": "#E0A020",
      "bold": true
    },
    "method.declaration": {
      "foreground": "#E0A020",
      "bold": true
    },
    "class": {
      "foreground": "#8080A0",
      "bold": true
    },
    "class.declaration": {
      "foreground": "#8080A0",
      "bold": true
    },
    "struct": {
      "foreground": "#8080A0",
      "bold": true
    },
    "struct.declaration": {
      "foreground": "#8080A0",
      "bold": true
    },
    "interface": {
      "foreground": "#8080A0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#8080A0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#606080",
      "bold": true
    },
    "type": {
      "foreground": "#606080"
    },
    "typeParameter": {
      "foreground": "#606080",
      "italic": true
    },
    "variable": {
      "foreground": "#B09070"
    },
    "variable.readonly": {
      "foreground": "#D060A0"
    },
    "property": {
      "foreground": "#608050"
    },
    "parameter": {
      "foreground": "#606080",
      "italic": true
    },
    "keyword": {
      "foreground": "#C06820"
    },
    "modifier": {
      "foreground": "#C06820"
    },
    "string": {
      "foreground": "#D4B870"
    },
    "number": {
      "foreground": "#FFD040"
    },
    "comment": {
      "foreground": "#302010",
      "italic": true
    },
    "decorator": {
      "foreground": "#D060A0"
    },
    "namespace": {
      "foreground": "#806030"
    },
    "macro": {
      "foreground": "#907840",
      "bold": true
    },
    "lifetime": {
      "foreground": "#907050",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#6090D0",
      "italic": true
    },
    "selfParameter": {
      "foreground": "#6090D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#208060",
      "bold": true
    },
    "operator": {
      "foreground": "#C06820"
    },
    "*.mutable": {
      "underline": true
    },
    "*.unsafe": {
      "foreground": "#C03020"
    }
  }
}