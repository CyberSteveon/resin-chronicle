{
  "name": "Dalmasca Desert",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0C0902",
    "editor.foreground": "#B09070",
    "editorCursor.foreground": "#E0A020",
    "editor.lineHighlightBackground": "#181206",
    "editor.selectionBackground": "#563D0CCC",
    "editor.selectionHighlightBackground": "#563D0C66",
    "editor.inactiveSelectionBackground": "#563D0C88",
    "editor.findMatchBackground": "#FFD04044",
    "editor.findMatchHighlightBackground": "#FFD04022",
    "editor.findMatchBorder": "#FFD040",
    "editor.wordHighlightBackground": "#563D0C66",
    "editor.wordHighlightStrongBackground": "#563D0CCC",
    "editorLineNumber.foreground": "#8B5D2E",
    "editorLineNumber.activeForeground": "#E0A020",
    "editorWhitespace.foreground": "#8B5D2E",
    "editorIndentGuide.background1": "#1E1B14",
    "editorIndentGuide.activeBackground1": "#8B5D2E",
    "editorRuler.foreground": "#1E1B14",
    "editorBracketMatch.background": "#563D0C66",
    "editorBracketMatch.border": "#706040",
    "editorError.foreground": "#C03020",
    "editorWarning.foreground": "#606080",
    "editorInfo.foreground": "#E0A020",
    "editorHint.foreground": "#208060",
    "editorGutter.background": "#0C0902",
    "editorGutter.addedBackground": "#D4B870",
    "editorGutter.modifiedBackground": "#907050",
    "editorGutter.deletedBackground": "#C03020",
    "editorGroupHeader.tabsBackground": "#080500",
    "tab.activeBackground": "#0C0902",
    "tab.inactiveBackground": "#080500",
    "tab.activeForeground": "#B09070",
    "tab.inactiveForeground": "#8B5D2E",
    "tab.activeBorderTop": "#E0A020",
    "tab.border": "#1E1B14",
    "titleBar.activeBackground": "#080500",
    "titleBar.activeForeground": "#B09070",
    "titleBar.inactiveBackground": "#080500",
    "titleBar.inactiveForeground": "#8B5D2E",
    "activityBar.background": "#16130C",
    "activityBar.foreground": "#B09070",
    "activityBar.inactiveForeground": "#8B5D2E",
    "activityBar.border": "#1E1B14",
    "activityBarBadge.background": "#E0A020",
    "activityBarBadge.foreground": "#0C0902",
    "sideBar.background": "#16130C",
    "sideBar.foreground": "#B09070",
    "sideBar.border": "#1E1B14",
    "list.activeSelectionBackground": "#563D0CCC",
    "list.activeSelectionForeground": "#B09070",
    "list.hoverBackground": "#181206",
    "list.highlightForeground": "#E0A020",
    "statusBar.background": "#080500",
    "statusBar.foreground": "#8B5D2E",
    "statusBar.border": "#1E1B14",
    "statusBarItem.remoteBackground": "#E0A020",
    "statusBarItem.remoteForeground": "#0C0902",
    "panel.background": "#0C0902",
    "panel.border": "#1E1B14",
    "terminal.background": "#0C0902",
    "terminal.foreground": "#B09070",
    "terminal.ansiBlack": "#080500",
    "terminal.ansiRed": "#C03020",
    "terminal.ansiGreen": "#D4B870",
    "terminal.ansiYellow": "#907050",
    "terminal.ansiBlue": "#E0A020",
    "terminal.ansiMagenta": "#C06820",
    "terminal.ansiCyan": "#208060",
    "terminal.ansiWhite": "#8B5D2E",
    "terminal.ansiBrightBlack": "#8B5D2E",
    "terminal.ansiBrightRed": "#C03020",
    "terminal.ansiBrightGreen": "#D4B870",
    "terminal.ansiBrightYellow": "#FFD040",
    "terminal.ansiBrightBlue": "#E0A020",
    "terminal.ansiBrightMagenta": "#D060A0",
    "terminal.ansiBrightCyan": "#E0A020",
    "terminal.ansiBrightWhite": "#B09070",
    "terminalCursor.foreground": "#E0A020",
    "input.background": "#16130C",
    "input.foreground": "#B09070",
    "input.border": "#1E1B14",
    "input.placeholderForeground": "#8B5D2E",
    "button.background": "#E0A020",
    "button.foreground": "#0C0902",
    "badge.background": "#E0A020",
    "badge.foreground": "#0C0902",
    "focusBorder": "#E0A02066",
    "scrollbarSlider.background": "#8B5D2E22",
    "scrollbarSlider.hoverBackground": "#8B5D2E33",
    "gitDecoration.addedResourceForeground": "#D4B870",
    "gitDecoration.modifiedResourceForeground": "#907050",
    "gitDecoration.deletedResourceForeground": "#C03020",
    "gitDecoration.ignoredResourceForeground": "#8B5D2E",
    "diffEditor.insertedTextBackground": "#D4B87018",
    "diffEditor.removedTextBackground": "#C0302018",
    "minimap.findMatchHighlight": "#FFD040",
    "minimap.selectionHighlight": "#563D0CCC",
    "peekView.border": "#E0A020",
    "peekViewEditor.background": "#16130C",
    "peekViewResult.background": "#080500",
    "breadcrumb.foreground": "#8B5D2E",
    "breadcrumb.focusForeground": "#B09070",
    "editorWidget.background": "#16130C",
    "editorSuggestWidget.background": "#16130C",
    "editorSuggestWidget.selectedBackground": "#563D0CCC",
    "editorHoverWidget.background": "#16130C"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#B09070"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8B5D2E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D4B870"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#907840"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C06820"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#208060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#E0A020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#8080A0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#606080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#B09070"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#606080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#608050"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#6090D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFD040"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C06820"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8B5D2E"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#706040"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806030"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#606080"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03020",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#7E6532"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#907050",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#907840",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#606080"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D060A0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E0A020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#8080A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D4B870"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#208060"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#E0A020",
      "bold": true
    },
    "method": {
      "foreground": "#E0A020",
      "bold": true
    },
    "class": {
      "foreground": "#8080A0",
      "bold": true
    },
    "struct": {
      "foreground": "#8080A0",
      "bold": true
    },
    "interface": {
      "foreground": "#8080A0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#8080A0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#606080",
      "bold": true
    },
    "type": {
      "foreground": "#8080A0"
    },
    "typeParameter": {
      "foreground": "#606080",
      "italic": true
    },
    "variable": {
      "foreground": "#B09070"
    },
    "variable.readonly": {
      "foreground": "#D060A0"
    },
    "property": {
      "foreground": "#608050"
    },
    "parameter": {
      "foreground": "#606080",
      "italic": true
    },
    "keyword": {
      "foreground": "#C06820"
    },
    "string": {
      "foreground": "#D4B870"
    },
    "number": {
      "foreground": "#FFD040"
    },
    "comment": {
      "foreground": "#8B5D2E",
      "italic": true
    },
    "decorator": {
      "foreground": "#D060A0"
    },
    "namespace": {
      "foreground": "#806030"
    },
    "macro": {
      "foreground": "#907840",
      "bold": true
    },
    "lifetime": {
      "foreground": "#907050",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#6090D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#208060",
      "bold": true
    },
    "operator": {
      "foreground": "#C06820"
    },
    "*.unsafe": {
      "foreground": "#C03020"
    }
  }
}