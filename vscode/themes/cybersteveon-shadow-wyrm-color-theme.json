{
  "name": "Shadow Wyrm",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#08060E",
    "editor.foreground": "#A890C0",
    "editorCursor.foreground": "#4AE54A",
    "editor.lineHighlightBackground": "#100D1A",
    "editor.selectionBackground": "#1F5423CC",
    "editor.selectionHighlightBackground": "#1F542366",
    "editor.inactiveSelectionBackground": "#1F542388",
    "editor.findMatchBackground": "#4AE54A44",
    "editor.findMatchHighlightBackground": "#4AE54A22",
    "editor.findMatchBorder": "#4AE54A",
    "editor.wordHighlightBackground": "#1F542366",
    "editor.wordHighlightStrongBackground": "#1F5423CC",
    "editorLineNumber.foreground": "#7053BE",
    "editorLineNumber.activeForeground": "#4AE54A",
    "editorWhitespace.foreground": "#7053BE",
    "editorIndentGuide.background1": "#1A1820",
    "editorIndentGuide.activeBackground1": "#7053BE",
    "editorRuler.foreground": "#1A1820",
    "editorBracketMatch.background": "#1F542366",
    "editorBracketMatch.border": "#705888",
    "editorError.foreground": "#C82828",
    "editorWarning.foreground": "#B0A840",
    "editorInfo.foreground": "#4AE54A",
    "editorHint.foreground": "#2EA82E",
    "editorGutter.background": "#08060E",
    "editorGutter.addedBackground": "#C8C0A8",
    "editorGutter.modifiedBackground": "#C89030",
    "editorGutter.deletedBackground": "#C82828",
    "editorGroupHeader.tabsBackground": "#04020A",
    "tab.activeBackground": "#08060E",
    "tab.inactiveBackground": "#04020A",
    "tab.activeForeground": "#A890C0",
    "tab.inactiveForeground": "#7053BE",
    "tab.activeBorderTop": "#4AE54A",
    "tab.border": "#1A1820",
    "titleBar.activeBackground": "#04020A",
    "titleBar.activeForeground": "#A890C0",
    "titleBar.inactiveBackground": "#04020A",
    "titleBar.inactiveForeground": "#7053BE",
    "activityBar.background": "#121018",
    "activityBar.foreground": "#A890C0",
    "activityBar.inactiveForeground": "#7053BE",
    "activityBar.border": "#1A1820",
    "activityBarBadge.background": "#4AE54A",
    "activityBarBadge.foreground": "#08060E",
    "sideBar.background": "#121018",
    "sideBar.foreground": "#A890C0",
    "sideBar.border": "#1A1820",
    "list.activeSelectionBackground": "#1F5423CC",
    "list.activeSelectionForeground": "#A890C0",
    "list.hoverBackground": "#100D1A",
    "list.highlightForeground": "#4AE54A",
    "statusBar.background": "#04020A",
    "statusBar.foreground": "#7053BE",
    "statusBar.border": "#1A1820",
    "statusBarItem.remoteBackground": "#4AE54A",
    "statusBarItem.remoteForeground": "#08060E",
    "panel.background": "#08060E",
    "panel.border": "#1A1820",
    "terminal.background": "#08060E",
    "terminal.foreground": "#A890C0",
    "terminal.ansiBlack": "#04020A",
    "terminal.ansiRed": "#C82828",
    "terminal.ansiGreen": "#C8C0A8",
    "terminal.ansiYellow": "#C89030",
    "terminal.ansiBlue": "#4AE54A",
    "terminal.ansiMagenta": "#9B30C8",
    "terminal.ansiCyan": "#2EA82E",
    "terminal.ansiWhite": "#7053BE",
    "terminal.ansiBrightBlack": "#7053BE",
    "terminal.ansiBrightRed": "#C82828",
    "terminal.ansiBrightGreen": "#C8C0A8",
    "terminal.ansiBrightYellow": "#C060F0",
    "terminal.ansiBrightBlue": "#4AE54A",
    "terminal.ansiBrightMagenta": "#D040A0",
    "terminal.ansiBrightCyan": "#4AE54A",
    "terminal.ansiBrightWhite": "#A890C0",
    "terminalCursor.foreground": "#4AE54A",
    "input.background": "#121018",
    "input.foreground": "#A890C0",
    "input.border": "#1A1820",
    "input.placeholderForeground": "#7053BE",
    "button.background": "#4AE54A",
    "button.foreground": "#08060E",
    "badge.background": "#4AE54A",
    "badge.foreground": "#08060E",
    "focusBorder": "#4AE54A66",
    "scrollbarSlider.background": "#7053BE22",
    "scrollbarSlider.hoverBackground": "#7053BE33",
    "gitDecoration.addedResourceForeground": "#C8C0A8",
    "gitDecoration.modifiedResourceForeground": "#C89030",
    "gitDecoration.deletedResourceForeground": "#C82828",
    "gitDecoration.ignoredResourceForeground": "#7053BE",
    "diffEditor.insertedTextBackground": "#C8C0A818",
    "diffEditor.removedTextBackground": "#C8282818",
    "minimap.findMatchHighlight": "#4AE54A",
    "minimap.selectionHighlight": "#1F5423CC",
    "peekView.border": "#4AE54A",
    "peekViewEditor.background": "#121018",
    "peekViewResult.background": "#04020A",
    "breadcrumb.foreground": "#7053BE",
    "breadcrumb.focusForeground": "#A890C0",
    "editorWidget.background": "#121018",
    "editorSuggestWidget.background": "#121018",
    "editorSuggestWidget.selectedBackground": "#1F5423CC",
    "editorHoverWidget.background": "#121018"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A890C0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7053BE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C8C0A8"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C89030"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#C89030"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#908870"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9B30C8"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#2EA82E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#4AE54A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#E8E060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#E8E060"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#B0A840",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A890C0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B0A840",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#508050"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60A8C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C060F0"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#9B30C8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7053BE"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#705888"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#7755B2"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#4AE54A"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B0A840"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C82828",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#8050B0"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#C89030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#908870",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#E8E060",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#B0A840"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#4AE54A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E8E060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C8C0A8"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#2EA82E"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#4AE54A"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#4AE54A",
      "bold": true
    },
    "method": {
      "foreground": "#4AE54A",
      "bold": true
    },
    "class": {
      "foreground": "#E8E060",
      "bold": true
    },
    "struct": {
      "foreground": "#E8E060",
      "bold": true
    },
    "interface": {
      "foreground": "#E8E060",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#E8E060",
      "bold": true
    },
    "enumMember": {
      "foreground": "#B0A840",
      "bold": true
    },
    "type": {
      "foreground": "#E8E060"
    },
    "typeParameter": {
      "foreground": "#B0A840",
      "italic": true
    },
    "variable": {
      "foreground": "#A890C0"
    },
    "variable.readonly": {
      "foreground": "#D040A0"
    },
    "property": {
      "foreground": "#508050"
    },
    "parameter": {
      "foreground": "#B0A840",
      "italic": true
    },
    "keyword": {
      "foreground": "#9B30C8"
    },
    "string": {
      "foreground": "#C8C0A8"
    },
    "number": {
      "foreground": "#C060F0"
    },
    "comment": {
      "foreground": "#7053BE",
      "italic": true
    },
    "decorator": {
      "foreground": "#D040A0"
    },
    "namespace": {
      "foreground": "#7755B2"
    },
    "macro": {
      "foreground": "#908870",
      "bold": true
    },
    "lifetime": {
      "foreground": "#C89030",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60A8C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#2EA82E",
      "bold": true
    },
    "operator": {
      "foreground": "#9B30C8"
    },
    "*.unsafe": {
      "foreground": "#C82828"
    }
  }
}