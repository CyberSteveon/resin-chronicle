{
  "name": "Neon Resin Dust",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0F1114",
    "editor.foreground": "#B4D1D3",
    "editorCursor.foreground": "#98D4D6",
    "editor.lineHighlightBackground": "#171B20",
    "editor.selectionBackground": "#7FEDF044",
    "editor.selectionHighlightBackground": "#7FEDF022",
    "editor.inactiveSelectionBackground": "#7FEDF022",
    "editor.findMatchBackground": "#A9C53944",
    "editor.findMatchHighlightBackground": "#A9C53922",
    "editor.findMatchBorder": "#A9C539",
    "editor.wordHighlightBackground": "#7FEDF022",
    "editor.wordHighlightStrongBackground": "#7FEDF044",
    "editorLineNumber.foreground": "#656B79",
    "editorLineNumber.activeForeground": "#98D4D6",
    "editorWhitespace.foreground": "#656B79",
    "editorIndentGuide.background1": "#212326",
    "editorIndentGuide.activeBackground1": "#656B79",
    "editorRuler.foreground": "#212326",
    "editorBracketMatch.background": "#7FEDF022",
    "editorBracketMatch.border": "#7A98A4",
    "editorError.foreground": "#D46E77",
    "editorWarning.foreground": "#D4986A",
    "editorInfo.foreground": "#98D4D6",
    "editorHint.foreground": "#2D9B89",
    "editorGutter.background": "#0F1114",
    "editorGutter.addedBackground": "#9FCA81",
    "editorGutter.modifiedBackground": "#A9C539",
    "editorGutter.deletedBackground": "#D46E77",
    "editorGroupHeader.tabsBackground": "#0B0D10",
    "tab.activeBackground": "#0F1114",
    "tab.inactiveBackground": "#0B0D10",
    "tab.activeForeground": "#B4D1D3",
    "tab.inactiveForeground": "#656B79",
    "tab.activeBorderTop": "#98D4D6",
    "tab.border": "#212326",
    "titleBar.activeBackground": "#0B0D10",
    "titleBar.activeForeground": "#B4D1D3",
    "titleBar.inactiveBackground": "#0B0D10",
    "titleBar.inactiveForeground": "#656B79",
    "activityBar.background": "#191B1E",
    "activityBar.foreground": "#B4D1D3",
    "activityBar.inactiveForeground": "#656B79",
    "activityBar.border": "#212326",
    "activityBarBadge.background": "#98D4D6",
    "activityBarBadge.foreground": "#0F1114",
    "sideBar.background": "#191B1E",
    "sideBar.foreground": "#B4D1D3",
    "sideBar.border": "#212326",
    "list.activeSelectionBackground": "#7FEDF044",
    "list.activeSelectionForeground": "#B4D1D3",
    "list.hoverBackground": "#171B20",
    "list.highlightForeground": "#98D4D6",
    "statusBar.background": "#0B0D10",
    "statusBar.foreground": "#656B79",
    "statusBar.border": "#212326",
    "statusBarItem.remoteBackground": "#98D4D6",
    "statusBarItem.remoteForeground": "#0F1114",
    "panel.background": "#0F1114",
    "panel.border": "#212326",
    "terminal.background": "#0F1114",
    "terminal.foreground": "#B4D1D3",
    "terminal.ansiBlack": "#0B0D10",
    "terminal.ansiRed": "#D46E77",
    "terminal.ansiGreen": "#9FCA81",
    "terminal.ansiYellow": "#A9C539",
    "terminal.ansiBlue": "#98D4D6",
    "terminal.ansiMagenta": "#CF5C85",
    "terminal.ansiCyan": "#2D9B89",
    "terminal.ansiWhite": "#656B79",
    "terminal.ansiBrightBlack": "#656B79",
    "terminal.ansiBrightRed": "#D46E77",
    "terminal.ansiBrightGreen": "#9FCA81",
    "terminal.ansiBrightYellow": "#A9C539",
    "terminal.ansiBrightBlue": "#98D4D6",
    "terminal.ansiBrightMagenta": "#CF5C85",
    "terminal.ansiBrightCyan": "#98D4D6",
    "terminal.ansiBrightWhite": "#B4D1D3",
    "terminalCursor.foreground": "#98D4D6",
    "input.background": "#191B1E",
    "input.foreground": "#B4D1D3",
    "input.border": "#212326",
    "input.placeholderForeground": "#656B79",
    "button.background": "#98D4D6",
    "button.foreground": "#0F1114",
    "badge.background": "#98D4D6",
    "badge.foreground": "#0F1114",
    "focusBorder": "#98D4D666",
    "scrollbarSlider.background": "#656B7922",
    "scrollbarSlider.hoverBackground": "#656B7933",
    "gitDecoration.addedResourceForeground": "#9FCA81",
    "gitDecoration.modifiedResourceForeground": "#A9C539",
    "gitDecoration.deletedResourceForeground": "#D46E77",
    "gitDecoration.ignoredResourceForeground": "#656B79",
    "diffEditor.insertedTextBackground": "#9FCA8118",
    "diffEditor.removedTextBackground": "#D46E7718",
    "minimap.findMatchHighlight": "#A9C539",
    "minimap.selectionHighlight": "#7FEDF044",
    "peekView.border": "#98D4D6",
    "peekViewEditor.background": "#191B1E",
    "peekViewResult.background": "#0B0D10",
    "breadcrumb.foreground": "#656B79",
    "breadcrumb.focusForeground": "#B4D1D3",
    "editorWidget.background": "#191B1E",
    "editorSuggestWidget.background": "#191B1E",
    "editorSuggestWidget.selectedBackground": "#7FEDF044",
    "editorHoverWidget.background": "#191B1E"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#B4D1D3"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#656B79",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9FCA81"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#A9C539"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#A9C539"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#C4E3E4"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#CF5C85"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#2D9B89",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#98D4D6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C57539",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C57539"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#D4986A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#CF5C85"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#B4D1D3"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#D4986A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#90BCAD"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#C7D7EF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#A9C539"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#CF5C85"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#CF5C85"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#656B79"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#7A98A4"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#98D4D6"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#98D4D6"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D4986A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#D46E77",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#D59E6E"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#A9C539",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#C4E3E4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C57539",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#D4986A"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#CF5C85"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#98D4D6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C57539",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#9FCA81"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#2D9B89"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#98D4D6"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#98D4D6",
      "bold": true
    },
    "method": {
      "foreground": "#98D4D6",
      "bold": true
    },
    "class": {
      "foreground": "#C57539",
      "bold": true
    },
    "struct": {
      "foreground": "#C57539",
      "bold": true
    },
    "interface": {
      "foreground": "#C57539",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C57539",
      "bold": true
    },
    "enumMember": {
      "foreground": "#D4986A",
      "bold": true
    },
    "type": {
      "foreground": "#C57539"
    },
    "typeParameter": {
      "foreground": "#D4986A",
      "italic": true
    },
    "variable": {
      "foreground": "#B4D1D3"
    },
    "variable.readonly": {
      "foreground": "#CF5C85"
    },
    "property": {
      "foreground": "#90BCAD"
    },
    "parameter": {
      "foreground": "#D4986A",
      "italic": true
    },
    "keyword": {
      "foreground": "#CF5C85"
    },
    "string": {
      "foreground": "#9FCA81"
    },
    "number": {
      "foreground": "#A9C539"
    },
    "comment": {
      "foreground": "#656B79",
      "italic": true
    },
    "decorator": {
      "foreground": "#CF5C85"
    },
    "namespace": {
      "foreground": "#98D4D6"
    },
    "macro": {
      "foreground": "#C4E3E4",
      "bold": true
    },
    "lifetime": {
      "foreground": "#A9C539",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#C7D7EF",
      "italic": true
    },
    "builtinType": {
      "foreground": "#2D9B89",
      "bold": true
    },
    "operator": {
      "foreground": "#CF5C85"
    },
    "*.unsafe": {
      "foreground": "#D46E77"
    }
  }
}