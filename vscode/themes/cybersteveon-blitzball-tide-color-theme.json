{
  "name": "Blitzball Tide",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080408",
    "editor.foreground": "#7898B0",
    "editorCursor.foreground": "#00C8FF",
    "editor.lineHighlightBackground": "#100814",
    "editor.selectionBackground": "#05485ECC",
    "editor.selectionHighlightBackground": "#05485E66",
    "editor.inactiveSelectionBackground": "#05485E88",
    "editor.findMatchBackground": "#FFE04044",
    "editor.findMatchHighlightBackground": "#FFE04022",
    "editor.findMatchBorder": "#FFE040",
    "editor.wordHighlightBackground": "#05485E66",
    "editor.wordHighlightStrongBackground": "#05485ECC",
    "editorLineNumber.foreground": "#4D669A",
    "editorLineNumber.activeForeground": "#00C8FF",
    "editorWhitespace.foreground": "#4D669A",
    "editorIndentGuide.background1": "#1A161A",
    "editorIndentGuide.activeBackground1": "#4D669A",
    "editorRuler.foreground": "#1A161A",
    "editorBracketMatch.background": "#05485E66",
    "editorBracketMatch.border": "#406081",
    "editorError.foreground": "#FF2040",
    "editorWarning.foreground": "#BB1123",
    "editorInfo.foreground": "#00C8FF",
    "editorHint.foreground": "#0090C8",
    "editorGutter.background": "#080408",
    "editorGutter.addedBackground": "#00E5CC",
    "editorGutter.modifiedBackground": "#C08820",
    "editorGutter.deletedBackground": "#FF2040",
    "editorGroupHeader.tabsBackground": "#040004",
    "tab.activeBackground": "#080408",
    "tab.inactiveBackground": "#040004",
    "tab.activeForeground": "#7898B0",
    "tab.inactiveForeground": "#4D669A",
    "tab.activeBorderTop": "#00C8FF",
    "tab.border": "#1A161A",
    "titleBar.activeBackground": "#040004",
    "titleBar.activeForeground": "#7898B0",
    "titleBar.inactiveBackground": "#040004",
    "titleBar.inactiveForeground": "#4D669A",
    "activityBar.background": "#120E12",
    "activityBar.foreground": "#7898B0",
    "activityBar.inactiveForeground": "#4D669A",
    "activityBar.border": "#1A161A",
    "activityBarBadge.background": "#00C8FF",
    "activityBarBadge.foreground": "#080408",
    "sideBar.background": "#120E12",
    "sideBar.foreground": "#7898B0",
    "sideBar.border": "#1A161A",
    "list.activeSelectionBackground": "#05485ECC",
    "list.activeSelectionForeground": "#7898B0",
    "list.hoverBackground": "#100814",
    "list.highlightForeground": "#00C8FF",
    "statusBar.background": "#040004",
    "statusBar.foreground": "#4D669A",
    "statusBar.border": "#1A161A",
    "statusBarItem.remoteBackground": "#00C8FF",
    "statusBarItem.remoteForeground": "#080408",
    "panel.background": "#080408",
    "panel.border": "#1A161A",
    "terminal.background": "#080408",
    "terminal.foreground": "#7898B0",
    "terminal.ansiBlack": "#040004",
    "terminal.ansiRed": "#FF2040",
    "terminal.ansiGreen": "#00E5CC",
    "terminal.ansiYellow": "#C08820",
    "terminal.ansiBlue": "#00C8FF",
    "terminal.ansiMagenta": "#FFB800",
    "terminal.ansiCyan": "#0090C8",
    "terminal.ansiWhite": "#4D669A",
    "terminal.ansiBrightBlack": "#4D669A",
    "terminal.ansiBrightRed": "#FF2040",
    "terminal.ansiBrightGreen": "#00E5CC",
    "terminal.ansiBrightYellow": "#FFE040",
    "terminal.ansiBrightBlue": "#00C8FF",
    "terminal.ansiBrightMagenta": "#E040A0",
    "terminal.ansiBrightCyan": "#00C8FF",
    "terminal.ansiBrightWhite": "#7898B0",
    "terminalCursor.foreground": "#00C8FF",
    "input.background": "#120E12",
    "input.foreground": "#7898B0",
    "input.border": "#1A161A",
    "input.placeholderForeground": "#4D669A",
    "button.background": "#00C8FF",
    "button.foreground": "#080408",
    "badge.background": "#00C8FF",
    "badge.foreground": "#080408",
    "focusBorder": "#00C8FF66",
    "scrollbarSlider.background": "#4D669A22",
    "scrollbarSlider.hoverBackground": "#4D669A33",
    "gitDecoration.addedResourceForeground": "#00E5CC",
    "gitDecoration.modifiedResourceForeground": "#C08820",
    "gitDecoration.deletedResourceForeground": "#FF2040",
    "gitDecoration.ignoredResourceForeground": "#4D669A",
    "diffEditor.insertedTextBackground": "#00E5CC18",
    "diffEditor.removedTextBackground": "#FF204018",
    "minimap.findMatchHighlight": "#FFE040",
    "minimap.selectionHighlight": "#05485ECC",
    "peekView.border": "#00C8FF",
    "peekViewEditor.background": "#120E12",
    "peekViewResult.background": "#040004",
    "breadcrumb.foreground": "#4D669A",
    "breadcrumb.focusForeground": "#7898B0",
    "editorWidget.background": "#120E12",
    "editorSuggestWidget.background": "#120E12",
    "editorSuggestWidget.selectedBackground": "#05485ECC",
    "editorHoverWidget.background": "#120E12"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#7898B0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4D669A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#00E5CC"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C08820"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#C08820"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#006858"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFB800"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#0090C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#00C8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#CC1430",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#CC1430"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#BB1123",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#E040A0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#7898B0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#BB1123",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#308060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#80D8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFE040"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#E040A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFB800"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#4D669A"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#406081"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#005BE5"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#00C8FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#BB1123"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF2040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#3B67A2"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#C08820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#006858",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#CC1430",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#BB1123"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#E040A0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#00C8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#CC1430",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#00E5CC"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#0090C8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#00C8FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#00C8FF",
      "bold": true
    },
    "method": {
      "foreground": "#00C8FF",
      "bold": true
    },
    "class": {
      "foreground": "#CC1430",
      "bold": true
    },
    "struct": {
      "foreground": "#CC1430",
      "bold": true
    },
    "interface": {
      "foreground": "#CC1430",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#CC1430",
      "bold": true
    },
    "enumMember": {
      "foreground": "#BB1123",
      "bold": true
    },
    "type": {
      "foreground": "#CC1430"
    },
    "typeParameter": {
      "foreground": "#BB1123",
      "italic": true
    },
    "variable": {
      "foreground": "#7898B0"
    },
    "variable.readonly": {
      "foreground": "#E040A0"
    },
    "property": {
      "foreground": "#308060"
    },
    "parameter": {
      "foreground": "#BB1123",
      "italic": true
    },
    "keyword": {
      "foreground": "#FFB800"
    },
    "string": {
      "foreground": "#00E5CC"
    },
    "number": {
      "foreground": "#FFE040"
    },
    "comment": {
      "foreground": "#4D669A",
      "italic": true
    },
    "decorator": {
      "foreground": "#E040A0"
    },
    "namespace": {
      "foreground": "#005BE5"
    },
    "macro": {
      "foreground": "#006858",
      "bold": true
    },
    "lifetime": {
      "foreground": "#C08820",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#80D8F0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#0090C8",
      "bold": true
    },
    "operator": {
      "foreground": "#FFB800"
    },
    "*.unsafe": {
      "foreground": "#FF2040"
    }
  }
}