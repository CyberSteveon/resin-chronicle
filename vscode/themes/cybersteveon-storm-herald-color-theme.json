{
  "name": "Storm Herald",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080C12",
    "editor.foreground": "#90A8C0",
    "editorCursor.foreground": "#FFE040",
    "editor.lineHighlightBackground": "#101820",
    "editor.selectionBackground": "#FFE04044",
    "editor.selectionHighlightBackground": "#FFE04022",
    "editor.inactiveSelectionBackground": "#FFE04022",
    "editor.findMatchBackground": "#FFE04044",
    "editor.findMatchHighlightBackground": "#FFE04022",
    "editor.findMatchBorder": "#FFE040",
    "editor.wordHighlightBackground": "#FFE04022",
    "editor.wordHighlightStrongBackground": "#FFE04044",
    "editorLineNumber.foreground": "#546C84",
    "editorLineNumber.activeForeground": "#FFE040",
    "editorWhitespace.foreground": "#546C84",
    "editorIndentGuide.background1": "#1A1E24",
    "editorIndentGuide.activeBackground1": "#546C84",
    "editorRuler.foreground": "#1A1E24",
    "editorBracketMatch.background": "#FFE04022",
    "editorBracketMatch.border": "#506070",
    "editorError.foreground": "#FF4444",
    "editorWarning.foreground": "#4070A0",
    "editorInfo.foreground": "#FFE040",
    "editorHint.foreground": "#40A890",
    "editorGutter.background": "#080C12",
    "editorGutter.addedBackground": "#C0C8D0",
    "editorGutter.modifiedBackground": "#D08030",
    "editorGutter.deletedBackground": "#FF4444",
    "editorGroupHeader.tabsBackground": "#04080E",
    "tab.activeBackground": "#080C12",
    "tab.inactiveBackground": "#04080E",
    "tab.activeForeground": "#90A8C0",
    "tab.inactiveForeground": "#546C84",
    "tab.activeBorderTop": "#FFE040",
    "tab.border": "#1A1E24",
    "titleBar.activeBackground": "#04080E",
    "titleBar.activeForeground": "#90A8C0",
    "titleBar.inactiveBackground": "#04080E",
    "titleBar.inactiveForeground": "#546C84",
    "activityBar.background": "#12161C",
    "activityBar.foreground": "#90A8C0",
    "activityBar.inactiveForeground": "#546C84",
    "activityBar.border": "#1A1E24",
    "activityBarBadge.background": "#FFE040",
    "activityBarBadge.foreground": "#080C12",
    "sideBar.background": "#12161C",
    "sideBar.foreground": "#90A8C0",
    "sideBar.border": "#1A1E24",
    "list.activeSelectionBackground": "#FFE04044",
    "list.activeSelectionForeground": "#90A8C0",
    "list.hoverBackground": "#101820",
    "list.highlightForeground": "#FFE040",
    "statusBar.background": "#04080E",
    "statusBar.foreground": "#546C84",
    "statusBar.border": "#1A1E24",
    "statusBarItem.remoteBackground": "#FFE040",
    "statusBarItem.remoteForeground": "#080C12",
    "panel.background": "#080C12",
    "panel.border": "#1A1E24",
    "terminal.background": "#080C12",
    "terminal.foreground": "#90A8C0",
    "terminal.ansiBlack": "#04080E",
    "terminal.ansiRed": "#FF4444",
    "terminal.ansiGreen": "#C0C8D0",
    "terminal.ansiYellow": "#D08030",
    "terminal.ansiBlue": "#FFE040",
    "terminal.ansiMagenta": "#A070D0",
    "terminal.ansiCyan": "#40A890",
    "terminal.ansiWhite": "#546C84",
    "terminal.ansiBrightBlack": "#546C84",
    "terminal.ansiBrightRed": "#FF4444",
    "terminal.ansiBrightGreen": "#C0C8D0",
    "terminal.ansiBrightYellow": "#C090F0",
    "terminal.ansiBrightBlue": "#FFE040",
    "terminal.ansiBrightMagenta": "#FF6040",
    "terminal.ansiBrightCyan": "#FFE040",
    "terminal.ansiBrightWhite": "#90A8C0",
    "terminalCursor.foreground": "#FFE040",
    "input.background": "#12161C",
    "input.foreground": "#90A8C0",
    "input.border": "#1A1E24",
    "input.placeholderForeground": "#546C84",
    "button.background": "#FFE040",
    "button.foreground": "#080C12",
    "badge.background": "#FFE040",
    "badge.foreground": "#080C12",
    "focusBorder": "#FFE04066",
    "scrollbarSlider.background": "#546C8422",
    "scrollbarSlider.hoverBackground": "#546C8433",
    "gitDecoration.addedResourceForeground": "#C0C8D0",
    "gitDecoration.modifiedResourceForeground": "#D08030",
    "gitDecoration.deletedResourceForeground": "#FF4444",
    "gitDecoration.ignoredResourceForeground": "#546C84",
    "diffEditor.insertedTextBackground": "#C0C8D018",
    "diffEditor.removedTextBackground": "#FF444418",
    "minimap.findMatchHighlight": "#FFE040",
    "minimap.selectionHighlight": "#FFE04044",
    "peekView.border": "#FFE040",
    "peekViewEditor.background": "#12161C",
    "peekViewResult.background": "#04080E",
    "breadcrumb.foreground": "#546C84",
    "breadcrumb.focusForeground": "#90A8C0",
    "editorWidget.background": "#12161C",
    "editorSuggestWidget.background": "#12161C",
    "editorSuggestWidget.selectedBackground": "#FFE04044",
    "editorHoverWidget.background": "#12161C"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#90A8C0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#546C84",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C0C8D0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D08030"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#D08030"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#808898"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A070D0"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#40A890",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#FFE040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#5890C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#5890C8"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#4070A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#FF6040"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#90A8C0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#4070A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#508060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#70A8D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#C090F0"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#FF6040"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#A070D0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#546C84"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#506070"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#3868A0"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FFE040"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4070A0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF4444",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#6058A0"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#D08030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#808898",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#5890C8",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#4070A0"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#FF6040"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FFE040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#5890C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C0C8D0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#40A890"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#FFE040"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#FFE040",
      "bold": true
    },
    "method": {
      "foreground": "#FFE040",
      "bold": true
    },
    "class": {
      "foreground": "#5890C8",
      "bold": true
    },
    "struct": {
      "foreground": "#5890C8",
      "bold": true
    },
    "interface": {
      "foreground": "#5890C8",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#5890C8",
      "bold": true
    },
    "enumMember": {
      "foreground": "#4070A0",
      "bold": true
    },
    "type": {
      "foreground": "#5890C8"
    },
    "typeParameter": {
      "foreground": "#4070A0",
      "italic": true
    },
    "variable": {
      "foreground": "#90A8C0"
    },
    "variable.readonly": {
      "foreground": "#FF6040"
    },
    "property": {
      "foreground": "#508060"
    },
    "parameter": {
      "foreground": "#4070A0",
      "italic": true
    },
    "keyword": {
      "foreground": "#A070D0"
    },
    "string": {
      "foreground": "#C0C8D0"
    },
    "number": {
      "foreground": "#C090F0"
    },
    "comment": {
      "foreground": "#546C84",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF6040"
    },
    "namespace": {
      "foreground": "#3868A0"
    },
    "macro": {
      "foreground": "#808898",
      "bold": true
    },
    "lifetime": {
      "foreground": "#D08030",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#70A8D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#40A890",
      "bold": true
    },
    "operator": {
      "foreground": "#A070D0"
    },
    "*.unsafe": {
      "foreground": "#FF4444"
    }
  }
}