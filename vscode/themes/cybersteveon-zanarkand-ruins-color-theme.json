  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#788898"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#202838",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#B0C8E0"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#906040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#906040"
      }
    },
    {
      "name": "Template / f-string interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression",
        "meta.embedded.expression",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#607888"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#4898D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#70C8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type.instance"
      ],
      "settings": {
        "foreground": "#A06030"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum",
        "meta.enum"
      ],
      "settings": {
        "foreground": "#A06030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#788898"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#A06030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Struct fields / property access",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "meta.path variable.other"
      ],
      "settings": {
        "foreground": "#408898"
      }
    },
    {
      "name": "Self / this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#A0D8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#FFE080"
      }
    },
    {
      "name": "Constants and booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language.special"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.brackets"
      ],
      "settings": {
        "foreground": "#202838"
      }
    },
    {
      "name": "Namespace / path separators",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace",
        "meta.path punctuation"
      ],
      "settings": {
        "foreground": "#405060"
      }
    },
    {
      "name": "Import / module names",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#506080"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#70C8F8"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A06030"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C83050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility modifiers (pub / private)",
      "scope": [
        "storage.modifier.visibility",
        "keyword.other.rust",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#304860"
      }
    },
    {
      "name": "Rust — lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": {
        "foreground": "#906040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust — macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust",
        "meta.macro.rust"
      ],
      "settings": {
        "foreground": "#607888",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust — traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust — enum variants (path)",
      "scope": [
        "entity.name.enum.rust",
        "meta.path.rust entity.name.type.rust"
      ],
      "settings": {
        "foreground": "#A06030"
      }
    },
    {
      "name": "Rust — derive attributes",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "PowerShell cmdlets",
      "scope": [
        "support.function.powershell",
        "entity.name.function.powershell"
      ],
      "settings": {
        "foreground": "#70C8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PowerShell variables",
      "scope": [
        "variable.other.readwrite.powershell"
      ],
      "settings": {
        "foreground": "#A0D8F0"
      }
    },
    {
      "name": "PowerShell parameters",
      "scope": [
        "variable.parameter.powershell"
      ],
      "settings": {
        "foreground": "#A06030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#70C8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#202838",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B0C8E0"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#4898D0"
      }
    },
    {
      "name": "JSON / TOML / YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "string.quoted.double.json meta.structure.dictionary.key.json",
        "keyword.key.toml",
        "support.type.property-name.toml",
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#70C8F8"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#70C8F8",
