    "number": {
      "foreground": "#FFE080"
    },
    "comment": {
      "foreground": "#202838",
      "italic": true
    },
    "decorator": {
      "foreground": "#B060D0"
    },
    "namespace": {
      "foreground": "#506080"
    },
    "macro": {
      "foreground": "#607888",
      "bold": true
    },
    "lifetime": {
      "foreground": "#906040",
      "italic": true
