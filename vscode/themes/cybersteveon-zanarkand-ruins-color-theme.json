{
  "name": "Zanarkand Ruins",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#060810",
    "editor.foreground": "#788898",
    "editorCursor.foreground": "#70C8F8",
    "editor.lineHighlightBackground": "#0C1020",
    "editor.selectionBackground": "#20384ACC",
    "editor.selectionHighlightBackground": "#20384A66",
    "editor.inactiveSelectionBackground": "#20384A88",
    "editor.findMatchBackground": "#FFE08044",
    "editor.findMatchHighlightBackground": "#FFE08022",
    "editor.findMatchBorder": "#FFE080",
    "editor.wordHighlightBackground": "#20384A66",
    "editor.wordHighlightStrongBackground": "#20384ACC",
    "editorLineNumber.foreground": "#526790",
    "editorLineNumber.activeForeground": "#70C8F8",
    "editorWhitespace.foreground": "#526790",
    "editorIndentGuide.background1": "#181A22",
    "editorIndentGuide.activeBackground1": "#526790",
    "editorRuler.foreground": "#181A22",
    "editorBracketMatch.background": "#20384A66",
    "editorBracketMatch.border": "#4E6175",
    "editorError.foreground": "#C83050",
    "editorWarning.foreground": "#A06030",
    "editorInfo.foreground": "#70C8F8",
    "editorHint.foreground": "#4898D0",
    "editorGutter.background": "#060810",
    "editorGutter.addedBackground": "#B0C8E0",
    "editorGutter.modifiedBackground": "#906040",
    "editorGutter.deletedBackground": "#C83050",
    "editorGroupHeader.tabsBackground": "#02040C",
    "tab.activeBackground": "#060810",
    "tab.inactiveBackground": "#02040C",
    "tab.activeForeground": "#788898",
    "tab.inactiveForeground": "#526790",
    "tab.activeBorderTop": "#70C8F8",
    "tab.border": "#181A22",
    "titleBar.activeBackground": "#02040C",
    "titleBar.activeForeground": "#788898",
    "titleBar.inactiveBackground": "#02040C",
    "titleBar.inactiveForeground": "#526790",
    "activityBar.background": "#10121A",
    "activityBar.foreground": "#788898",
    "activityBar.inactiveForeground": "#526790",
    "activityBar.border": "#181A22",
    "activityBarBadge.background": "#70C8F8",
    "activityBarBadge.foreground": "#060810",
    "sideBar.background": "#10121A",
    "sideBar.foreground": "#788898",
    "sideBar.border": "#181A22",
    "list.activeSelectionBackground": "#20384ACC",
    "list.activeSelectionForeground": "#788898",
    "list.hoverBackground": "#0C1020",
    "list.highlightForeground": "#70C8F8",
    "statusBar.background": "#02040C",
    "statusBar.foreground": "#526790",
    "statusBar.border": "#181A22",
    "statusBarItem.remoteBackground": "#70C8F8",
    "statusBarItem.remoteForeground": "#060810",
    "panel.background": "#060810",
    "panel.border": "#181A22",
    "terminal.background": "#060810",
    "terminal.foreground": "#788898",
    "terminal.ansiBlack": "#02040C",
    "terminal.ansiRed": "#C83050",
    "terminal.ansiGreen": "#B0C8E0",
    "terminal.ansiYellow": "#906040",
    "terminal.ansiBlue": "#70C8F8",
    "terminal.ansiMagenta": "#E8C060",
    "terminal.ansiCyan": "#4898D0",
    "terminal.ansiWhite": "#526790",
    "terminal.ansiBrightBlack": "#526790",
    "terminal.ansiBrightRed": "#C83050",
    "terminal.ansiBrightGreen": "#B0C8E0",
    "terminal.ansiBrightYellow": "#FFE080",
    "terminal.ansiBrightBlue": "#70C8F8",
    "terminal.ansiBrightMagenta": "#B060D0",
    "terminal.ansiBrightCyan": "#70C8F8",
    "terminal.ansiBrightWhite": "#788898",
    "terminalCursor.foreground": "#70C8F8",
    "input.background": "#10121A",
    "input.foreground": "#788898",
    "input.border": "#181A22",
    "input.placeholderForeground": "#526790",
    "button.background": "#70C8F8",
    "button.foreground": "#060810",
    "badge.background": "#70C8F8",
    "badge.foreground": "#060810",
    "focusBorder": "#70C8F866",
    "scrollbarSlider.background": "#52679022",
    "scrollbarSlider.hoverBackground": "#52679033",
    "gitDecoration.addedResourceForeground": "#B0C8E0",
    "gitDecoration.modifiedResourceForeground": "#906040",
    "gitDecoration.deletedResourceForeground": "#C83050",
    "gitDecoration.ignoredResourceForeground": "#526790",
    "diffEditor.insertedTextBackground": "#B0C8E018",
    "diffEditor.removedTextBackground": "#C8305018",
    "minimap.findMatchHighlight": "#FFE080",
    "minimap.selectionHighlight": "#20384ACC",
    "peekView.border": "#70C8F8",
    "peekViewEditor.background": "#10121A",
    "peekViewResult.background": "#02040C",
    "breadcrumb.foreground": "#526790",
    "breadcrumb.focusForeground": "#788898",
    "editorWidget.background": "#10121A",
    "editorSuggestWidget.background": "#10121A",
    "editorSuggestWidget.selectedBackground": "#20384ACC",
    "editorHoverWidget.background": "#10121A"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#788898"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#526790",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#B0C8E0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#906040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#906040"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#607888"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#4898D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#70C8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C88040"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#A06030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#788898"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A06030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#408898"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#A0D8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFE080"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#E8C060"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#526790"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#4E6175"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#506080"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#70C8F8"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A06030"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C83050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#476A8E"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#906040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#607888",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#A06030"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#70C8F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C88040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B0C8E0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#4898D0"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#70C8F8"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#70C8F8",
      "bold": true
    },
    "method": {
      "foreground": "#70C8F8",
      "bold": true
    },
    "class": {
      "foreground": "#C88040",
      "bold": true
    },
    "struct": {
      "foreground": "#C88040",
      "bold": true
    },
    "interface": {
      "foreground": "#C88040",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C88040",
      "bold": true
    },
    "enumMember": {
      "foreground": "#A06030",
      "bold": true
    },
    "type": {
      "foreground": "#C88040"
    },
    "typeParameter": {
      "foreground": "#A06030",
      "italic": true
    },
    "variable": {
      "foreground": "#788898"
    },
    "variable.readonly": {
      "foreground": "#B060D0"
    },
    "property": {
      "foreground": "#408898"
    },
    "parameter": {
      "foreground": "#A06030",
      "italic": true
    },
    "keyword": {
      "foreground": "#E8C060"
    },
    "string": {
      "foreground": "#B0C8E0"
    },
    "number": {
      "foreground": "#FFE080"
    },
    "comment": {
      "foreground": "#526790",
      "italic": true
    },
    "decorator": {
      "foreground": "#B060D0"
    },
    "namespace": {
      "foreground": "#506080"
    },
    "macro": {
      "foreground": "#607888",
      "bold": true
    },
    "lifetime": {
      "foreground": "#906040",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#A0D8F0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#4898D0",
      "bold": true
    },
    "operator": {
      "foreground": "#E8C060"
    },
    "*.unsafe": {
      "foreground": "#C83050"
    }
  }
}