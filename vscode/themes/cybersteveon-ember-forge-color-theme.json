{
  "name": "Ember Forge",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0A0806",
    "editor.foreground": "#8090A0",
    "editorCursor.foreground": "#FFB300",
    "editor.lineHighlightBackground": "#141008",
    "editor.selectionBackground": "#473204CC",
    "editor.selectionHighlightBackground": "#47320466",
    "editor.inactiveSelectionBackground": "#47320488",
    "editor.findMatchBackground": "#FFB30044",
    "editor.findMatchHighlightBackground": "#FFB30022",
    "editor.findMatchBorder": "#FFB300",
    "editor.wordHighlightBackground": "#47320466",
    "editor.wordHighlightStrongBackground": "#473204CC",
    "editorLineNumber.foreground": "#7B624A",
    "editorLineNumber.activeForeground": "#FFB300",
    "editorWhitespace.foreground": "#7B624A",
    "editorIndentGuide.background1": "#1C1A18",
    "editorIndentGuide.activeBackground1": "#7B624A",
    "editorRuler.foreground": "#1C1A18",
    "editorBracketMatch.background": "#47320466",
    "editorBracketMatch.border": "#506070",
    "editorError.foreground": "#CC2200",
    "editorWarning.foreground": "#D06020",
    "editorInfo.foreground": "#FF5500",
    "editorHint.foreground": "#CC4400",
    "editorGutter.background": "#0A0806",
    "editorGutter.addedBackground": "#A8B8C0",
    "editorGutter.modifiedBackground": "#B87040",
    "editorGutter.deletedBackground": "#CC2200",
    "editorGroupHeader.tabsBackground": "#060402",
    "tab.activeBackground": "#0A0806",
    "tab.inactiveBackground": "#060402",
    "tab.activeForeground": "#8090A0",
    "tab.inactiveForeground": "#7B624A",
    "tab.activeBorderTop": "#FFB300",
    "tab.border": "#1C1A18",
    "titleBar.activeBackground": "#060402",
    "titleBar.activeForeground": "#8090A0",
    "titleBar.inactiveBackground": "#060402",
    "titleBar.inactiveForeground": "#7B624A",
    "activityBar.background": "#141210",
    "activityBar.foreground": "#8090A0",
    "activityBar.inactiveForeground": "#7B624A",
    "activityBar.border": "#1C1A18",
    "activityBarBadge.background": "#FFB300",
    "activityBarBadge.foreground": "#0A0806",
    "sideBar.background": "#141210",
    "sideBar.foreground": "#8090A0",
    "sideBar.border": "#1C1A18",
    "list.activeSelectionBackground": "#473204CC",
    "list.activeSelectionForeground": "#8090A0",
    "list.hoverBackground": "#141008",
    "list.highlightForeground": "#FFB300",
    "statusBar.background": "#060402",
    "statusBar.foreground": "#7B624A",
    "statusBar.border": "#1C1A18",
    "statusBarItem.remoteBackground": "#FFB300",
    "statusBarItem.remoteForeground": "#0A0806",
    "panel.background": "#0A0806",
    "panel.border": "#1C1A18",
    "terminal.background": "#0A0806",
    "terminal.foreground": "#8090A0",
    "terminal.ansiBlack": "#060402",
    "terminal.ansiRed": "#CC2200",
    "terminal.ansiGreen": "#A8B8C0",
    "terminal.ansiYellow": "#B87040",
    "terminal.ansiBlue": "#FF5500",
    "terminal.ansiMagenta": "#FFB300",
    "terminal.ansiCyan": "#CC4400",
    "terminal.ansiWhite": "#7B624A",
    "terminal.ansiBrightBlack": "#7B624A",
    "terminal.ansiBrightRed": "#CC2200",
    "terminal.ansiBrightGreen": "#A8B8C0",
    "terminal.ansiBrightYellow": "#FFD700",
    "terminal.ansiBrightBlue": "#FF5500",
    "terminal.ansiBrightMagenta": "#C04020",
    "terminal.ansiBrightCyan": "#FFB300",
    "terminal.ansiBrightWhite": "#8090A0",
    "terminalCursor.foreground": "#FFB300",
    "input.background": "#141210",
    "input.foreground": "#8090A0",
    "input.border": "#1C1A18",
    "input.placeholderForeground": "#7B624A",
    "button.background": "#FFB300",
    "button.foreground": "#0A0806",
    "badge.background": "#FFB300",
    "badge.foreground": "#0A0806",
    "focusBorder": "#FFB30066",
    "scrollbarSlider.background": "#7B624A22",
    "scrollbarSlider.hoverBackground": "#7B624A33",
    "gitDecoration.addedResourceForeground": "#A8B8C0",
    "gitDecoration.modifiedResourceForeground": "#B87040",
    "gitDecoration.deletedResourceForeground": "#CC2200",
    "gitDecoration.ignoredResourceForeground": "#7B624A",
    "diffEditor.insertedTextBackground": "#A8B8C018",
    "diffEditor.removedTextBackground": "#CC220018",
    "minimap.findMatchHighlight": "#FFB300",
    "minimap.selectionHighlight": "#473204CC",
    "peekView.border": "#FFB300",
    "peekViewEditor.background": "#141210",
    "peekViewResult.background": "#060402",
    "breadcrumb.foreground": "#7B624A",
    "breadcrumb.focusForeground": "#8090A0",
    "editorWidget.background": "#141210",
    "editorSuggestWidget.background": "#141210",
    "editorSuggestWidget.selectedBackground": "#473204CC",
    "editorHoverWidget.background": "#141210"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#8090A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B624A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#A8B8C0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B87040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#B87040"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#708090"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFB300"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#CC4400",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#FF5500",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF8C00"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#D06020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#C04020"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#8090A0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#D06020",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#5A9060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#70A0C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#C04020"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FFB300"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7B624A"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#506070"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#B87040"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF5500"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D06020"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#CC2200",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#935831"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#B87040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#708090",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#D06020"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#C04020"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FF5500",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A8B8C0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#CC4400"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#FF5500"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#FF5500",
      "bold": true
    },
    "method": {
      "foreground": "#FF5500",
      "bold": true
    },
    "class": {
      "foreground": "#FF8C00",
      "bold": true
    },
    "struct": {
      "foreground": "#FF8C00",
      "bold": true
    },
    "interface": {
      "foreground": "#FF8C00",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#FF8C00",
      "bold": true
    },
    "enumMember": {
      "foreground": "#D06020",
      "bold": true
    },
    "type": {
      "foreground": "#FF8C00"
    },
    "typeParameter": {
      "foreground": "#D06020",
      "italic": true
    },
    "variable": {
      "foreground": "#8090A0"
    },
    "variable.readonly": {
      "foreground": "#C04020"
    },
    "property": {
      "foreground": "#5A9060"
    },
    "parameter": {
      "foreground": "#D06020",
      "italic": true
    },
    "keyword": {
      "foreground": "#FFB300"
    },
    "string": {
      "foreground": "#A8B8C0"
    },
    "number": {
      "foreground": "#FFD700"
    },
    "comment": {
      "foreground": "#7B624A",
      "italic": true
    },
    "decorator": {
      "foreground": "#C04020"
    },
    "namespace": {
      "foreground": "#B87040"
    },
    "macro": {
      "foreground": "#708090",
      "bold": true
    },
    "lifetime": {
      "foreground": "#B87040",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#70A0C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#CC4400",
      "bold": true
    },
    "operator": {
      "foreground": "#FFB300"
    },
    "*.unsafe": {
      "foreground": "#CC2200"
    }
  }
}