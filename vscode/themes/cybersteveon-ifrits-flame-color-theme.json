{
  "name": "Ifrit's Flame",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0A0402",
    "editor.foreground": "#907060",
    "editorCursor.foreground": "#FF4400",
    "editor.lineHighlightBackground": "#180806",
    "editor.selectionBackground": "#471401CC",
    "editor.selectionHighlightBackground": "#47140166",
    "editor.inactiveSelectionBackground": "#47140188",
    "editor.findMatchBackground": "#E0A02044",
    "editor.findMatchHighlightBackground": "#E0A02022",
    "editor.findMatchBorder": "#E0A020",
    "editor.wordHighlightBackground": "#47140166",
    "editor.wordHighlightStrongBackground": "#471401CC",
    "editorLineNumber.foreground": "#B83D1E",
    "editorLineNumber.activeForeground": "#FF4400",
    "editorWhitespace.foreground": "#B83D1E",
    "editorIndentGuide.background1": "#1C1614",
    "editorIndentGuide.activeBackground1": "#B83D1E",
    "editorRuler.foreground": "#1C1614",
    "editorBracketMatch.background": "#47140166",
    "editorBracketMatch.border": "#7E543F",
    "editorError.foreground": "#CC2030",
    "editorWarning.foreground": "#CC3810",
    "editorInfo.foreground": "#FF4400",
    "editorHint.foreground": "#CC2800",
    "editorGutter.background": "#0A0402",
    "editorGutter.addedBackground": "#C09080",
    "editorGutter.modifiedBackground": "#D0C020",
    "editorGutter.deletedBackground": "#CC2030",
    "editorGroupHeader.tabsBackground": "#060000",
    "tab.activeBackground": "#0A0402",
    "tab.inactiveBackground": "#060000",
    "tab.activeForeground": "#907060",
    "tab.inactiveForeground": "#B83D1E",
    "tab.activeBorderTop": "#FF4400",
    "tab.border": "#1C1614",
    "titleBar.activeBackground": "#060000",
    "titleBar.activeForeground": "#907060",
    "titleBar.inactiveBackground": "#060000",
    "titleBar.inactiveForeground": "#B83D1E",
    "activityBar.background": "#140E0C",
    "activityBar.foreground": "#907060",
    "activityBar.inactiveForeground": "#B83D1E",
    "activityBar.border": "#1C1614",
    "activityBarBadge.background": "#FF4400",
    "activityBarBadge.foreground": "#0A0402",
    "sideBar.background": "#140E0C",
    "sideBar.foreground": "#907060",
    "sideBar.border": "#1C1614",
    "list.activeSelectionBackground": "#471401CC",
    "list.activeSelectionForeground": "#907060",
    "list.hoverBackground": "#180806",
    "list.highlightForeground": "#FF4400",
    "statusBar.background": "#060000",
    "statusBar.foreground": "#B83D1E",
    "statusBar.border": "#1C1614",
    "statusBarItem.remoteBackground": "#FF4400",
    "statusBarItem.remoteForeground": "#0A0402",
    "panel.background": "#0A0402",
    "panel.border": "#1C1614",
    "terminal.background": "#0A0402",
    "terminal.foreground": "#907060",
    "terminal.ansiBlack": "#060000",
    "terminal.ansiRed": "#CC2030",
    "terminal.ansiGreen": "#C09080",
    "terminal.ansiYellow": "#D0C020",
    "terminal.ansiBlue": "#FF4400",
    "terminal.ansiMagenta": "#FF8000",
    "terminal.ansiCyan": "#CC2800",
    "terminal.ansiWhite": "#B83D1E",
    "terminal.ansiBrightBlack": "#B83D1E",
    "terminal.ansiBrightRed": "#CC2030",
    "terminal.ansiBrightGreen": "#C09080",
    "terminal.ansiBrightYellow": "#E0A020",
    "terminal.ansiBrightBlue": "#FF4400",
    "terminal.ansiBrightMagenta": "#D04010",
    "terminal.ansiBrightCyan": "#FF4400",
    "terminal.ansiBrightWhite": "#907060",
    "terminalCursor.foreground": "#FF4400",
    "input.background": "#140E0C",
    "input.foreground": "#907060",
    "input.border": "#1C1614",
    "input.placeholderForeground": "#B83D1E",
    "button.background": "#FF4400",
    "button.foreground": "#0A0402",
    "badge.background": "#FF4400",
    "badge.foreground": "#0A0402",
    "focusBorder": "#FF440066",
    "scrollbarSlider.background": "#B83D1E22",
    "scrollbarSlider.hoverBackground": "#B83D1E33",
    "gitDecoration.addedResourceForeground": "#C09080",
    "gitDecoration.modifiedResourceForeground": "#D0C020",
    "gitDecoration.deletedResourceForeground": "#CC2030",
    "gitDecoration.ignoredResourceForeground": "#B83D1E",
    "diffEditor.insertedTextBackground": "#C0908018",
    "diffEditor.removedTextBackground": "#CC203018",
    "minimap.findMatchHighlight": "#E0A020",
    "minimap.selectionHighlight": "#471401CC",
    "peekView.border": "#FF4400",
    "peekViewEditor.background": "#140E0C",
    "peekViewResult.background": "#060000",
    "breadcrumb.foreground": "#B83D1E",
    "breadcrumb.focusForeground": "#907060",
    "editorWidget.background": "#140E0C",
    "editorSuggestWidget.background": "#140E0C",
    "editorSuggestWidget.selectedBackground": "#471401CC",
    "editorHoverWidget.background": "#140E0C"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#907060"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B83D1E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C09080"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D0C020"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#D0C020"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#806050"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF8000"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#CC2800",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#FF4400",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FF6020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF6020"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#CC3810",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D04010"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#907060"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#CC3810",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#508060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#3060A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E0A020"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D04010"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FF8000"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#B83D1E"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#7E543F"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#885B44"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF4400"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#CC3810"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#CC2030",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#B73D1E"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#D0C020",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#806050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#FF6020",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#CC3810"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D04010"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FF4400",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF6020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C09080"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#CC2800"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#FF4400"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#FF4400",
      "bold": true
    },
    "method": {
      "foreground": "#FF4400",
      "bold": true
    },
    "class": {
      "foreground": "#FF6020",
      "bold": true
    },
    "struct": {
      "foreground": "#FF6020",
      "bold": true
    },
    "interface": {
      "foreground": "#FF6020",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#FF6020",
      "bold": true
    },
    "enumMember": {
      "foreground": "#CC3810",
      "bold": true
    },
    "type": {
      "foreground": "#FF6020"
    },
    "typeParameter": {
      "foreground": "#CC3810",
      "italic": true
    },
    "variable": {
      "foreground": "#907060"
    },
    "variable.readonly": {
      "foreground": "#D04010"
    },
    "property": {
      "foreground": "#508060"
    },
    "parameter": {
      "foreground": "#CC3810",
      "italic": true
    },
    "keyword": {
      "foreground": "#FF8000"
    },
    "string": {
      "foreground": "#C09080"
    },
    "number": {
      "foreground": "#E0A020"
    },
    "comment": {
      "foreground": "#B83D1E",
      "italic": true
    },
    "decorator": {
      "foreground": "#D04010"
    },
    "namespace": {
      "foreground": "#885B44"
    },
    "macro": {
      "foreground": "#806050",
      "bold": true
    },
    "lifetime": {
      "foreground": "#D0C020",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#3060A0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#CC2800",
      "bold": true
    },
    "operator": {
      "foreground": "#FF8000"
    },
    "*.unsafe": {
      "foreground": "#CC2030"
    }
  }
}