{
  "name": "Crystalline Dominion",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0A0806",
    "editor.foreground": "#8898A8",
    "editorCursor.foreground": "#90C8F0",
    "editor.lineHighlightBackground": "#141010",
    "editor.selectionBackground": "#90C8F044",
    "editor.selectionHighlightBackground": "#90C8F022",
    "editor.inactiveSelectionBackground": "#90C8F022",
    "editor.findMatchBackground": "#F0D06044",
    "editor.findMatchHighlightBackground": "#F0D06022",
    "editor.findMatchBorder": "#F0D060",
    "editor.wordHighlightBackground": "#90C8F022",
    "editor.wordHighlightStrongBackground": "#90C8F044",
    "editorLineNumber.foreground": "#705D96",
    "editorLineNumber.activeForeground": "#90C8F0",
    "editorWhitespace.foreground": "#705D96",
    "editorIndentGuide.background1": "#1C1A18",
    "editorIndentGuide.activeBackground1": "#705D96",
    "editorRuler.foreground": "#1C1A18",
    "editorBracketMatch.background": "#90C8F022",
    "editorBracketMatch.border": "#506070",
    "editorError.foreground": "#C03040",
    "editorWarning.foreground": "#A07820",
    "editorInfo.foreground": "#90C8F0",
    "editorHint.foreground": "#6098C8",
    "editorGutter.background": "#0A0806",
    "editorGutter.addedBackground": "#E0E8FF",
    "editorGutter.modifiedBackground": "#806080",
    "editorGutter.deletedBackground": "#C03040",
    "editorGroupHeader.tabsBackground": "#060402",
    "tab.activeBackground": "#0A0806",
    "tab.inactiveBackground": "#060402",
    "tab.activeForeground": "#8898A8",
    "tab.inactiveForeground": "#705D96",
    "tab.activeBorderTop": "#90C8F0",
    "tab.border": "#1C1A18",
    "titleBar.activeBackground": "#060402",
    "titleBar.activeForeground": "#8898A8",
    "titleBar.inactiveBackground": "#060402",
    "titleBar.inactiveForeground": "#705D96",
    "activityBar.background": "#141210",
    "activityBar.foreground": "#8898A8",
    "activityBar.inactiveForeground": "#705D96",
    "activityBar.border": "#1C1A18",
    "activityBarBadge.background": "#90C8F0",
    "activityBarBadge.foreground": "#0A0806",
    "sideBar.background": "#141210",
    "sideBar.foreground": "#8898A8",
    "sideBar.border": "#1C1A18",
    "list.activeSelectionBackground": "#90C8F044",
    "list.activeSelectionForeground": "#8898A8",
    "list.hoverBackground": "#141010",
    "list.highlightForeground": "#90C8F0",
    "statusBar.background": "#060402",
    "statusBar.foreground": "#705D96",
    "statusBar.border": "#1C1A18",
    "statusBarItem.remoteBackground": "#90C8F0",
    "statusBarItem.remoteForeground": "#0A0806",
    "panel.background": "#0A0806",
    "panel.border": "#1C1A18",
    "terminal.background": "#0A0806",
    "terminal.foreground": "#8898A8",
    "terminal.ansiBlack": "#060402",
    "terminal.ansiRed": "#C03040",
    "terminal.ansiGreen": "#E0E8FF",
    "terminal.ansiYellow": "#806080",
    "terminal.ansiBlue": "#90C8F0",
    "terminal.ansiMagenta": "#D0A830",
    "terminal.ansiCyan": "#6098C8",
    "terminal.ansiWhite": "#705D96",
    "terminal.ansiBrightBlack": "#705D96",
    "terminal.ansiBrightRed": "#C03040",
    "terminal.ansiBrightGreen": "#E0E8FF",
    "terminal.ansiBrightYellow": "#F0D060",
    "terminal.ansiBrightBlue": "#90C8F0",
    "terminal.ansiBrightMagenta": "#E06040",
    "terminal.ansiBrightCyan": "#90C8F0",
    "terminal.ansiBrightWhite": "#8898A8",
    "terminalCursor.foreground": "#90C8F0",
    "input.background": "#141210",
    "input.foreground": "#8898A8",
    "input.border": "#1C1A18",
    "input.placeholderForeground": "#705D96",
    "button.background": "#90C8F0",
    "button.foreground": "#0A0806",
    "badge.background": "#90C8F0",
    "badge.foreground": "#0A0806",
    "focusBorder": "#90C8F066",
    "scrollbarSlider.background": "#705D9622",
    "scrollbarSlider.hoverBackground": "#705D9633",
    "gitDecoration.addedResourceForeground": "#E0E8FF",
    "gitDecoration.modifiedResourceForeground": "#806080",
    "gitDecoration.deletedResourceForeground": "#C03040",
    "gitDecoration.ignoredResourceForeground": "#705D96",
    "diffEditor.insertedTextBackground": "#E0E8FF18",
    "diffEditor.removedTextBackground": "#C0304018",
    "minimap.findMatchHighlight": "#F0D060",
    "minimap.selectionHighlight": "#90C8F044",
    "peekView.border": "#90C8F0",
    "peekViewEditor.background": "#141210",
    "peekViewResult.background": "#060402",
    "breadcrumb.foreground": "#705D96",
    "breadcrumb.focusForeground": "#8898A8",
    "editorWidget.background": "#141210",
    "editorSuggestWidget.background": "#141210",
    "editorSuggestWidget.selectedBackground": "#90C8F044",
    "editorHoverWidget.background": "#141210"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#8898A8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#705D96",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#E0E8FF"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#806080"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#806080"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#8090B0"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D0A830"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#6098C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#90C8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#B060D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#B060D0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#A07820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#E06040"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#8898A8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A07820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#407860"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60D8C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#F0D060"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#E06040"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#D0A830"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#705D96"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#506070"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#5166A3"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#90C8F0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A07820"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#5166A3"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#806080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#8090B0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#B060D0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#A07820"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#E06040"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#90C8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#B060D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E0E8FF"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#6098C8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#90C8F0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#90C8F0",
      "bold": true
    },
    "method": {
      "foreground": "#90C8F0",
      "bold": true
    },
    "class": {
      "foreground": "#B060D0",
      "bold": true
    },
    "struct": {
      "foreground": "#B060D0",
      "bold": true
    },
    "interface": {
      "foreground": "#B060D0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#B060D0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#A07820",
      "bold": true
    },
    "type": {
      "foreground": "#B060D0"
    },
    "typeParameter": {
      "foreground": "#A07820",
      "italic": true
    },
    "variable": {
      "foreground": "#8898A8"
    },
    "variable.readonly": {
      "foreground": "#E06040"
    },
    "property": {
      "foreground": "#407860"
    },
    "parameter": {
      "foreground": "#A07820",
      "italic": true
    },
    "keyword": {
      "foreground": "#D0A830"
    },
    "string": {
      "foreground": "#E0E8FF"
    },
    "number": {
      "foreground": "#F0D060"
    },
    "comment": {
      "foreground": "#705D96",
      "italic": true
    },
    "decorator": {
      "foreground": "#E06040"
    },
    "namespace": {
      "foreground": "#5166A3"
    },
    "macro": {
      "foreground": "#8090B0",
      "bold": true
    },
    "lifetime": {
      "foreground": "#806080",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60D8C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#6098C8",
      "bold": true
    },
    "operator": {
      "foreground": "#D0A830"
    },
    "*.unsafe": {
      "foreground": "#C03040"
    }
  }
}