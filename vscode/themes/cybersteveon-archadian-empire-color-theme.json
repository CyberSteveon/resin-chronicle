  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A0B0C0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#302018",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D0B080"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#907860"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#907860"
      }
    },
    {
      "name": "Template / f-string interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression",
        "meta.embedded.expression",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#6030A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8040C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type.instance"
      ],
      "settings": {
        "foreground": "#906800"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum",
        "meta.enum"
      ],
      "settings": {
        "foreground": "#906800",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#A0B0C0"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#B05820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Struct fields / property access",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "meta.path variable.other"
      ],
      "settings": {
        "foreground": "#608060"
      }
    },
    {
      "name": "Self / this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#6090D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Constants and booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language.special"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.brackets"
      ],
      "settings": {
        "foreground": "#302018"
      }
    },
    {
      "name": "Namespace / path separators",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace",
        "meta.path punctuation"
      ],
      "settings": {
        "foreground": "#607080"
      }
    },
    {
      "name": "Import / module names",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806030"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#8040C0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#906800"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03030",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility modifiers (pub / private)",
      "scope": [
        "storage.modifier.visibility",
        "keyword.other.rust",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#604010"
      }
    },
    {
      "name": "Rust — lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": {
        "foreground": "#907860",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust — macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust",
        "meta.macro.rust"
      ],
      "settings": {
        "foreground": "#907050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust — traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust — enum variants (path)",
      "scope": [
        "entity.name.enum.rust",
        "meta.path.rust entity.name.type.rust"
      ],
      "settings": {
        "foreground": "#906800"
      }
    },
    {
      "name": "Rust — derive attributes",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "PowerShell cmdlets",
      "scope": [
        "support.function.powershell",
        "entity.name.function.powershell"
      ],
      "settings": {
        "foreground": "#8040C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PowerShell variables",
      "scope": [
        "variable.other.readwrite.powershell"
      ],
      "settings": {
        "foreground": "#6090D0"
      }
    },
    {
      "name": "PowerShell parameters",
      "scope": [
        "variable.parameter.powershell"
      ],
      "settings": {
        "foreground": "#B05820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#8040C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#302018",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D0B080"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6030A0"
      }
    },
    {
      "name": "JSON / TOML / YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "string.quoted.double.json meta.structure.dictionary.key.json",
        "keyword.key.toml",
        "support.type.property-name.toml",
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#8040C0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#8040C0",
      "bold": true
    },
    "function.declaration": {
      "foreground": "#8040C0",
      "bold": true
    },
    "method": {
      "foreground": "#8040C0",
      "bold": true
    },
    "method.declaration": {
      "foreground": "#8040C0",
      "bold": true
    },
    "class": {
      "foreground": "#E08040",
      "bold": true
    },
    "class.declaration": {
      "foreground": "#E08040",
      "bold": true
    },
    "struct": {
      "foreground": "#E08040",
      "bold": true
    },
    "struct.declaration": {
      "foreground": "#E08040",
      "bold": true
    },
    "interface": {
      "foreground": "#E08040",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#E08040",
      "bold": true
    },
    "enumMember": {
      "foreground": "#906800",
      "bold": true
    },
    "type": {
      "foreground": "#906800"
    },
    "typeParameter": {
      "foreground": "#B05820",
      "italic": true
    },
    "variable": {
      "foreground": "#A0B0C0"
    },
    "variable.readonly": {
      "foreground": "#D040A0"
    },
    "property": {
      "foreground": "#608060"
    },
    "parameter": {
      "foreground": "#B05820",
      "italic": true
    },
    "keyword": {
      "foreground": "#C0900A"
    },
    "modifier": {
      "foreground": "#C0900A"
    },
    "string": {
      "foreground": "#D0B080"
    },
    "number": {
      "foreground": "#C0900A"
    },
    "comment": {
      "foreground": "#302018",
      "italic": true
    },
    "decorator": {
      "foreground": "#D040A0"
    },
    "namespace": {
      "foreground": "#806030"
    },
    "macro": {
      "foreground": "#907050",
      "bold": true
    },
    "lifetime": {
      "foreground": "#907860",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#6090D0",
      "italic": true
    },
    "selfParameter": {
      "foreground": "#6090D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#6030A0",
      "bold": true
    },
    "operator": {
      "foreground": "#C0900A"
    },
    "*.mutable": {
      "underline": true
    },
    "*.unsafe": {
      "foreground": "#C03030"
    }
  }
}