{
  "name": "Archadian Empire",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0C0808",
    "editor.foreground": "#A0B0C0",
    "editorCursor.foreground": "#C0900A",
    "editor.lineHighlightBackground": "#181010",
    "editor.selectionBackground": "#4A3708CC",
    "editor.selectionHighlightBackground": "#4A370866",
    "editor.inactiveSelectionBackground": "#4A370888",
    "editor.findMatchBackground": "#C0900A44",
    "editor.findMatchHighlightBackground": "#C0900A22",
    "editor.findMatchBorder": "#C0900A",
    "editor.wordHighlightBackground": "#4A370866",
    "editor.wordHighlightStrongBackground": "#4A3708CC",
    "editorLineNumber.foreground": "#8C5D46",
    "editorLineNumber.activeForeground": "#C0900A",
    "editorWhitespace.foreground": "#8C5D46",
    "editorIndentGuide.background1": "#1E1A1A",
    "editorIndentGuide.activeBackground1": "#8C5D46",
    "editorRuler.foreground": "#1E1A1A",
    "editorBracketMatch.background": "#4A370866",
    "editorBracketMatch.border": "#607080",
    "editorError.foreground": "#C03030",
    "editorWarning.foreground": "#B05820",
    "editorInfo.foreground": "#8040C0",
    "editorHint.foreground": "#793FC5",
    "editorGutter.background": "#0C0808",
    "editorGutter.addedBackground": "#D0B080",
    "editorGutter.modifiedBackground": "#907860",
    "editorGutter.deletedBackground": "#C03030",
    "editorGroupHeader.tabsBackground": "#080404",
    "tab.activeBackground": "#0C0808",
    "tab.inactiveBackground": "#080404",
    "tab.activeForeground": "#A0B0C0",
    "tab.inactiveForeground": "#8C5D46",
    "tab.activeBorderTop": "#C0900A",
    "tab.border": "#1E1A1A",
    "titleBar.activeBackground": "#080404",
    "titleBar.activeForeground": "#A0B0C0",
    "titleBar.inactiveBackground": "#080404",
    "titleBar.inactiveForeground": "#8C5D46",
    "activityBar.background": "#161212",
    "activityBar.foreground": "#A0B0C0",
    "activityBar.inactiveForeground": "#8C5D46",
    "activityBar.border": "#1E1A1A",
    "activityBarBadge.background": "#C0900A",
    "activityBarBadge.foreground": "#0C0808",
    "sideBar.background": "#161212",
    "sideBar.foreground": "#A0B0C0",
    "sideBar.border": "#1E1A1A",
    "list.activeSelectionBackground": "#4A3708CC",
    "list.activeSelectionForeground": "#A0B0C0",
    "list.hoverBackground": "#181010",
    "list.highlightForeground": "#C0900A",
    "statusBar.background": "#080404",
    "statusBar.foreground": "#8C5D46",
    "statusBar.border": "#1E1A1A",
    "statusBarItem.remoteBackground": "#C0900A",
    "statusBarItem.remoteForeground": "#0C0808",
    "panel.background": "#0C0808",
    "panel.border": "#1E1A1A",
    "terminal.background": "#0C0808",
    "terminal.foreground": "#A0B0C0",
    "terminal.ansiBlack": "#080404",
    "terminal.ansiRed": "#C03030",
    "terminal.ansiGreen": "#D0B080",
    "terminal.ansiYellow": "#907860",
    "terminal.ansiBlue": "#8040C0",
    "terminal.ansiMagenta": "#C0900A",
    "terminal.ansiCyan": "#793FC5",
    "terminal.ansiWhite": "#8C5D46",
    "terminal.ansiBrightBlack": "#8C5D46",
    "terminal.ansiBrightRed": "#C03030",
    "terminal.ansiBrightGreen": "#D0B080",
    "terminal.ansiBrightYellow": "#C0900A",
    "terminal.ansiBrightBlue": "#8040C0",
    "terminal.ansiBrightMagenta": "#D040A0",
    "terminal.ansiBrightCyan": "#C0900A",
    "terminal.ansiBrightWhite": "#A0B0C0",
    "terminalCursor.foreground": "#C0900A",
    "input.background": "#161212",
    "input.foreground": "#A0B0C0",
    "input.border": "#1E1A1A",
    "input.placeholderForeground": "#8C5D46",
    "button.background": "#C0900A",
    "button.foreground": "#0C0808",
    "badge.background": "#C0900A",
    "badge.foreground": "#0C0808",
    "focusBorder": "#C0900A66",
    "scrollbarSlider.background": "#8C5D4622",
    "scrollbarSlider.hoverBackground": "#8C5D4633",
    "gitDecoration.addedResourceForeground": "#D0B080",
    "gitDecoration.modifiedResourceForeground": "#907860",
    "gitDecoration.deletedResourceForeground": "#C03030",
    "gitDecoration.ignoredResourceForeground": "#8C5D46",
    "diffEditor.insertedTextBackground": "#D0B08018",
    "diffEditor.removedTextBackground": "#C0303018",
    "minimap.findMatchHighlight": "#C0900A",
    "minimap.selectionHighlight": "#4A3708CC",
    "peekView.border": "#C0900A",
    "peekViewEditor.background": "#161212",
    "peekViewResult.background": "#080404",
    "breadcrumb.foreground": "#8C5D46",
    "breadcrumb.focusForeground": "#A0B0C0",
    "editorWidget.background": "#161212",
    "editorSuggestWidget.background": "#161212",
    "editorSuggestWidget.selectedBackground": "#4A3708CC",
    "editorHoverWidget.background": "#161212"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#A0B0C0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C5D46",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D0B080"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#907860"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#907860"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#907050"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#793FC5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#8040C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#E08040"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#906800",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A0B0C0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B05820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#608060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#6090D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C0900A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8C5D46"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#607080"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#806030"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#8040C0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#906800"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C03030",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#8D5E17"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#907860",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#907050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#906800"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#D040A0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#8040C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E08040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D0B080"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#793FC5"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#8040C0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#8040C0",
      "bold": true
    },
    "method": {
      "foreground": "#8040C0",
      "bold": true
    },
    "class": {
      "foreground": "#E08040",
      "bold": true
    },
    "struct": {
      "foreground": "#E08040",
      "bold": true
    },
    "interface": {
      "foreground": "#E08040",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#E08040",
      "bold": true
    },
    "enumMember": {
      "foreground": "#906800",
      "bold": true
    },
    "type": {
      "foreground": "#E08040"
    },
    "typeParameter": {
      "foreground": "#B05820",
      "italic": true
    },
    "variable": {
      "foreground": "#A0B0C0"
    },
    "variable.readonly": {
      "foreground": "#D040A0"
    },
    "property": {
      "foreground": "#608060"
    },
    "parameter": {
      "foreground": "#B05820",
      "italic": true
    },
    "keyword": {
      "foreground": "#C0900A"
    },
    "string": {
      "foreground": "#D0B080"
    },
    "number": {
      "foreground": "#C0900A"
    },
    "comment": {
      "foreground": "#8C5D46",
      "italic": true
    },
    "decorator": {
      "foreground": "#D040A0"
    },
    "namespace": {
      "foreground": "#806030"
    },
    "macro": {
      "foreground": "#907050",
      "bold": true
    },
    "lifetime": {
      "foreground": "#907860",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#6090D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#793FC5",
      "bold": true
    },
    "operator": {
      "foreground": "#C0900A"
    },
    "*.unsafe": {
      "foreground": "#C03030"
    }
  }
}