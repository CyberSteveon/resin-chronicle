{
  "name": "Mako Reactor",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#060E08",
    "editor.foreground": "#708090",
    "editorCursor.foreground": "#39FF14",
    "editor.lineHighlightBackground": "#0C1A0E",
    "editor.selectionBackground": "#39FF1444",
    "editor.selectionHighlightBackground": "#39FF1422",
    "editor.inactiveSelectionBackground": "#39FF1422",
    "editor.findMatchBackground": "#A0FF6044",
    "editor.findMatchHighlightBackground": "#A0FF6022",
    "editor.findMatchBorder": "#A0FF60",
    "editor.wordHighlightBackground": "#39FF1422",
    "editor.wordHighlightStrongBackground": "#39FF1444",
    "editorLineNumber.foreground": "#547054",
    "editorLineNumber.activeForeground": "#39FF14",
    "editorWhitespace.foreground": "#547054",
    "editorIndentGuide.background1": "#18201A",
    "editorIndentGuide.activeBackground1": "#547054",
    "editorRuler.foreground": "#18201A",
    "editorBracketMatch.background": "#39FF1422",
    "editorBracketMatch.border": "#516274",
    "editorError.foreground": "#CC2040",
    "editorWarning.foreground": "#906000",
    "editorInfo.foreground": "#39FF14",
    "editorHint.foreground": "#1EC400",
    "editorGutter.background": "#060E08",
    "editorGutter.addedBackground": "#A0B0B8",
    "editorGutter.modifiedBackground": "#FFB000",
    "editorGutter.deletedBackground": "#CC2040",
    "editorGroupHeader.tabsBackground": "#020A04",
    "tab.activeBackground": "#060E08",
    "tab.inactiveBackground": "#020A04",
    "tab.activeForeground": "#708090",
    "tab.inactiveForeground": "#547054",
    "tab.activeBorderTop": "#39FF14",
    "tab.border": "#18201A",
    "titleBar.activeBackground": "#020A04",
    "titleBar.activeForeground": "#708090",
    "titleBar.inactiveBackground": "#020A04",
    "titleBar.inactiveForeground": "#547054",
    "activityBar.background": "#101812",
    "activityBar.foreground": "#708090",
    "activityBar.inactiveForeground": "#547054",
    "activityBar.border": "#18201A",
    "activityBarBadge.background": "#39FF14",
    "activityBarBadge.foreground": "#060E08",
    "sideBar.background": "#101812",
    "sideBar.foreground": "#708090",
    "sideBar.border": "#18201A",
    "list.activeSelectionBackground": "#39FF1444",
    "list.activeSelectionForeground": "#708090",
    "list.hoverBackground": "#0C1A0E",
    "list.highlightForeground": "#39FF14",
    "statusBar.background": "#020A04",
    "statusBar.foreground": "#547054",
    "statusBar.border": "#18201A",
    "statusBarItem.remoteBackground": "#39FF14",
    "statusBarItem.remoteForeground": "#060E08",
    "panel.background": "#060E08",
    "panel.border": "#18201A",
    "terminal.background": "#060E08",
    "terminal.foreground": "#708090",
    "terminal.ansiBlack": "#020A04",
    "terminal.ansiRed": "#CC2040",
    "terminal.ansiGreen": "#A0B0B8",
    "terminal.ansiYellow": "#FFB000",
    "terminal.ansiBlue": "#39FF14",
    "terminal.ansiMagenta": "#00C070",
    "terminal.ansiCyan": "#1EC400",
    "terminal.ansiWhite": "#547054",
    "terminal.ansiBrightBlack": "#547054",
    "terminal.ansiBrightRed": "#CC2040",
    "terminal.ansiBrightGreen": "#A0B0B8",
    "terminal.ansiBrightYellow": "#A0FF60",
    "terminal.ansiBrightBlue": "#39FF14",
    "terminal.ansiBrightMagenta": "#8060D0",
    "terminal.ansiBrightCyan": "#39FF14",
    "terminal.ansiBrightWhite": "#708090",
    "terminalCursor.foreground": "#39FF14",
    "input.background": "#101812",
    "input.foreground": "#708090",
    "input.border": "#18201A",
    "input.placeholderForeground": "#547054",
    "button.background": "#39FF14",
    "button.foreground": "#060E08",
    "badge.background": "#39FF14",
    "badge.foreground": "#060E08",
    "focusBorder": "#39FF1466",
    "scrollbarSlider.background": "#54705422",
    "scrollbarSlider.hoverBackground": "#54705433",
    "gitDecoration.addedResourceForeground": "#A0B0B8",
    "gitDecoration.modifiedResourceForeground": "#FFB000",
    "gitDecoration.deletedResourceForeground": "#CC2040",
    "gitDecoration.ignoredResourceForeground": "#547054",
    "diffEditor.insertedTextBackground": "#A0B0B818",
    "diffEditor.removedTextBackground": "#CC204018",
    "minimap.findMatchHighlight": "#A0FF60",
    "minimap.selectionHighlight": "#39FF1444",
    "peekView.border": "#39FF14",
    "peekViewEditor.background": "#101812",
    "peekViewResult.background": "#020A04",
    "breadcrumb.foreground": "#547054",
    "breadcrumb.focusForeground": "#708090",
    "editorWidget.background": "#101812",
    "editorSuggestWidget.background": "#101812",
    "editorSuggestWidget.selectedBackground": "#39FF1444",
    "editorHoverWidget.background": "#101812"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#708090"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#547054",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#A0B0B8"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFB000"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#FFB000"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#607080"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00C070"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#1EC400",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#39FF14",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#C08000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#C08000"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#906000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#8060D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#708090"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#906000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#208050"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#5090C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#A0FF60"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#8060D0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#00C070"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#547054"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#516274"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#4B715E"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#39FF14"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#906000"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#CC2040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#3A754E"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#FFB000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#607080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#C08000",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#906000"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#8060D0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#39FF14",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C08000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#A0B0B8"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#1EC400"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#39FF14"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#39FF14",
      "bold": true
    },
    "method": {
      "foreground": "#39FF14",
      "bold": true
    },
    "class": {
      "foreground": "#C08000",
      "bold": true
    },
    "struct": {
      "foreground": "#C08000",
      "bold": true
    },
    "interface": {
      "foreground": "#C08000",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#C08000",
      "bold": true
    },
    "enumMember": {
      "foreground": "#906000",
      "bold": true
    },
    "type": {
      "foreground": "#C08000"
    },
    "typeParameter": {
      "foreground": "#906000",
      "italic": true
    },
    "variable": {
      "foreground": "#708090"
    },
    "variable.readonly": {
      "foreground": "#8060D0"
    },
    "property": {
      "foreground": "#208050"
    },
    "parameter": {
      "foreground": "#906000",
      "italic": true
    },
    "keyword": {
      "foreground": "#00C070"
    },
    "string": {
      "foreground": "#A0B0B8"
    },
    "number": {
      "foreground": "#A0FF60"
    },
    "comment": {
      "foreground": "#547054",
      "italic": true
    },
    "decorator": {
      "foreground": "#8060D0"
    },
    "namespace": {
      "foreground": "#4B715E"
    },
    "macro": {
      "foreground": "#607080",
      "bold": true
    },
    "lifetime": {
      "foreground": "#FFB000",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#5090C0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#1EC400",
      "bold": true
    },
    "operator": {
      "foreground": "#00C070"
    },
    "*.unsafe": {
      "foreground": "#CC2040"
    }
  }
}