{
  "name": "Shiva's Embrace",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#04080E",
    "editor.foreground": "#7890A0",
    "editorCursor.foreground": "#A0E8FF",
    "editor.lineHighlightBackground": "#080F1C",
    "editor.selectionBackground": "#2B404ACC",
    "editor.selectionHighlightBackground": "#2B404A66",
    "editor.inactiveSelectionBackground": "#2B404A88",
    "editor.findMatchBackground": "#E0F8FF44",
    "editor.findMatchHighlightBackground": "#E0F8FF22",
    "editor.findMatchBorder": "#E0F8FF",
    "editor.wordHighlightBackground": "#2B404A66",
    "editor.wordHighlightStrongBackground": "#2B404ACC",
    "editorLineNumber.foreground": "#476B8F",
    "editorLineNumber.activeForeground": "#A0E8FF",
    "editorWhitespace.foreground": "#476B8F",
    "editorIndentGuide.background1": "#161A20",
    "editorIndentGuide.activeBackground1": "#476B8F",
    "editorRuler.foreground": "#161A20",
    "editorBracketMatch.background": "#2B404A66",
    "editorBracketMatch.border": "#4C6278",
    "editorError.foreground": "#D03050",
    "editorWarning.foreground": "#9848C0",
    "editorInfo.foreground": "#A0E8FF",
    "editorHint.foreground": "#68C0E8",
    "editorGutter.background": "#04080E",
    "editorGutter.addedBackground": "#D0EEFF",
    "editorGutter.modifiedBackground": "#807040",
    "editorGutter.deletedBackground": "#D03050",
    "editorGroupHeader.tabsBackground": "#00040A",
    "tab.activeBackground": "#04080E",
    "tab.inactiveBackground": "#00040A",
    "tab.activeForeground": "#7890A0",
    "tab.inactiveForeground": "#476B8F",
    "tab.activeBorderTop": "#A0E8FF",
    "tab.border": "#161A20",
    "titleBar.activeBackground": "#00040A",
    "titleBar.activeForeground": "#7890A0",
    "titleBar.inactiveBackground": "#00040A",
    "titleBar.inactiveForeground": "#476B8F",
    "activityBar.background": "#0E1218",
    "activityBar.foreground": "#7890A0",
    "activityBar.inactiveForeground": "#476B8F",
    "activityBar.border": "#161A20",
    "activityBarBadge.background": "#A0E8FF",
    "activityBarBadge.foreground": "#04080E",
    "sideBar.background": "#0E1218",
    "sideBar.foreground": "#7890A0",
    "sideBar.border": "#161A20",
    "list.activeSelectionBackground": "#2B404ACC",
    "list.activeSelectionForeground": "#7890A0",
    "list.hoverBackground": "#080F1C",
    "list.highlightForeground": "#A0E8FF",
    "statusBar.background": "#00040A",
    "statusBar.foreground": "#476B8F",
    "statusBar.border": "#161A20",
    "statusBarItem.remoteBackground": "#A0E8FF",
    "statusBarItem.remoteForeground": "#04080E",
    "panel.background": "#04080E",
    "panel.border": "#161A20",
    "terminal.background": "#04080E",
    "terminal.foreground": "#7890A0",
    "terminal.ansiBlack": "#00040A",
    "terminal.ansiRed": "#D03050",
    "terminal.ansiGreen": "#D0EEFF",
    "terminal.ansiYellow": "#807040",
    "terminal.ansiBlue": "#A0E8FF",
    "terminal.ansiMagenta": "#C060E0",
    "terminal.ansiCyan": "#68C0E8",
    "terminal.ansiWhite": "#476B8F",
    "terminal.ansiBrightBlack": "#476B8F",
    "terminal.ansiBrightRed": "#D03050",
    "terminal.ansiBrightGreen": "#D0EEFF",
    "terminal.ansiBrightYellow": "#E0F8FF",
    "terminal.ansiBrightBlue": "#A0E8FF",
    "terminal.ansiBrightMagenta": "#A050C8",
    "terminal.ansiBrightCyan": "#A0E8FF",
    "terminal.ansiBrightWhite": "#7890A0",
    "terminalCursor.foreground": "#A0E8FF",
    "input.background": "#0E1218",
    "input.foreground": "#7890A0",
    "input.border": "#161A20",
    "input.placeholderForeground": "#476B8F",
    "button.background": "#A0E8FF",
    "button.foreground": "#04080E",
    "badge.background": "#A0E8FF",
    "badge.foreground": "#04080E",
    "focusBorder": "#A0E8FF66",
    "scrollbarSlider.background": "#476B8F22",
    "scrollbarSlider.hoverBackground": "#476B8F33",
    "gitDecoration.addedResourceForeground": "#D0EEFF",
    "gitDecoration.modifiedResourceForeground": "#807040",
    "gitDecoration.deletedResourceForeground": "#D03050",
    "gitDecoration.ignoredResourceForeground": "#476B8F",
    "diffEditor.insertedTextBackground": "#D0EEFF18",
    "diffEditor.removedTextBackground": "#D0305018",
    "minimap.findMatchHighlight": "#E0F8FF",
    "minimap.selectionHighlight": "#2B404ACC",
    "peekView.border": "#A0E8FF",
    "peekViewEditor.background": "#0E1218",
    "peekViewResult.background": "#00040A",
    "breadcrumb.foreground": "#476B8F",
    "breadcrumb.focusForeground": "#7890A0",
    "editorWidget.background": "#0E1218",
    "editorSuggestWidget.background": "#0E1218",
    "editorSuggestWidget.selectedBackground": "#2B404ACC",
    "editorHoverWidget.background": "#0E1218"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#7890A0"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#476B8F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D0EEFF"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#807040"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#807040"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#6890A8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C060E0"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#68C0E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#A0E8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#80D0F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#80D0F0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#9848C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#A050C8"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#7890A0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#9848C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#3A7860"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#60D8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E0F8FF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#A050C8"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C060E0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#476B8F"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#4C6278"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#366D8E"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#A0E8FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9848C0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#D03050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#3C6C90"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#807040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#6890A8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#80D0F0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#9848C0"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#A050C8"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#A0E8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#80D0F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#D0EEFF"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#68C0E8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#A0E8FF"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#A0E8FF",
      "bold": true
    },
    "method": {
      "foreground": "#A0E8FF",
      "bold": true
    },
    "class": {
      "foreground": "#80D0F0",
      "bold": true
    },
    "struct": {
      "foreground": "#80D0F0",
      "bold": true
    },
    "interface": {
      "foreground": "#80D0F0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#80D0F0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#9848C0",
      "bold": true
    },
    "type": {
      "foreground": "#80D0F0"
    },
    "typeParameter": {
      "foreground": "#9848C0",
      "italic": true
    },
    "variable": {
      "foreground": "#7890A0"
    },
    "variable.readonly": {
      "foreground": "#A050C8"
    },
    "property": {
      "foreground": "#3A7860"
    },
    "parameter": {
      "foreground": "#9848C0",
      "italic": true
    },
    "keyword": {
      "foreground": "#C060E0"
    },
    "string": {
      "foreground": "#D0EEFF"
    },
    "number": {
      "foreground": "#E0F8FF"
    },
    "comment": {
      "foreground": "#476B8F",
      "italic": true
    },
    "decorator": {
      "foreground": "#A050C8"
    },
    "namespace": {
      "foreground": "#366D8E"
    },
    "macro": {
      "foreground": "#6890A8",
      "bold": true
    },
    "lifetime": {
      "foreground": "#807040",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#60D8F0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#68C0E8",
      "bold": true
    },
    "operator": {
      "foreground": "#C060E0"
    },
    "*.unsafe": {
      "foreground": "#D03050"
    }
  }
}