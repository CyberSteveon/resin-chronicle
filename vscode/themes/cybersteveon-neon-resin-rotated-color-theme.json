    "editorRuler.foreground": "#281F22",
    "editorBracketMatch.background": "#7FEDF022",
    "editorBracketMatch.border": "#B5699E",
    "editorError.foreground": "#54FF43",
    "editorWarning.foreground": "#40FF92",
    "editorInfo.foreground": "#EF7EEC",
    "editorHint.foreground": "#A700C9",
    "editorGutter.background": "#160D10",
    "editorGutter.addedBackground": "#639AE8",
    "editorGutter.modifiedBackground": "#00CBFF",
    "editorGutter.deletedBackground": "#54FF43",
    "editorGroupHeader.tabsBackground": "#12090C",
    "tab.activeBackground": "#160D10",
    "tab.inactiveBackground": "#12090C",
    "tab.activeForeground": "#E0A7DC",
    "tab.inactiveForeground": "#875F6C",
    "tab.activeBorderTop": "#EF7EEC",
    "tab.border": "#281F22",
    "titleBar.activeBackground": "#12090C",
    "titleBar.activeForeground": "#E0A7DC",
    "titleBar.inactiveBackground": "#12090C",
    "titleBar.inactiveForeground": "#875F6C",
    "activityBar.background": "#20171A",
    "activityBar.foreground": "#E0A7DC",
    "activityBar.inactiveForeground": "#875F6C",
    "activityBar.border": "#281F22",
    "activityBarBadge.background": "#EF7EEC",
    "activityBarBadge.foreground": "#160D10",
    "sideBar.background": "#20171A",
    "sideBar.foreground": "#E0A7DC",
    "sideBar.border": "#281F22",
    "list.activeSelectionBackground": "#7FEDF044",
    "list.activeSelectionForeground": "#E0A7DC",
    "list.hoverBackground": "#23141A",
    "list.highlightForeground": "#EF7EEC",
    "statusBar.background": "#12090C",
    "statusBar.foreground": "#875F6C",
    "statusBar.border": "#281F22",
    "statusBarItem.remoteBackground": "#EF7EEC",
    "statusBarItem.remoteForeground": "#160D10",
    "panel.background": "#160D10",
    "panel.border": "#281F22",
    "terminal.background": "#160D10",
    "terminal.foreground": "#E0A7DC",
    "terminal.ansiBlack": "#12090C",
    "terminal.ansiRed": "#54FF43",
    "terminal.ansiGreen": "#639AE8",
    "terminal.ansiYellow": "#00CBFF",
    "terminal.ansiBlue": "#EF7EEC",
    "terminal.ansiMagenta": "#78FF2D",
    "terminal.ansiCyan": "#A700C9",
    "terminal.ansiWhite": "#875F6C",
    "terminal.ansiBrightBlack": "#875F6C",
    "terminal.ansiBrightRed": "#54FF43",
    "terminal.ansiBrightGreen": "#639AE8",
    "terminal.ansiBrightYellow": "#00CBFF",
    "terminal.ansiBrightBlue": "#EF7EEC",
    "terminal.ansiBrightMagenta": "#78FF2D",
    "terminal.ansiBrightCyan": "#EF7EEC",
    "terminal.ansiBrightWhite": "#E0A7DC",
    "terminalCursor.foreground": "#EF7EEC",
    "input.background": "#20171A",
    "input.foreground": "#E0A7DC",
    "input.border": "#281F22",
    "input.placeholderForeground": "#875F6C",
    "button.background": "#EF7EEC",
    "button.foreground": "#160D10",
    "badge.background": "#EF7EEC",
    "badge.foreground": "#160D10",
    "focusBorder": "#EF7EEC66",
    "scrollbarSlider.background": "#875F6C22",
    "scrollbarSlider.hoverBackground": "#875F6C33",
    "gitDecoration.addedResourceForeground": "#639AE8",
    "gitDecoration.modifiedResourceForeground": "#00CBFF",
    "gitDecoration.deletedResourceForeground": "#54FF43",
    "gitDecoration.ignoredResourceForeground": "#875F6C",
    "diffEditor.insertedTextBackground": "#639AE818",
    "diffEditor.removedTextBackground": "#54FF4318",
    "minimap.findMatchHighlight": "#00CBFF",
    "minimap.selectionHighlight": "#7FEDF044",
    "peekView.border": "#EF7EEC",
    "peekViewEditor.background": "#20171A",
    "peekViewResult.background": "#12090C",
    "breadcrumb.foreground": "#875F6C",
    "breadcrumb.focusForeground": "#E0A7DC",
    "editorWidget.background": "#20171A",
    "editorSuggestWidget.background": "#20171A",
    "editorSuggestWidget.selectedBackground": "#7FEDF044",
    "editorHoverWidget.background": "#20171A"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#E0A7DC"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#875F6C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#639AE8"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00CBFF"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#00CBFF"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#F1B7EE"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#78FF2D"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#A700C9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#EF7EEC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#00FF6D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#00FF6D"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#40FF92",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#78FF2D"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#E0A7DC"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#40FF92",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#B27ECF"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#FFB8D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#00CBFF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#78FF2D"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#78FF2D"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#875F6C"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#B5699E"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#EF7EEC"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#EF7EEC"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#40FF92"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#54FF43",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#44FF9B"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#00CBFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#F1B7EE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#00FF6D",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#40FF92"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#78FF2D"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#EF7EEC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#00FF6D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#639AE8"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#A700C9"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#EF7EEC"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#EF7EEC",
      "bold": true
    },
    "method": {
      "foreground": "#EF7EEC",
      "bold": true
    },
    "class": {
      "foreground": "#00FF6D",
      "bold": true
    },
    "struct": {
      "foreground": "#00FF6D",
      "bold": true
    },
    "interface": {
      "foreground": "#00FF6D",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#00FF6D",
      "bold": true
    },
    "enumMember": {
      "foreground": "#40FF92",
      "bold": true
    },
    "type": {
      "foreground": "#00FF6D"
    },
    "typeParameter": {
      "foreground": "#40FF92",
      "italic": true
    },
    "variable": {
      "foreground": "#E0A7DC"
    },
    "variable.readonly": {
      "foreground": "#78FF2D"
    },
    "property": {
      "foreground": "#B27ECF"
    },
    "parameter": {
      "foreground": "#40FF92",
      "italic": true
    },
    "keyword": {
      "foreground": "#78FF2D"
    },
    "string": {
      "foreground": "#639AE8"
    },
    "number": {
      "foreground": "#00CBFF"
    },
    "comment": {
      "foreground": "#875F6C",
      "italic": true
    },
    "decorator": {
      "foreground": "#78FF2D"
    },
    "namespace": {
      "foreground": "#EF7EEC"
    },
    "macro": {
      "foreground": "#F1B7EE",
      "bold": true
    },
    "lifetime": {
      "foreground": "#00CBFF",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#FFB8D4",
      "italic": true
    },
    "builtinType": {
      "foreground": "#A700C9",
      "bold": true
    },
    "operator": {
      "foreground": "#78FF2D"
    },
    "*.unsafe": {
      "foreground": "#54FF43"
    }
  }
}