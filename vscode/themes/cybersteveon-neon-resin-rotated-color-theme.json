    "editor.inactiveSelectionBackground": "#7FEDF022",
    "editor.findMatchBackground": "#00CBFF44",
    "editor.findMatchHighlightBackground": "#00CBFF22",
    "editor.findMatchBorder": "#00CBFF",
    "editor.wordHighlightBackground": "#7FEDF022",
    "editor.wordHighlightStrongBackground": "#7FEDF044",
    "editorLineNumber.foreground": "#875F6C",
    "editorLineNumber.activeForeground": "#EF7EEC",
    "editorWhitespace.foreground": "#875F6C",
    "editorIndentGuide.background1": "#281F22",
