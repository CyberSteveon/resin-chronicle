    },
    "keyword": {
      "foreground": "#78FF2D"
    },
    "modifier": {
      "foreground": "#78FF2D"
    },
    "string": {
      "foreground": "#639AE8"
    },
    "number": {
      "foreground": "#00CBFF"
    },
    "comment": {
      "foreground": "#553C44",
      "italic": true
    },
    "decorator": {
      "foreground": "#78FF2D"
    },
    "namespace": {
      "foreground": "#EF7EEC"
    },
    "macro": {
      "foreground": "#F1B7EE",
      "bold": true
    },
    "lifetime": {
      "foreground": "#00CBFF",
      "italic": true
