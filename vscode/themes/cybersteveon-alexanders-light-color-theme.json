{
  "name": "Alexander's Light",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080A08",
    "editor.foreground": "#808898",
    "editorCursor.foreground": "#E0D080",
    "editor.lineHighlightBackground": "#101410",
    "editor.selectionBackground": "#E0D08044",
    "editor.selectionHighlightBackground": "#E0D08022",
    "editor.inactiveSelectionBackground": "#E0D08022",
    "editor.findMatchBackground": "#F0E88044",
    "editor.findMatchHighlightBackground": "#F0E88022",
    "editor.findMatchBorder": "#F0E880",
    "editor.wordHighlightBackground": "#E0D08022",
    "editor.wordHighlightStrongBackground": "#E0D08044",
    "editorLineNumber.foreground": "#4F6F4F",
    "editorLineNumber.activeForeground": "#E0D080",
    "editorWhitespace.foreground": "#4F6F4F",
    "editorIndentGuide.background1": "#1A1C1A",
    "editorIndentGuide.activeBackground1": "#4F6F4F",
    "editorRuler.foreground": "#1A1C1A",
    "editorBracketMatch.background": "#E0D08022",
    "editorBracketMatch.border": "#58616B",
    "editorError.foreground": "#C04040",
    "editorWarning.foreground": "#708090",
    "editorInfo.foreground": "#90C0F0",
    "editorHint.foreground": "#6090C8",
    "editorGutter.background": "#080A08",
    "editorGutter.addedBackground": "#C0E0FF",
    "editorGutter.modifiedBackground": "#607868",
    "editorGutter.deletedBackground": "#C04040",
    "editorGroupHeader.tabsBackground": "#040604",
    "tab.activeBackground": "#080A08",
    "tab.inactiveBackground": "#040604",
    "tab.activeForeground": "#808898",
    "tab.inactiveForeground": "#4F6F4F",
    "tab.activeBorderTop": "#E0D080",
    "tab.border": "#1A1C1A",
    "titleBar.activeBackground": "#040604",
    "titleBar.activeForeground": "#808898",
    "titleBar.inactiveBackground": "#040604",
    "titleBar.inactiveForeground": "#4F6F4F",
    "activityBar.background": "#121412",
    "activityBar.foreground": "#808898",
    "activityBar.inactiveForeground": "#4F6F4F",
    "activityBar.border": "#1A1C1A",
    "activityBarBadge.background": "#E0D080",
    "activityBarBadge.foreground": "#080A08",
    "sideBar.background": "#121412",
    "sideBar.foreground": "#808898",
    "sideBar.border": "#1A1C1A",
    "list.activeSelectionBackground": "#E0D08044",
    "list.activeSelectionForeground": "#808898",
    "list.hoverBackground": "#101410",
    "list.highlightForeground": "#E0D080",
    "statusBar.background": "#040604",
    "statusBar.foreground": "#4F6F4F",
    "statusBar.border": "#1A1C1A",
    "statusBarItem.remoteBackground": "#E0D080",
    "statusBarItem.remoteForeground": "#080A08",
    "panel.background": "#080A08",
    "panel.border": "#1A1C1A",
    "terminal.background": "#080A08",
    "terminal.foreground": "#808898",
    "terminal.ansiBlack": "#040604",
    "terminal.ansiRed": "#C04040",
    "terminal.ansiGreen": "#C0E0FF",
    "terminal.ansiYellow": "#607868",
    "terminal.ansiBlue": "#90C0F0",
    "terminal.ansiMagenta": "#E0D080",
    "terminal.ansiCyan": "#6090C8",
    "terminal.ansiWhite": "#4F6F4F",
    "terminal.ansiBrightBlack": "#4F6F4F",
    "terminal.ansiBrightRed": "#C04040",
    "terminal.ansiBrightGreen": "#C0E0FF",
    "terminal.ansiBrightYellow": "#F0E880",
    "terminal.ansiBrightBlue": "#90C0F0",
    "terminal.ansiBrightMagenta": "#E080C0",
    "terminal.ansiBrightCyan": "#E0D080",
    "terminal.ansiBrightWhite": "#808898",
    "terminalCursor.foreground": "#E0D080",
    "input.background": "#121412",
    "input.foreground": "#808898",
    "input.border": "#1A1C1A",
    "input.placeholderForeground": "#4F6F4F",
    "button.background": "#E0D080",
    "button.foreground": "#080A08",
    "badge.background": "#E0D080",
    "badge.foreground": "#080A08",
    "focusBorder": "#E0D08066",
    "scrollbarSlider.background": "#4F6F4F22",
    "scrollbarSlider.hoverBackground": "#4F6F4F33",
    "gitDecoration.addedResourceForeground": "#C0E0FF",
    "gitDecoration.modifiedResourceForeground": "#607868",
    "gitDecoration.deletedResourceForeground": "#C04040",
    "gitDecoration.ignoredResourceForeground": "#4F6F4F",
    "diffEditor.insertedTextBackground": "#C0E0FF18",
    "diffEditor.removedTextBackground": "#C0404018",
    "minimap.findMatchHighlight": "#F0E880",
    "minimap.selectionHighlight": "#E0D08044",
    "peekView.border": "#E0D080",
    "peekViewEditor.background": "#121412",
    "peekViewResult.background": "#040604",
    "breadcrumb.foreground": "#4F6F4F",
    "breadcrumb.focusForeground": "#808898",
    "editorWidget.background": "#121412",
    "editorSuggestWidget.background": "#121412",
    "editorSuggestWidget.selectedBackground": "#E0D08044",
    "editorHoverWidget.background": "#121412"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#808898"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4F6F4F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C0E0FF"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#607868"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp",
        "meta.regex"
      ],
      "settings": {
        "foreground": "#607868"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#7090A8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E0D080"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#6090C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#90C0F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#A0B0C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#A0B0C0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#B0A050",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#808898"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#708090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#508060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#A0E0D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#F0E880"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#E0D080"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#4F6F4F"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#58616B"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#507090"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#90C0F0"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B0A050"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C04040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#4E6C76"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#607868",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#7090A8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#A0B0C0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#B0A050"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#90C0F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#A0B0C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C0E0FF"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#6090C8"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#90C0F0"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#90C0F0",
      "bold": true
    },
    "method": {
      "foreground": "#90C0F0",
      "bold": true
    },
    "class": {
      "foreground": "#A0B0C0",
      "bold": true
    },
    "struct": {
      "foreground": "#A0B0C0",
      "bold": true
    },
    "interface": {
      "foreground": "#A0B0C0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#A0B0C0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#B0A050",
      "bold": true
    },
    "type": {
      "foreground": "#A0B0C0"
    },
    "typeParameter": {
      "foreground": "#708090",
      "italic": true
    },
    "variable": {
      "foreground": "#808898"
    },
    "variable.readonly": {
      "foreground": "#E080C0"
    },
    "property": {
      "foreground": "#508060"
    },
    "parameter": {
      "foreground": "#708090",
      "italic": true
    },
    "keyword": {
      "foreground": "#E0D080"
    },
    "string": {
      "foreground": "#C0E0FF"
    },
    "number": {
      "foreground": "#F0E880"
    },
    "comment": {
      "foreground": "#4F6F4F",
      "italic": true
    },
    "decorator": {
      "foreground": "#E080C0"
    },
    "namespace": {
      "foreground": "#507090"
    },
    "macro": {
      "foreground": "#7090A8",
      "bold": true
    },
    "lifetime": {
      "foreground": "#607868",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#A0E0D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#6090C8",
      "bold": true
    },
    "operator": {
      "foreground": "#E0D080"
    },
    "*.unsafe": {
      "foreground": "#C04040"
    }
  }
}