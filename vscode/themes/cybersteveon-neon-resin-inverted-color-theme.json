    "list.activeSelectionBackground": "#401713CC",
    "list.activeSelectionForeground": "#BD4D47",
    "list.hoverBackground": "#252018",
    "list.highlightForeground": "#DE1F1A",
    "statusBar.background": "#1A1612",
    "statusBar.foreground": "#C2BAAA",
    "statusBar.border": "#302C28",
    "statusBarItem.remoteBackground": "#DE1F1A",
    "statusBarItem.remoteForeground": "#1E1A16",
    "panel.background": "#1E1A16",
