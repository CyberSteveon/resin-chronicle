    "terminal.ansiCyan": "#FF3658",
    "terminal.ansiWhite": "#C2BAAA",
    "terminal.ansiBrightBlack": "#C2BAAA",
    "terminal.ansiBrightRed": "#00BBAA",
    "terminal.ansiBrightGreen": "#9A35E2",
    "terminal.ansiBrightYellow": "#6943FF",
    "terminal.ansiBrightBlue": "#DE1F1A",
    "terminal.ansiBrightMagenta": "#00D287",
    "terminal.ansiBrightCyan": "#DE1F1A",
    "terminal.ansiBrightWhite": "#BD4D47",
    "terminalCursor.foreground": "#DE1F1A",
    "input.background": "#282420",
