    },
    "comment": {
      "foreground": "#C2BAAA",
      "italic": true
    },
    "decorator": {
      "foreground": "#00D287"
    },
    "namespace": {
      "foreground": "#80120F"
    },
    "macro": {
      "foreground": "#47100E",
      "bold": true
    },
    "lifetime": {
      "foreground": "#3300FF",
      "italic": true
