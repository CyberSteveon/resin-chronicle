{
  "name": "Neon Resin Ultra",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#050609",
    "editor.foreground": "#9ED8DC",
    "editorCursor.foreground": "#CEFBFC",
    "editor.lineHighlightBackground": "#080A0E",
    "editor.selectionBackground": "#2F5659CC",
    "editor.selectionHighlightBackground": "#2F565966",
    "editor.inactiveSelectionBackground": "#2F565988",
    "editor.findMatchBackground": "#D8FF3F44",
    "editor.findMatchHighlightBackground": "#D8FF3F22",
    "editor.findMatchBorder": "#D8FF3F",
    "editor.wordHighlightBackground": "#2F565966",
    "editor.wordHighlightStrongBackground": "#2F5659CC",
    "editorLineNumber.foreground": "#596884",
    "editorLineNumber.activeForeground": "#CEFBFC",
    "editorWhitespace.foreground": "#596884",
    "editorIndentGuide.background1": "#17181B",
    "editorIndentGuide.activeBackground1": "#596884",
    "editorRuler.foreground": "#17181B",
    "editorBracketMatch.background": "#2F565966",
    "editorBracketMatch.border": "#96BFD0",
    "editorError.foreground": "#FF949E",
    "editorWarning.foreground": "#FEBF8F",
    "editorInfo.foreground": "#CEFBFC",
    "editorHint.foreground": "#00FBD0",
    "editorGutter.background": "#050609",
    "editorGutter.addedBackground": "#C8F8A6",
    "editorGutter.modifiedBackground": "#D8FF3F",
    "editorGutter.deletedBackground": "#FF949E",
    "editorGroupHeader.tabsBackground": "#010205",
    "tab.activeBackground": "#050609",
    "tab.inactiveBackground": "#010205",
    "tab.activeForeground": "#9ED8DC",
    "tab.inactiveForeground": "#596884",
    "tab.activeBorderTop": "#CEFBFC",
    "tab.border": "#17181B",
    "titleBar.activeBackground": "#010205",
    "titleBar.activeForeground": "#9ED8DC",
    "titleBar.inactiveBackground": "#010205",
    "titleBar.inactiveForeground": "#596884",
    "activityBar.background": "#0F1013",
    "activityBar.foreground": "#9ED8DC",
    "activityBar.inactiveForeground": "#596884",
    "activityBar.border": "#17181B",
    "activityBarBadge.background": "#CEFBFC",
    "activityBarBadge.foreground": "#050609",
    "sideBar.background": "#0F1013",
    "sideBar.foreground": "#9ED8DC",
    "sideBar.border": "#17181B",
    "list.activeSelectionBackground": "#2F5659CC",
    "list.activeSelectionForeground": "#9ED8DC",
    "list.hoverBackground": "#080A0E",
    "list.highlightForeground": "#CEFBFC",
    "statusBar.background": "#010205",
    "statusBar.foreground": "#596884",
    "statusBar.border": "#17181B",
    "statusBarItem.remoteBackground": "#CEFBFC",
    "statusBarItem.remoteForeground": "#050609",
    "panel.background": "#050609",
    "panel.border": "#17181B",
    "terminal.background": "#050609",
    "terminal.foreground": "#9ED8DC",
    "terminal.ansiBlack": "#010205",
    "terminal.ansiRed": "#FF949E",
    "terminal.ansiGreen": "#C8F8A6",
    "terminal.ansiYellow": "#D8FF3F",
    "terminal.ansiBlue": "#CEFBFC",
    "terminal.ansiMagenta": "#FF78A8",
    "terminal.ansiCyan": "#00FBD0",
    "terminal.ansiWhite": "#596884",
    "terminal.ansiBrightBlack": "#596884",
    "terminal.ansiBrightRed": "#FF949E",
    "terminal.ansiBrightGreen": "#C8F8A6",
    "terminal.ansiBrightYellow": "#D8FF3F",
    "terminal.ansiBrightBlue": "#CEFBFC",
    "terminal.ansiBrightMagenta": "#FF78A8",
    "terminal.ansiBrightCyan": "#CEFBFC",
    "terminal.ansiBrightWhite": "#9ED8DC",
    "terminalCursor.foreground": "#CEFBFC",
    "input.background": "#0F1013",
    "input.foreground": "#9ED8DC",
    "input.border": "#17181B",
    "input.placeholderForeground": "#596884",
    "button.background": "#CEFBFC",
    "button.foreground": "#050609",
    "badge.background": "#CEFBFC",
    "badge.foreground": "#050609",
    "focusBorder": "#CEFBFC66",
    "scrollbarSlider.background": "#59688422",
    "scrollbarSlider.hoverBackground": "#59688433",
    "gitDecoration.addedResourceForeground": "#C8F8A6",
    "gitDecoration.modifiedResourceForeground": "#D8FF3F",
    "gitDecoration.deletedResourceForeground": "#FF949E",
    "gitDecoration.ignoredResourceForeground": "#596884",
    "diffEditor.insertedTextBackground": "#C8F8A618",
    "diffEditor.removedTextBackground": "#FF949E18",
    "minimap.findMatchHighlight": "#D8FF3F",
    "minimap.selectionHighlight": "#2F5659CC",
    "peekView.border": "#CEFBFC",
    "peekViewEditor.background": "#0F1013",
    "peekViewResult.background": "#010205",
    "breadcrumb.foreground": "#596884",
    "breadcrumb.focusForeground": "#9ED8DC",
    "editorWidget.background": "#0F1013",
    "editorSuggestWidget.background": "#0F1013",
    "editorSuggestWidget.selectedBackground": "#2F5659CC",
    "editorHoverWidget.background": "#0F1013"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#9ED8DC"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#596884",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C8F8A6"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D8FF3F"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#D8FF3F"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#F1FCFD"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF78A8"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#00FBD0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#CEFBFC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FF913F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF913F"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#FEBF8F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#FF78A8"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#9ED8DC"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FEBF8F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#B7E8D7"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#EFF5FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D8FF3F"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#FF78A8"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#FF78A8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#596884"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#96BFD0"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#CEFBFC"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#CEFBFC"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FEBF8F"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FF949E",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#FEC696"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#D8FF3F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#F1FCFD",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#FF913F",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#FEBF8F"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#FF78A8"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#CEFBFC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF913F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C8F8A6"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#00FBD0"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#CEFBFC"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#CEFBFC",
      "bold": true
    },
    "method": {
      "foreground": "#CEFBFC",
      "bold": true
    },
    "class": {
      "foreground": "#FF913F",
      "bold": true
    },
    "struct": {
      "foreground": "#FF913F",
      "bold": true
    },
    "interface": {
      "foreground": "#FF913F",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#FF913F",
      "bold": true
    },
    "enumMember": {
      "foreground": "#FEBF8F",
      "bold": true
    },
    "type": {
      "foreground": "#FF913F"
    },
    "typeParameter": {
      "foreground": "#FEBF8F",
      "italic": true
    },
    "variable": {
      "foreground": "#9ED8DC"
    },
    "variable.readonly": {
      "foreground": "#FF78A8"
    },
    "property": {
      "foreground": "#B7E8D7"
    },
    "parameter": {
      "foreground": "#FEBF8F",
      "italic": true
    },
    "keyword": {
      "foreground": "#FF78A8"
    },
    "string": {
      "foreground": "#C8F8A6"
    },
    "number": {
      "foreground": "#D8FF3F"
    },
    "comment": {
      "foreground": "#596884",
      "italic": true
    },
    "decorator": {
      "foreground": "#FF78A8"
    },
    "namespace": {
      "foreground": "#CEFBFC"
    },
    "macro": {
      "foreground": "#F1FCFD",
      "bold": true
    },
    "lifetime": {
      "foreground": "#D8FF3F",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#EFF5FF",
      "italic": true
    },
    "builtinType": {
      "foreground": "#00FBD0",
      "bold": true
    },
    "operator": {
      "foreground": "#FF78A8"
    },
    "*.unsafe": {
      "foreground": "#FF949E"
    }
  }
}