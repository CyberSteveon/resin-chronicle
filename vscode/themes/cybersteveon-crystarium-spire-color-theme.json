{
  "name": "Crystarium Spire",
  "author": "CyberSteveOn",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#08080E",
    "editor.foreground": "#9088A8",
    "editorCursor.foreground": "#E0C060",
    "editor.lineHighlightBackground": "#100F1C",
    "editor.selectionBackground": "#3E3622CC",
    "editor.selectionHighlightBackground": "#3E362266",
    "editor.inactiveSelectionBackground": "#3E362288",
    "editor.findMatchBackground": "#F0D86044",
    "editor.findMatchHighlightBackground": "#F0D86022",
    "editor.findMatchBorder": "#F0D860",
    "editor.wordHighlightBackground": "#3E362266",
    "editor.wordHighlightStrongBackground": "#3E3622CC",
    "editorLineNumber.foreground": "#7358AB",
    "editorLineNumber.activeForeground": "#E0C060",
    "editorWhitespace.foreground": "#7358AB",
    "editorIndentGuide.background1": "#1A1A20",
    "editorIndentGuide.activeBackground1": "#7358AB",
    "editorRuler.foreground": "#1A1A20",
    "editorBracketMatch.background": "#3E362266",
    "editorBracketMatch.border": "#62588A",
    "editorError.foreground": "#C04050",
    "editorWarning.foreground": "#C09030",
    "editorInfo.foreground": "#E0C060",
    "editorHint.foreground": "#B89040",
    "editorGutter.background": "#08080E",
    "editorGutter.addedBackground": "#C0A8E0",
    "editorGutter.modifiedBackground": "#806080",
    "editorGutter.deletedBackground": "#C04050",
    "editorGroupHeader.tabsBackground": "#04040A",
    "tab.activeBackground": "#08080E",
    "tab.inactiveBackground": "#04040A",
    "tab.activeForeground": "#9088A8",
    "tab.inactiveForeground": "#7358AB",
    "tab.activeBorderTop": "#E0C060",
    "tab.border": "#1A1A20",
    "titleBar.activeBackground": "#04040A",
    "titleBar.activeForeground": "#9088A8",
    "titleBar.inactiveBackground": "#04040A",
    "titleBar.inactiveForeground": "#7358AB",
    "activityBar.background": "#121218",
    "activityBar.foreground": "#9088A8",
    "activityBar.inactiveForeground": "#7358AB",
    "activityBar.border": "#1A1A20",
    "activityBarBadge.background": "#E0C060",
    "activityBarBadge.foreground": "#08080E",
    "sideBar.background": "#121218",
    "sideBar.foreground": "#9088A8",
    "sideBar.border": "#1A1A20",
    "list.activeSelectionBackground": "#3E3622CC",
    "list.activeSelectionForeground": "#9088A8",
    "list.hoverBackground": "#100F1C",
    "list.highlightForeground": "#E0C060",
    "statusBar.background": "#04040A",
    "statusBar.foreground": "#7358AB",
    "statusBar.border": "#1A1A20",
    "statusBarItem.remoteBackground": "#E0C060",
    "statusBarItem.remoteForeground": "#08080E",
    "panel.background": "#08080E",
    "panel.border": "#1A1A20",
    "terminal.background": "#08080E",
    "terminal.foreground": "#9088A8",
    "terminal.ansiBlack": "#04040A",
    "terminal.ansiRed": "#C04050",
    "terminal.ansiGreen": "#C0A8E0",
    "terminal.ansiYellow": "#806080",
    "terminal.ansiBlue": "#E0C060",
    "terminal.ansiMagenta": "#A060E0",
    "terminal.ansiCyan": "#B89040",
    "terminal.ansiWhite": "#7358AB",
    "terminal.ansiBrightBlack": "#7358AB",
    "terminal.ansiBrightRed": "#C04050",
    "terminal.ansiBrightGreen": "#C0A8E0",
    "terminal.ansiBrightYellow": "#F0D860",
    "terminal.ansiBrightBlue": "#E0C060",
    "terminal.ansiBrightMagenta": "#E080C0",
    "terminal.ansiBrightCyan": "#E0C060",
    "terminal.ansiBrightWhite": "#9088A8",
    "terminalCursor.foreground": "#E0C060",
    "input.background": "#121218",
    "input.foreground": "#9088A8",
    "input.border": "#1A1A20",
    "input.placeholderForeground": "#7358AB",
    "button.background": "#E0C060",
    "button.foreground": "#08080E",
    "badge.background": "#E0C060",
    "badge.foreground": "#08080E",
    "focusBorder": "#E0C06066",
    "scrollbarSlider.background": "#7358AB22",
    "scrollbarSlider.hoverBackground": "#7358AB33",
    "gitDecoration.addedResourceForeground": "#C0A8E0",
    "gitDecoration.modifiedResourceForeground": "#806080",
    "gitDecoration.deletedResourceForeground": "#C04050",
    "gitDecoration.ignoredResourceForeground": "#7358AB",
    "diffEditor.insertedTextBackground": "#C0A8E018",
    "diffEditor.removedTextBackground": "#C0405018",
    "minimap.findMatchHighlight": "#F0D860",
    "minimap.selectionHighlight": "#3E3622CC",
    "peekView.border": "#E0C060",
    "peekViewEditor.background": "#121218",
    "peekViewResult.background": "#04040A",
    "breadcrumb.foreground": "#7358AB",
    "breadcrumb.focusForeground": "#9088A8",
    "editorWidget.background": "#121218",
    "editorSuggestWidget.background": "#121218",
    "editorSuggestWidget.selectedBackground": "#3E3622CC",
    "editorHoverWidget.background": "#121218"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#9088A8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7358AB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C0A8E0"
      }
    },
    {
      "name": "Escapes",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#806080"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "source.regexp"
      ],
      "settings": {
        "foreground": "#806080"
      }
    },
    {
      "name": "Interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#806898"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A060E0"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.function.builtin",
        "support.function",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#B89040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#E0C060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#80B8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#80B8F0"
      }
    },
    {
      "name": "Enum variants",
      "scope": [
        "entity.name.enum",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#C09030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#9088A8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C09030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Fields",
      "scope": [
        "variable.other.member",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#508060"
      }
    },
    {
      "name": "Self/this",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#80E0D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#F0D860"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#A060E0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7358AB"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.namespace"
      ],
      "settings": {
        "foreground": "#62588A"
      }
    },
    {
      "name": "Imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#7458AB"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#E0C060"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C09030"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#C04050",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Visibility",
      "scope": [
        "storage.modifier.visibility",
        "storage.modifier.pub"
      ],
      "settings": {
        "foreground": "#735CA1"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "storage.modifier.lifetime.rust",
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#806080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "support.macro.rust",
        "entity.name.macro.rust"
      ],
      "settings": {
        "foreground": "#806898",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust traits",
      "scope": [
        "entity.name.trait.rust"
      ],
      "settings": {
        "foreground": "#80B8F0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Rust enum variants",
      "scope": [
        "entity.name.enum.rust"
      ],
      "settings": {
        "foreground": "#C09030"
      }
    },
    {
      "name": "Rust derive",
      "scope": [
        "meta.attribute.rust"
      ],
      "settings": {
        "foreground": "#E080C0"
      }
    },
    {
      "name": "MD headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E0C060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#80B8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MD code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#C0A8E0"
      }
    },
    {
      "name": "MD links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#B89040"
      }
    },
    {
      "name": "JSON/YAML keys",
      "scope": [
        "meta.mapping.key.json",
        "keyword.key.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#E0C060"
      }
    }
  ],
  "semanticTokenColors": {
    "function": {
      "foreground": "#E0C060",
      "bold": true
    },
    "method": {
      "foreground": "#E0C060",
      "bold": true
    },
    "class": {
      "foreground": "#80B8F0",
      "bold": true
    },
    "struct": {
      "foreground": "#80B8F0",
      "bold": true
    },
    "interface": {
      "foreground": "#80B8F0",
      "bold": true,
      "italic": true
    },
    "enum": {
      "foreground": "#80B8F0",
      "bold": true
    },
    "enumMember": {
      "foreground": "#C09030",
      "bold": true
    },
    "type": {
      "foreground": "#80B8F0"
    },
    "typeParameter": {
      "foreground": "#C09030",
      "italic": true
    },
    "variable": {
      "foreground": "#9088A8"
    },
    "variable.readonly": {
      "foreground": "#E080C0"
    },
    "property": {
      "foreground": "#508060"
    },
    "parameter": {
      "foreground": "#C09030",
      "italic": true
    },
    "keyword": {
      "foreground": "#A060E0"
    },
    "string": {
      "foreground": "#C0A8E0"
    },
    "number": {
      "foreground": "#F0D860"
    },
    "comment": {
      "foreground": "#7358AB",
      "italic": true
    },
    "decorator": {
      "foreground": "#E080C0"
    },
    "namespace": {
      "foreground": "#7458AB"
    },
    "macro": {
      "foreground": "#806898",
      "bold": true
    },
    "lifetime": {
      "foreground": "#806080",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#80E0D0",
      "italic": true
    },
    "builtinType": {
      "foreground": "#B89040",
      "bold": true
    },
    "operator": {
      "foreground": "#A060E0"
    },
    "*.unsafe": {
      "foreground": "#C04050"
    }
  }
}